<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "Add Product",
           description: "Optionally look up an identifier, or enter product details directly." %>

<% if @match_context&.valid? %>
  <%= render "shared/request_match_banner", context: @match_context %>
<% end %>

<%= form_with url: items_add_item_path(step: "choose_path"), method: :post, class: "ss-form ss-form--standard" do %>
  <%= render "shared/request_match_params_fields", context: @match_context if @match_context&.active? %>
  <%= render layout: "shared/forms/section", locals: { title: "How do you want to start?" } do %>
    <div class="ss-choice-list" role="radiogroup" aria-label="Add product assist">
      <label class="ss-choice-option" for="assist_lookup">
        <%= radio_button_tag :assist, "lookup", @draft["assist"] == "lookup", id: "assist_lookup" %>
        <div>
          <span class="ss-choice-title">Look up by identifier</span>
          <p class="ss-help">Search ISBN/UPC or external catalog, then review and save as a Product.</p>
        </div>
      </label>
      <label class="ss-choice-option" for="assist_manual">
        <%= radio_button_tag :assist, "manual", @draft["assist"] != "lookup", id: "assist_manual" %>
        <div>
          <span class="ss-choice-title">Enter product details</span>
          <p class="ss-help">Open the Product form directly. Type defaults to Book; change Type for music, service, and other kinds.</p>
        </div>
      </label>
    </div>
  <% end %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Continue", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Search for existing item", variant: :secondary, url: items_root_path(@match_context&.param_hash || {}) %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: (@match_context&.return_path || items_root_path) %>
  </footer>
<% end %>
