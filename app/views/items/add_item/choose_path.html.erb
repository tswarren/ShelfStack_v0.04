<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "Add Item",
           description: "What kind of item are you adding?" %>

<% if @match_context&.valid? %>
  <%= render "shared/request_match_banner", context: @match_context %>
<% end %>

<%= form_with url: items_add_item_path(step: "choose_path"), method: :post, class: "ss-form ss-form--standard" do %>
  <%= render "shared/request_match_params_fields", context: @match_context if @match_context&.active? %>
  <%= render layout: "shared/forms/section", locals: { title: "Creation Path" } do %>
    <div class="ss-choice-list" role="radiogroup" aria-label="Creation path">
      <label class="ss-choice-option" for="workflow_catalog_linked">
        <%= radio_button_tag :workflow, "catalog_linked", @draft["workflow"] == "catalog_linked", id: "workflow_catalog_linked" %>
        <div>
          <span class="ss-choice-title">Catalog-linked item</span>
          <p class="ss-help">Books, media, gifts, and other items with bibliographic or catalog metadata. Catalog-linked items start with ISBN lookup.</p>
        </div>
      </label>
      <label class="ss-choice-option" for="workflow_non_catalog">
        <%= radio_button_tag :workflow, "non_catalog", @draft["workflow"] == "non_catalog", id: "workflow_non_catalog" %>
        <div>
          <span class="ss-choice-title">Non-catalog item</span>
          <p class="ss-help">Services, fees, donations, gift cards, and simple merchandise without catalog metadata.</p>
        </div>
      </label>
    </div>
  <% end %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Continue", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Search for existing item", variant: :secondary, url: items_root_path(@match_context&.param_hash || {}) %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: (@match_context&.return_path || items_root_path) %>
  </footer>
<% end %>
