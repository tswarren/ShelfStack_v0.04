<h1>Add Item — Step 4: Selling Setup</h1>

<%= form_with model: @product, url: items_add_item_path(step: "selling_setup"), method: :post do |f| %>
  <% if @product.errors.any? %>
    <div class="flash flash-alert"><%= @product.errors.full_messages.to_sentence %></div>
  <% end %>
  <%= f.hidden_field :catalog_item_id, value: @catalog_item.id %>
  <%= f.label :name %><%= f.text_field :name, value: @product.name.presence || ProductNameRenderer.product_name(@product) %>
  <%= f.label :sku, "SKU (leave blank for catalog default)" %><%= f.text_field :sku %>
  <p class="ss-hint">Source: catalog primary identifier (<%= @catalog_item.primary_identifier&.normalized_identifier %>)</p>
  <%= f.label :list_price_cents, "List price (cents)" %><%= f.number_field :list_price_cents, min: 0, value: @product.list_price_cents || 0 %>
  <%= f.label :default_display_location_id, "Default display location" %>
  <%= f.collection_select :default_display_location_id, @display_locations, :id, :name, include_blank: true %>
  <%= f.submit "Continue", class: "ss-btn" %>
<% end %>

<p><%= link_to "Back", items_add_item_path(step: "catalog_details") %></p>
