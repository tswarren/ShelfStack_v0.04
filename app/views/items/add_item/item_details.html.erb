<%= render "shared/forms/page_header",
           eyebrow: "Add Product",
           title: "Product details",
           description: if @external_lookup_staged
                          "Review imported metadata, edit as needed, then save the Product."
                        elsif @entry_context&.short_form?
                          "Enter Service or Non-Inventory details. Save with a default variant, or save the Product only."
                        else
                          "Enter product metadata and defaults. Save and continue to Create Variant, or save the Product only."
                        end %>

<%= render "items/add_item/match_context" %>

<%= form_with url: items_add_item_path(step: "item_details"), method: :post, class: "ss-form ss-form--wide" do %>
  <%= render "shared/request_match_params_fields", context: @match_context if @match_context&.active? %>
  <%= fields_for :catalog_item, @product do |f| %>
    <%= render "items/catalog_items/form",
          f: f,
          catalog_item: @product,
          formats: @formats,
          include_identifier: !@external_lookup_staged,
          primary_bisac_category_node_id: @primary_bisac_category_node_id,
          primary_bisac_category_node_label: @primary_bisac_category_node_label,
          bisac_category_node_ids: @bisac_category_node_ids,
          bisac_scheme_loaded: @bisac_scheme_loaded,
          store_category_nodes: @store_category_nodes,
          entry_context: @entry_context %>
  <% end %>
  <footer class="ss-form-actions">
    <% if @entry_context&.short_form? %>
      <%= render "shared/ui/button", label: "Save Product and Create Default Variant", type: :submit, variant: :primary %>
    <% else %>
      <%= render "shared/ui/button", label: "Save and Create Variant", type: :submit, variant: :primary %>
    <% end %>
    <%= render "shared/ui/button", label: "Save Product Only", type: :submit, variant: :secondary, name: "commit" %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: add_item_cancel_path %>
  </footer>
<% end %>
