<fieldset class="ss-form-section">
  <legend>Sellable SKU</legend>
  <%= f.label :attribute1_value, product.variant1_label.presence || "Attribute 1 value" %>
  <%= f.text_field :attribute1_value, data: { preview_target: "variant-attr1-value" } %>
  <%= f.label :attribute1_sku_component, "Attribute 1 SKU component" %>
  <%= f.text_field :attribute1_sku_component, maxlength: 5, data: { preview_target: "variant-attr1-sku" } %>
  <%= f.label :attribute2_value, product.variant2_label.presence || "Attribute 2 value" %>
  <%= f.text_field :attribute2_value, data: { preview_target: "variant-attr2-value" } %>
  <%= f.label :attribute2_sku_component, "Attribute 2 SKU component" %>
  <%= f.text_field :attribute2_sku_component, maxlength: 5, data: { preview_target: "variant-attr2-sku" } %>
  <%= f.label :name_override, "Name override (optional)" %>
  <%= f.text_field :name_override, data: { preview_target: "variant-name-override" } %>
  <p class="ss-hint">Name preview: <span data-preview="variant-name"><%= product.name %></span></p>
  <%= f.label :sku, "SKU (leave blank to generate)" %>
  <%= f.text_field :sku, maxlength: 50, value: variant.sku, data: { preview_target: "variant-sku-manual", auto_generated: true } %>
  <p class="ss-hint">SKU preview: <span data-preview="variant-sku"><%= variant_sku_preview(product) %></span></p>
  <%= f.label :selling_price_cents, "Selling price (cents)" %>
  <%= f.number_field :selling_price_cents, min: 0, value: variant.selling_price_cents, data: { preview_target: "variant-selling-price", auto_generated: true } %>
  <%= f.label :category_id, "Category" %>
  <%= f.collection_select :category_id, categories, :id, :name, selected: variant.category_id %>
  <%= f.label :display_location_id, "Display location" %>
  <%= f.collection_select :display_location_id, display_locations, :id, :name, include_blank: true %>
</fieldset>
<%= render "items/add_item/sellable_sku_preview_script", product: product, conditions: [] %>
