<%= render "shared/forms/page_header",
           eyebrow: "Add Item",
           title: "Identify by ISBN",
           description: "Scan or enter an ISBN to search local products and ISBNdb." %>

<%= render "items/add_item/match_context" %>

<% if @local_product.present? %>
  <div class="ss-notice ss-notice--info">
    <p><strong>Local match found:</strong> <%= @local_product.display_title %></p>
    <p>
      <%= link_to "Continue with this product", items_add_item_path(step: "item_details"), class: "ss-btn ss-btn-secondary" %>
      <%= link_to "View product", items_item_path(product_id: @local_product.id), class: "ss-btn ss-btn-secondary" %>
      <% if @match_context&.from_customer_request? && @local_match_variant.present? %>
        <%= button_to "Match existing variant to request",
              match_variant_customers_customer_request_path(@match_context.request_record, line_id: @match_context.line_id, product_variant_id: @local_match_variant.id),
              method: :post,
              class: "ss-btn ss-btn-secondary" %>
      <% elsif @match_context&.from_buyback_line? && @local_match_variant.present? %>
        <%= button_to "Match existing variant to buyback line",
              select_variant_buybacks_session_line_path(@match_context.session_record, @match_context.line, product_variant_id: @local_match_variant.id),
              method: :post,
              class: "ss-btn ss-btn-secondary" %>
      <% end %>
    </p>
  </div>
<% end %>

<%= form_with url: items_external_lookup_path, method: :post, class: "ss-form ss-form--standard" do %>
  <%= render "shared/request_match_params_fields", context: @match_context if @match_context&.active? %>
  <%= render layout: "shared/forms/section", locals: { title: "ISBN Lookup" } do %>
    <div class="ss-field">
      <%= label_tag :isbn, "ISBN" %>
      <%= text_field_tag :isbn, params[:isbn], autofocus: true, autocomplete: "off", inputmode: "numeric", class: "ss-input" %>
      <p class="ss-help">Press Enter or Continue to run a local-first lookup.</p>
    </div>
  <% end %>
  <footer class="ss-form-actions">
    <%= submit_tag "Continue", class: "ss-btn" %>
    <%= link_to "Enter details manually", items_add_item_path(step: "item_details"), class: "ss-btn ss-btn-secondary" %>
    <%= link_to "Back", items_add_item_path(step: "choose_path"), class: "ss-btn ss-btn-secondary" %>
    <%= link_to "Cancel", add_item_cancel_path, class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
