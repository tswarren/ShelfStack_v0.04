<%= render "shared/forms/page_header",
           eyebrow: "Add Item",
           title: "Identify by ISBN",
           description: "Scan or enter an ISBN to search local products and ISBNdb." %>

<%= render "items/add_item/match_context" %>

<% if @local_product.present? %>
  <div class="ss-notice ss-notice--info">
    <p><strong>Local match found:</strong> <%= @local_product.display_title %></p>
    <div class="ss-inline-actions">
      <%= render "shared/ui/button", label: "Continue with this product", variant: :secondary, url: items_add_item_path(step: "item_details") %>
      <%= render "shared/ui/button", label: "View product", variant: :secondary, url: items_item_path(product_id: @local_product.id) %>
      <% if @match_context&.from_demand_line? && @local_match_variant.present? %>
        <%= render "shared/ui/button",
                   label: "Match existing variant to demand",
                   variant: :secondary,
                   url: match_variant_demand_demand_line_path(@match_context.demand_line),
                   method: :post,
                   params: { product_variant_id: @local_match_variant.id } %>
      <% elsif @match_context&.from_buyback_line? && @local_match_variant.present? %>
        <%= render "shared/ui/button",
                   label: "Match existing variant to buyback line",
                   variant: :secondary,
                   url: select_variant_buybacks_session_line_path(@match_context.session_record, @match_context.line, product_variant_id: @local_match_variant.id),
                   method: :post %>
      <% end %>
    </div>
  </div>
<% end %>

<%= form_with url: items_external_lookup_path, method: :post, class: "ss-form ss-form--standard" do %>
  <%= render "shared/request_match_params_fields", context: @match_context if @match_context&.active? %>
  <%= render layout: "shared/forms/section", locals: { title: "ISBN Lookup" } do %>
    <div class="ss-field">
      <%= label_tag :isbn, "ISBN" %>
      <%= text_field_tag :isbn, params[:isbn], autofocus: true, autocomplete: "off", inputmode: "numeric", class: "ss-input" %>
      <p class="ss-help">Press Enter or Continue to run a local-first lookup.</p>
    </div>
  <% end %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Continue", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Enter details manually", variant: :secondary, url: items_add_item_path(step: "item_details") %>
    <%= render "shared/ui/button", label: "Back", variant: :secondary, url: items_add_item_path(step: "choose_path") %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: add_item_cancel_path %>
  </footer>
<% end %>
