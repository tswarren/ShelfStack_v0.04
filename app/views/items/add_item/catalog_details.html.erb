<h1>Add Item — Step 3: Catalog Details</h1>

<%= form_with url: items_add_item_path(step: "catalog_details"), method: :post do %>
  <%= fields_for :catalog_item, @catalog_item do |f| %>
    <%= render "items/catalog_items/form",
          f: f,
          catalog_item: @catalog_item,
          formats: @formats,
          include_identifier: true %>
  <% end %>
  <%= submit_tag "Continue", class: "ss-btn" %>
<% end %>

<p><%= link_to "Back", items_add_item_path(step: "type") %></p>
