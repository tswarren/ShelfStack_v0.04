<%= form_with model: product, url: items_add_item_path(step: "selling_setup"), method: :post, class: "ss-form ss-form--wide", html: { multipart: true } do |f| %>
  <%= render "shared/forms/errors", record: product %>
  <%= render "items/shared/product_forms/non_catalog",
             f: f,
             product: product,
             display_locations: display_locations,
             sub_departments: sub_departments,
             generated_sku: generated_sku,
             require_sku: true,
             description: "Define the product before creating sellable SKUs." %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Add Sellable SKU", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Done", type: :submit, variant: :secondary, name: "commit" %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: items_root_path %>
  </footer>
<% end %>

<div class="ss-inline-actions">
  <%= render "shared/ui/button",
             label: "Generate SKU",
             variant: :secondary,
             size: :small,
             url: items_add_item_path(step: "selling_setup"),
             method: :post,
             params: { generate_sku: "1" } %>
  <%= render "shared/ui/button", label: "Back", variant: :link, url: items_add_item_path(step: "choose_path") %>
</div>
