<%= form_with model: product, url: items_add_item_path(step: "selling_setup"), method: :post, class: "ss-form ss-form--wide", html: { multipart: true } do |f| %>
  <%= render "shared/forms/errors", record: product %>
  <%= render "items/shared/product_forms/non_catalog",
             f: f,
             product: product,
             display_locations: display_locations,
             sub_departments: sub_departments,
             generated_sku: generated_sku,
             require_sku: true,
             description: "Define the product before creating sellable SKUs." %>
  <footer class="ss-form-actions">
    <%= f.submit "Add Sellable SKU", class: "ss-btn" %>
    <%= submit_tag "Done", name: "commit", class: "ss-btn ss-btn-secondary" %>
    <%= link_to "Cancel", items_root_path, class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>

<p class="ss-form-actions" style="margin-top: 0.5rem;">
  <%= button_to "Generate SKU", items_add_item_path(step: "selling_setup"), method: :post,
        params: { generate_sku: "1" }, class: "ss-btn ss-btn-secondary ss-btn-small" %>
  <%= link_to "Back", items_add_item_path(step: "choose_path") %>
</p>
