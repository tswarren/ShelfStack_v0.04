<script>
  document.addEventListener("DOMContentLoaded", function() {
    var conditionSelect = document.querySelector("[data-preview-target='variant-condition']");
    var attr1Value = document.querySelector("[data-preview-target='variant-attr1-value']");
    var attr2Value = document.querySelector("[data-preview-target='variant-attr2-value']");
    var nameOverride = document.querySelector("[data-preview-target='variant-name-override']");
    var attr1Sku = document.querySelector("[data-preview-target='variant-attr1-sku']");
    var attr2Sku = document.querySelector("[data-preview-target='variant-attr2-sku']");
    var skuManual = document.querySelector("[data-preview-target='variant-sku-manual']");
    var sellingPrice = document.querySelector("[data-preview-target='variant-selling-price']");
    var skuPreview = document.querySelector("[data-preview='variant-sku']");
    var namePreview = document.querySelector("[data-preview='variant-name']");
    var product = <%= raw({ sku: product.sku, name: product.name, variation_type: product.variation_type, list_price_cents: product.list_price_cents.to_i }.to_json) %>;
    var conditions = <%= raw conditions.map { |c| { id: c.id, sku_component: c.sku_component, short_name: c.short_name, default_list_price_factor_bps: c.default_list_price_factor_bps.to_i } }.to_json %>;

    if (skuManual && skuManual.value.trim()) {
      skuManual.dataset.autoGenerated = "true";
    }
    if (sellingPrice && sellingPrice.value.trim()) {
      sellingPrice.dataset.autoGenerated = "true";
    }

    function selectedCondition() {
      if (!conditionSelect || !conditionSelect.value) return null;
      var id = parseInt(conditionSelect.value, 10);
      return conditions.find(function(c) { return c.id === id; });
    }

    function computedSku() {
      var base = product.sku;
      if (!base) return "";
      var condition = selectedCondition();
      var a1 = attr1Sku ? attr1Sku.value.trim().toUpperCase() : "";
      var a2 = attr2Sku ? attr2Sku.value.trim().toUpperCase() : "";
      var parts = [];
      if (condition && condition.sku_component) parts.push(condition.sku_component);
      if (product.variation_type === "variable" && a1) parts.push(a1);
      if (product.variation_type === "matrix") { if (a1) parts.push(a1); if (a2) parts.push(a2); }
      return parts.length ? base + "-" + parts.join("-") : base;
    }

    function computedSellingPrice() {
      var price = product.list_price_cents || 0;
      if (product.variation_type === "conditional") {
        var condition = selectedCondition();
        if (condition) {
          price = Math.floor(price * condition.default_list_price_factor_bps / 10000);
        }
      }
      return price;
    }

    function previewSku() {
      var sku = computedSku();
      if (skuPreview) skuPreview.textContent = sku || "—";
      if (skuManual && skuManual.dataset.autoGenerated === "true") {
        skuManual.value = sku;
      }
    }

    function previewSellingPrice() {
      if (!sellingPrice || sellingPrice.dataset.autoGenerated !== "true") return;
      sellingPrice.value = computedSellingPrice();
    }

    function previewName() {
      if (!namePreview) return;
      var override = nameOverride ? nameOverride.value.trim() : "";
      if (override) { namePreview.textContent = override; return; }
      var base = product.name || "—";
      var condition = selectedCondition();
      var a1 = attr1Value ? attr1Value.value.trim() : "";
      var a2 = attr2Value ? attr2Value.value.trim() : "";
      var name = base;
      if (product.variation_type === "conditional" && condition && condition.short_name) {
        name = base + " - " + condition.short_name;
      } else if (product.variation_type === "variable" && a1) {
        name = base + " - " + a1;
      } else if (product.variation_type === "matrix") {
        if (a1 && a2) name = base + " - " + a1 + " / " + a2;
        else if (a1) name = base + " - " + a1;
      }
      namePreview.textContent = name;
    }

    function refresh() {
      previewSku();
      previewSellingPrice();
      previewName();
    }

    if (skuManual) {
      skuManual.addEventListener("input", function() { skuManual.dataset.autoGenerated = "false"; });
    }
    if (sellingPrice) {
      sellingPrice.addEventListener("input", function() { sellingPrice.dataset.autoGenerated = "false"; });
    }

    [conditionSelect, attr1Value, attr2Value, nameOverride, attr1Sku, attr2Sku].forEach(function(el) {
      if (el) { el.addEventListener("change", refresh); el.addEventListener("input", refresh); }
    });
    refresh();
  });
</script>
