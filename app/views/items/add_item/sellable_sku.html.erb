<%= render "shared/forms/page_header",
           eyebrow: "Add Item",
           title: "Create Sellable SKU",
           description: "Product: #{@product.name} · SKU #{@product.sku}" %>

<%= render "items/add_item/match_context" %>

<%= form_with model: @variant, url: items_add_item_path(step: "sellable_sku"), method: :post, class: "ss-form ss-form--wide" do |f| %>
  <%= render "shared/request_match_params_fields", context: @match_context if @match_context&.active? %>
  <%= render "items/shared/variant_forms/chooser",
             f: f,
             variant: @variant,
             product: @product,
             products: [@product],
             sub_departments: @sub_departments,
             conditions: @conditions,
             display_locations: @display_locations,
             vendors: @vendors,
             lock_product: true,
             show_advanced: false %>

  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create SKU", type: :submit, variant: :primary, name: "commit" %>
    <%= render "shared/ui/button", label: "Create SKU and Add Another", type: :submit, variant: :secondary, name: "commit" %>
    <%= render "shared/ui/button",
               label: "Cancel",
               variant: :tertiary,
               url: (@match_context&.valid? ? add_item_cancel_path : Items::ItemPresenter.from_product(@product).show_path) %>
  </footer>
<% end %>

<p><%= render "shared/ui/button", label: "Back", variant: :link, url: items_add_item_path(step: "selling_setup") %></p>
