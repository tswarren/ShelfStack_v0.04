<h1>Add Item — Step 2: Item Type</h1>

<%= form_with url: items_add_item_path(step: "type"), method: :post do %>
  <%= label_tag :catalog_item_type, "What kind of item is this?" %>
  <%= select_tag :catalog_item_type,
        options_for_select(CatalogItem::CATALOG_ITEM_TYPES.map { |t| [humanize_controlled_value(t), t] }, @draft["catalog_item_type"]),
        include_blank: false %>
  <%= submit_tag "Continue", class: "ss-btn" %>
<% end %>

<p><%= link_to "Back", items_add_item_path(step: "identify") %></p>
