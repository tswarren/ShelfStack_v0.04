<%# locals: catalog_item: nil, product: nil, identifier: nil, error_message: nil %>
<% product ||= local_assigns[:product] %>
<% product ||= catalog_item&.products&.active_records&.order(:id)&.first if catalog_item.present? %>
<% if product.blank? %>
  <p class="ss-muted">Create a product before managing identifiers.</p>
<% else %>
<% editing = identifier.present? %>
<% form_url = if editing
  items_setup_modals_identifier_path(identifier, product_id: product.id)
else
  items_setup_modals_identifiers_path(product_id: product.id)
end %>
<% form_method = editing ? :patch : :post %>

<% error_message = local_assigns[:error_message] %>
<% if error_message.present? %>
  <div class="ss-errors"><%= error_message %></div>
<% end %>

<%= form_with url: form_url,
              method: form_method,
              data: {
                turbo_stream: true,
                create_url: items_setup_modals_identifiers_path(product_id: product.id)
              },
              class: "ss-form ss-form--standard" do |f| %>
  <div class="ss-field">
    <%= label_tag :identifier_type, "Type", class: "ss-label" %>
    <%= select_tag :identifier_type,
          options_for_select(ProductIdentifierService::LEGACY_IDENTIFIER_TYPES.map { |t| [t.upcase, t] }, product_identifier_legacy_type(identifier) || "isbn13"),
          class: "ss-input",
          disabled: editing,
          data: { item_setup_modal_target: "identifierTypeField" } %>
  </div>
  <div class="ss-field">
    <%= label_tag :identifier_value, "Value", class: "ss-label" %>
    <%= text_field_tag :identifier_value,
          identifier&.identifier_value,
          required: true,
          class: "ss-input",
          data: { item_setup_modal_target: "identifierValueField" } %>
  </div>
  <div class="ss-field">
    <%= label_tag :primary, "Set as primary", class: "ss-label" %>
    <%= check_box_tag :primary, "1", identifier&.primary_identifier?,
          data: { item_setup_modal_target: "primaryField" } %>
  </div>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: (editing ? "Save identifier" : "Add identifier"), type: :submit, variant: :primary %>
    <%= render "shared/ui/button",
               label: "Cancel",
               variant: :tertiary,
               type: :button,
               data: { action: "modal#close", modal_target_id_param: "item-identifier-modal" } %>
  </footer>
<% end %>
<% end %>
