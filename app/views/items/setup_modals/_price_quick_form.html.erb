<%# locals: variant: %>
<% if variant.errors.any? %>
  <div class="ss-errors"><%= variant.errors.full_messages.to_sentence %></div>
<% end %>

<%= form_with url: items_setup_modals_variant_price_path(variant),
              method: :patch,
              data: { turbo_stream: true },
              class: "ss-form ss-form--standard" do %>
  <%= hidden_field_tag :variant_id, variant.id %>
  <div class="ss-field">
    <%= label_tag :selling_price_cents, "Selling price (cents)", class: "ss-label" %>
    <%= number_field_tag :selling_price_cents,
          variant.selling_price_cents,
          min: 0,
          required: true,
          class: "ss-input",
          data: { item_setup_modal_target: "priceField" } %>
  </div>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Save price", type: :submit, variant: :primary %>
    <%= render "shared/ui/button",
               label: "Cancel",
               variant: :tertiary,
               type: :button,
               data: { action: "modal#close", modal_target_id_param: "item-price-modal" } %>
    <%= render "shared/ui/button",
               label: "Full edit",
               variant: :link,
               url: edit_items_product_variant_path(variant, return_to: "item"),
               data: { turbo_frame: "_top" } %>
  </footer>
<% end %>
