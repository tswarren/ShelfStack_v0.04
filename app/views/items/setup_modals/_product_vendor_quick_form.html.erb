<%# locals: product:, product_vendor:, vendors: %>
<% editing = product_vendor.persisted? %>
<% form_url = editing ? items_setup_modals_product_vendor_path(product_vendor) : items_setup_modals_product_vendors_path %>
<% form_method = editing ? :patch : :post %>

<% if product_vendor.errors.any? %>
  <div class="ss-errors"><%= product_vendor.errors.full_messages.to_sentence %></div>
<% end %>

<%= form_with model: product_vendor,
              url: form_url,
              method: form_method,
              data: { turbo_stream: true },
              class: "ss-form ss-form--standard" do |f| %>
  <%= hidden_field_tag :product_id, product.id %>
  <% unless editing %>
    <div class="ss-field">
      <%= f.label :vendor_id, "Vendor", class: "ss-label" %>
      <%= f.collection_select :vendor_id, vendors, :id, :name, { include_blank: true }, class: "ss-input", required: true %>
    </div>
  <% else %>
    <p class="ss-hint"><strong><%= product_vendor.vendor.name %></strong></p>
  <% end %>
  <div class="ss-field">
    <%= f.label :vendor_item_number, "Vendor item #", class: "ss-label" %>
    <%= f.text_field :vendor_item_number, class: "ss-input" %>
  </div>
  <div class="ss-field">
    <%= f.label :supplier_discount_bps, "Supplier discount (bps)", class: "ss-label" %>
    <%= f.number_field :supplier_discount_bps, min: 0, max: 10_000, class: "ss-input" %>
  </div>
  <div class="ss-field">
    <%= f.label :preferred, class: "ss-label" %>
    <%= f.check_box :preferred %>
  </div>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button",
               label: (editing ? "Save vendor source" : "Add vendor source"),
               type: :submit,
               variant: :primary %>
    <%= render "shared/ui/button",
               label: "Cancel",
               variant: :tertiary,
               type: :button,
               data: { action: "modal#close", modal_target_id_param: "item-product-vendor-modal" } %>
    <% if editing %>
      <%= render "shared/ui/button",
                 label: "Full edit",
                 variant: :link,
                 url: edit_items_product_product_vendor_path(product, product_vendor),
                 data: { turbo_frame: "_top" } %>
    <% else %>
      <%= render "shared/ui/button",
                 label: "Full form",
                 variant: :link,
                 url: new_items_product_product_vendor_path(product),
                 data: { turbo_frame: "_top" } %>
    <% end %>
  </footer>
<% end %>
