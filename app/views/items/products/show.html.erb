<%= render "setup/shared/back_link", path: items_products_path, label: "Products" %>

<%
  header_actions = if @product.active?
                     safe_join([
                       render("shared/ui/button", label: "New Variant", variant: :secondary, url: new_items_product_variant_path(product_id: @product.id)),
                       render("shared/ui/button", label: "Regenerate Name", variant: :secondary, url: regenerate_name_items_product_path(@product), method: :patch),
                       render("shared/ui/button", label: "Inactivate", variant: :secondary, url: inactivate_items_product_path(@product), method: :patch),
                       render("shared/ui/button", label: "Edit", variant: :primary, url: edit_items_product_path(@product))
                     ])
                   else
                     safe_join([
                       render("shared/ui/button", label: "New Variant", variant: :secondary, url: new_items_product_variant_path(product_id: @product.id)),
                       render("shared/ui/button", label: "Regenerate Name", variant: :secondary, url: regenerate_name_items_product_path(@product), method: :patch),
                       render("shared/ui/button", label: "Edit", variant: :secondary, url: edit_items_product_path(@product)),
                       render("shared/ui/button", label: "Reactivate", variant: :primary, url: reactivate_items_product_path(@product), method: :patch)
                     ])
                   end
%>

<%= render "shared/ui/page_header", title: @product.name, actions: header_actions %>

<% if @product.cover_image.attached? %>
  <div class="ss-cover-preview">
    <%= product_cover_image_tag(@product.cover_image, size: :hero, alt: "Cover image for #{@product.name}") %>
  </div>
<% end %>

<dl class="ss-summary">
  <dt>SKU</dt><dd><%= @product.sku %></dd>
  <dt>Catalog item</dt><dd><%= @product.catalog_item&.title || "—" %></dd>
  <dt>Product type</dt><dd><%= humanize_controlled_value(@product.product_type) %></dd>
  <dt>Variation type</dt><dd><%= humanize_controlled_value(@product.variation_type) %></dd>
  <dt>List price</dt><dd><%= format_cents(@product.list_price_cents) %></dd>
  <dt>Sellable</dt><dd><%= @product.sellable? ? "Yes" : "No" %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@product.active?), status: @product.active? ? :active : :inactive) %></dd>
</dl>

<h2>Variants</h2>
<% if @variants.any? %>
  <table class="ss-table">
    <thead><tr><th>Name</th><th>SKU</th><th>Price</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @variants.each do |variant| %>
        <tr>
          <td><%= variant.name %></td>
          <td><%= variant.sku %></td>
          <td><%= format_cents(variant.selling_price_cents) %></td>
          <td><%= ss_status_badge(status_label(variant.active?), status: variant.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", items_product_variant_path(variant) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="ss-muted">No variants yet.</p>
<% end %>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "product-danger-zone-heading",
           message: "Delete removes the product only when nothing references it. Prefer inactivating.",
           delete_label: "Delete product",
           delete_path: items_product_path(@product),
           confirm_message: "Delete this product?" %>
