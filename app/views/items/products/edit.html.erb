<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "Edit Product",
           description: @product.metadata_fused? ? "Update product details, classification, and selling defaults." : "Update selling setup for this item." %>

<%= form_with model: [:items, @product], class: "ss-form ss-form--wide", html: { multipart: true } do |f| %>
  <%= render "items/shared/return_to_item" %>
  <% if @product.metadata_fused? && @entry_context.present? %>
    <%= render "items/shared/product_forms/metadata/form",
          f: f,
          record: @product,
          entry_context: @entry_context,
          store_category_nodes: @store_category_nodes,
          vendors: @vendors,
          display_locations: @display_locations,
          include_identifier: false,
          primary_bisac_category_node_id: @primary_bisac_category_node_id,
          primary_bisac_category_node_label: @primary_bisac_category_node_label,
          bisac_category_node_ids: @bisac_category_node_ids || [],
          bisac_scheme_loaded: @bisac_scheme_loaded,
          primary_genre_category_node_id: @genre_form_state&.dig(:primary_genre_category_node_id),
          primary_genre_category_node_label: @genre_form_state&.dig(:primary_genre_category_node_label),
          genre_category_node_ids: @genre_form_state&.dig(:genre_category_node_ids) || [],
          genre_scheme_loaded: @genre_form_state&.dig(:genre_scheme_loaded) %>
  <% elsif @product.catalog_item.present? %>
    <%= render "items/shared/product_forms/catalog_linked",
               f: f,
               product: @product,
               catalog_item: @product.catalog_item,
               sub_departments: @sub_departments,
               display_locations: @display_locations,
               vendors: @vendors %>
  <% else %>
    <%= render "items/shared/product_forms/non_catalog",
               f: f,
               product: @product,
               sub_departments: @sub_departments,
               display_locations: @display_locations,
               vendors: @vendors %>
  <% end %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Update Product", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: item_flow_cancel_path(@product, tab: "item_setup") %>
  </footer>
<% end %>
