<% new_product_action = render("shared/ui/button", label: "New", variant: :primary, url: new_items_product_path) %>

<%= render "setup/shared/back_link", path: items_root_path, label: "Items" %>

<%= render "shared/ui/page_header",
           title: "Products",
           description: "Legacy admin list for store-facing products.",
           actions: new_product_action %>

<% if @products.any? %>
  <table class="ss-table">
    <thead><tr><th>Cover</th><th>Name</th><th>SKU</th><th>Type</th><th>Sellable</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td class="ss-table-cover"><%= item_cover_thumbnail(Items::ItemPresenter.from_product(product), size: :index) %></td>
          <td><%= product.name %></td>
          <td><%= product.sku %></td>
          <td><%= humanize_controlled_value(product.product_type) %></td>
          <td><%= product.sellable? ? "Yes" : "No" %></td>
          <td><%= ss_status_badge(status_label(product.active?), status: product.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", items_product_path(product) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No products yet",
             message: "Create a product from the Items workspace or this admin list.",
             actions: new_product_action %>
<% end %>
