<% operations_tab = local_assigns[:operations_tab] %>
<% operations = local_assigns[:operations] %>
<% overview = local_assigns[:overview] %>

<div data-controller="drawer item-variant-ops-drawer"
     data-item-variant-ops-drawer-url-value="<%= items_variant_operations_drawer_path %>"
     data-action="drawer:closed->item-variant-ops-drawer#resetOnClose">
<% if request_match_context.valid? %>
  <%= render "shared/request_match_banner", context: request_match_context %>
<% end %>

<% if operations_tab&.highlight_variant.present? %>
  <div class="ss-sidebar-card">
    <h2>Variant focus</h2>
    <p>
      <%= operations_tab.highlight_variant.sku %> —
      <%= operations_tab.highlight_variant.name %>
    </p>
    <%= render "shared/ui/button",
               label: "Show all variants",
               variant: :link,
               url: item.tab_path("operations") %>
  </div>
<% end %>

<% if operations&.variant_rows&.any? %>
  <h2>Variant operations</h2>
  <table class="ss-table">
    <thead>
      <tr>
        <th>SKU</th>
        <th>Status</th>
        <th class="ss-num">Available</th>
        <th class="ss-num">Reserved</th>
        <th class="ss-num">On hand</th>
        <th class="ss-num">On order avail.</th>
        <th class="ss-num">Ready pickup</th>
        <th class="ss-num">Open TBO</th>
        <th class="ss-num">Pending PO</th>
        <th class="ss-num">On order</th>
        <th>Preferred vendor</th>
        <th>Vendor source</th>
        <th>Vendor #</th>
        <th>Returnability</th>
        <th>Last received</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% operations.variant_rows.each do |row| %>
        <tr class="<%= "ss-table-row--highlight" if operations_tab&.highlight_variant&.id == row.variant.id %>">
          <td><%= row.variant.sku %></td>
          <td>
            <% ProductVariants::OperationalPolicy.for(row.variant).operational_badges.each do |badge| %>
              <span class="ss-badge ss-badge--muted"><%= badge.label %></span>
            <% end %>
          </td>
          <td class="ss-num"><%= row.available.nil? ? "—" : row.available %></td>
          <td class="ss-num"><%= row.reserved.nil? ? "—" : row.reserved %></td>
          <td class="ss-num"><%= row.on_hand.nil? ? "—" : row.on_hand %></td>
          <td class="ss-num"><%= row.on_order_available.nil? ? "—" : row.on_order_available %></td>
          <td class="ss-num"><%= row.ready_for_pickup_qty %></td>
          <td class="ss-num"><%= row.open_tbo %></td>
          <td class="ss-num"><%= row.pending_po.nil? ? "—" : row.pending_po %></td>
          <td class="ss-num"><%= row.on_order.nil? ? "—" : row.on_order %></td>
          <td><%= row.preferred_vendor_name || "—" %></td>
          <td><%= row.preferred_vendor_source.present? ? humanize_controlled_value(row.preferred_vendor_source) : "—" %></td>
          <td><%= row.vendor_item_number || "—" %></td>
          <td><%= row.returnability_status.present? ? row.returnability_status.humanize : "—" %></td>
          <td>
            <% if row.last_received.present? %>
              <%= l(row.last_received.received_at.to_date) %>
            <% else %>
              —
            <% end %>
          </td>
          <td>
            <%= render "shared/ui/button",
                       label: "Focus",
                       variant: :link,
                       url: items_item_path_with_match(item, tab: "operations", variant_id: row.variant.id) %>
            <%= render "shared/ui/button",
                       label: "Details",
                       variant: :secondary,
                       size: :small,
                       type: :button,
                       data: {
                         action: "item-variant-ops-drawer#prepareOpen drawer#open",
                         drawer_target_id_param: "item-variant-ops-drawer",
                         variant_id: row.variant.id,
                         variant_sku: row.variant.sku,
                         variant_name: row.variant.name
                       } %>
            <% if request_match_context.valid? &&
                  Authorization.allowed?(user: current_user, permission_key: "demand.match_variant", store: current_store) %>
              <%= render "shared/ui/button",
                         label: "Match",
                         variant: :primary,
                         size: :small,
                         url: match_variant_demand_demand_line_path(request_match_context.demand_line),
                         method: :post,
                         params: { product_variant_id: row.variant.id } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <p class="ss-hint">Select <strong>Details</strong> on a variant row to view demand, purchasing, receiving, and recent sales.</p>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No variant operations yet",
             message: "Create sellable SKUs in Item setup to review demand, purchasing, and inventory signals here." %>
<% end %>

<section id="receiving-history" class="ss-item-anchor-section" aria-label="Receiving history">
  <h2>Receiving history</h2>
  <p class="ss-hint">Receiving, purchase order, and return details are shown by variant in the Operations drawer.</p>
</section>

<% if local_assigns[:operational_warnings].present? %>
  <%= render "items/shared/operational_warnings_panel",
        warnings: operational_warnings,
        group_by: :variant,
        variants: item.variants %>
<% end %>

<% if operations_tab&.sales_visible? && operations_tab.sales_history_rows.any? %>
    <section id="sales-history" class="ss-item-section" aria-label="Sales history">
      <h2>Sales history</h2>
      <table class="ss-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>SKU</th>
            <th class="ss-num">Qty</th>
            <th class="ss-num">Net sales</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% operations_tab.sales_history_rows.each do |row| %>
            <tr>
              <td><%= l(row.sold_at, format: :short) %></td>
              <td><%= row.variant_sku %></td>
              <td class="ss-num"><%= row.quantity %></td>
              <td class="ss-num"><%= format_cents(row.net_sales_cents) %></td>
              <td><%= render "shared/ui/button", label: "Transaction", variant: :link, url: pos_transaction_path(row.transaction) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
<% end %>

<%= render "items/items/variant_operations_drawer", operations: operations %>
</div>
