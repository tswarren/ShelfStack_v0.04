<%= form_with url: items_demand_path,
              method: :post,
              class: "ss-form ss-form--standard",
              data: {
                turbo_stream: true,
                controller: "customer-request-hold-form",
                customer_request_hold_form_available_value: 0,
                customer_request_hold_form_on_hand_value: 0,
                customer_request_hold_form_can_override_value: false
              } do %>
  <%= hidden_field_tag :capture_intent, nil, data: { item_variant_ops_drawer_target: "requestTypeField" } %>
  <%= hidden_field_tag :product_variant_id, nil, data: { item_variant_ops_drawer_target: "productVariantField" } %>

  <div data-controller="customer-lookup"
       data-customer-lookup-url-value="<%= customers_customer_lookup_path %>"
       data-item-variant-ops-drawer-target="customerFields">
    <%= render layout: "shared/forms/section", locals: {
      title: "Customer",
      description: "Search for an existing customer or capture a walk-in snapshot."
    } do %>
      <div class="ss-field">
        <%= label_tag :customer_lookup, "Customer", class: "ss-label" %>
        <%= text_field_tag :customer_lookup, nil,
              class: "ss-input",
              placeholder: "Search by name, email, or phone…",
              autocomplete: "off",
              data: {
                customer_lookup_target: "lookupInput",
                action: "keydown->customer-lookup#lookupExact input->customer-lookup#search"
              } %>
        <%= hidden_field_tag :customer_id, nil, data: { customer_lookup_target: "customerId" } %>
        <p class="ss-hint" data-customer-lookup-target="preview"></p>
        <p class="ss-hint" data-customer-lookup-target="message"></p>
        <div class="ss-pos-choices" data-customer-lookup-target="choices"></div>
      </div>

      <div data-customer-lookup-target="walkInFields">
        <div class="ss-form-grid ss-form-grid--2">
          <div class="ss-field">
            <%= label_tag :customer_name_snapshot, "Walk-in name", class: "ss-label" %>
            <%= text_field_tag :customer_name_snapshot, nil, class: "ss-input" %>
          </div>
          <div class="ss-field">
            <%= label_tag :preferred_contact_method, "Preferred contact", class: "ss-label" %>
            <%= select_tag :preferred_contact_method,
                  options_for_select(DemandLine::PREFERRED_CONTACT_METHODS.map { |m| [customers_preferred_contact_label(m), m] }),
                  include_blank: true,
                  class: "ss-input" %>
          </div>
          <div class="ss-field">
            <%= label_tag :customer_email_snapshot, "Walk-in email", class: "ss-label" %>
            <%= email_field_tag :customer_email_snapshot, nil, class: "ss-input" %>
          </div>
          <div class="ss-field">
            <%= label_tag :customer_phone_snapshot, "Walk-in phone", class: "ss-label" %>
            <%= text_field_tag :customer_phone_snapshot, nil, class: "ss-input" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%= render layout: "shared/forms/section", locals: {
    title: "Demand",
    description: "Records customer or store demand intent. Inventory is not reserved until a later milestone."
  } do %>
    <div class="ss-form-grid ss-form-grid--2">
      <div class="ss-field">
        <%= label_tag :needed_by_date, "Needed by", class: "ss-label" %>
        <%= date_field_tag :needed_by_date, nil, class: "ss-input" %>
      </div>
      <div class="ss-field">
        <%= label_tag :quantity, "Quantity", class: "ss-label" %>
        <%= number_field_tag :quantity, 1, min: 1, class: "ss-input" %>
      </div>
    </div>

    <div data-item-variant-ops-drawer-target="holdFields" hidden>
      <div class="ss-form-grid ss-form-grid--2">
        <div class="ss-field">
          <%= label_tag :expires_at, "Hold expires on", class: "ss-label" %>
          <%= date_field_tag :expires_at, 14.days.from_now.to_date, class: "ss-input" %>
        </div>
      </div>
      <p class="ss-hint">On-hand holds reserve stock when allocated. Use quantity above available only with override permission.</p>
    </div>

    <p class="ss-hint" data-item-variant-ops-drawer-target="specialOrderNote" hidden>
      A linked customer record is required for special orders. Search for an existing customer or create one first.
    </p>

    <p class="ss-hint" data-item-variant-ops-drawer-target="notifyNote" hidden>
      Creates a notify request. Staff will contact the customer when stock is available. No inventory is reserved.
    </p>

    <p class="ss-hint" data-item-variant-ops-drawer-target="usedWantedNote" hidden>
      Records interest in a used copy. No vendor ordering path applies.
    </p>

    <p class="ss-hint" data-item-variant-ops-drawer-target="replenishmentNote" hidden>
      Creates shelf replenishment demand. No customer is required.
    </p>

    <div class="ss-field">
      <%= label_tag :notes, "Notes", class: "ss-label" %>
      <%= text_area_tag :notes, nil, rows: 2, class: "ss-input" %>
    </div>
  <% end %>

  <footer class="ss-form-actions">
    <%= submit_tag "Submit",
          class: "ss-btn",
          data: { item_variant_ops_drawer_target: "submitButton" } %>
    <button type="button" class="ss-btn ss-btn-secondary"
            data-action="drawer#close"
            data-drawer-target-id-param="item-variant-ops-drawer">Cancel</button>
  </footer>
<% end %>
