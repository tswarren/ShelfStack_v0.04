<% product = item.product %>
<% catalog_item = item.catalog_item %>
<% setup_product = product || catalog_item&.products&.active_records&.first %>
<% setup_catalog_item = catalog_item || product&.catalog_item %>
<% metadata_source = product.presence || setup_catalog_item %>
<% item_flow = { return_to: "item" } %>

<% if metadata_source.present? %>
  <% thumbnail = product.cover_image if product&.cover_image&.attached? %>
  <% thumbnail ||= setup_catalog_item.primary_thumbnail if setup_catalog_item&.primary_thumbnail&.attached? %>
  <% if thumbnail&.attached? %>
    <div class="ss-item-cover-preview">
      <%= product_cover_image_tag(thumbnail, size: :hero, alt: "Item thumbnail") %>
    </div>
  <% end %>
  <dl class="ss-summary">
    <dt>Type</dt><dd><%= humanize_controlled_value(metadata_source.catalog_item_type) %></dd>
    <dt>Format</dt><dd><%= metadata_source.format&.name || "—" %></dd>
    <dt>Publisher</dt><dd><%= metadata_source.publisher || "—" %></dd>
    <dt>Creators</dt><dd><%= metadata_source.creators || "—" %></dd>
    <dt>Publication status</dt><dd><%= humanize_controlled_value(metadata_source.publication_status) %></dd>
  </dl>
  <% if setup_product.blank? %>
    <p class="ss-muted">Create a product to enable operational use (sellable SKUs, inventory, and POS).</p>
  <% end %>
<% else %>
  <p class="ss-muted">Create a product to enable operational use (sellable SKUs, inventory, and POS).</p>
<% end %>

<% if setup_product.present? || setup_catalog_item.present? %>
  <h2>Product identifiers</h2>
  <table class="ss-table">
    <thead>
      <tr>
        <th>Type</th>
        <th>Value</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% identifiers.each do |identifier| %>
        <% display_type = product_identifier_display_type(identifier) %>
        <% barcode_safe = product_identifier_barcode_safe?(identifier) %>
        <tr>
          <td><%= display_type.upcase %></td>
          <td>
            <span class="ss-identifier-value<%= " ss-barcode-value" if barcode_safe %>">
              <%= identifier.normalized_identifier %>
              <% if identifier.primary_identifier? %>
                <%= identifier_primary_badge %>
              <% end %>
              <% if identifier.valid_check_digit == false %>
                <%= identifier_invalid_badge %>
              <% end %>
            </span>
          </td>
          <td class="ss-row-actions">
            <% if setup_product.present? && Authorization.allowed?(user: current_user, permission_key: "items.catalog_items.update", store: current_store) %>
              <%= render "shared/ui/button",
                         label: "Quick edit",
                         variant: :link,
                         type: :button,
                         data: {
                           action: "item-setup-modal#prepareIdentifierEdit modal#open",
                           modal_target_id_param: "item-identifier-modal",
                           identifier_value: identifier.identifier_value,
                           identifier_type: product_identifier_legacy_type(identifier),
                           primary: identifier.primary_identifier?,
                           update_url: items_setup_modals_identifier_path(identifier, product_id: setup_product.id)
                         } %>
              <% if identifiers.size > 1 %>
                <%= render "shared/ui/button",
                           label: "Remove",
                           variant: :link,
                           url: items_setup_modals_destroy_identifier_path(identifier, product_id: setup_product.id),
                           method: :delete,
                           form: { data: { turbo_stream: true } },
                           data: { turbo_confirm: "Remove this identifier?" } %>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="ss-catalog-actions">
    <% bibliographic_edit_path = item.edit_bibliographic_metadata_path %>
    <% if bibliographic_edit_path.present? %>
      <% if setup_catalog_item.present? && external_catalog_import.present? && Authorization.allowed?(user: current_user, permission_key: "items.external_lookup.access", store: current_store) %>
        <%= render "shared/ui/button",
                   label: "View original metadata",
                   variant: :secondary,
                   url: items_item_external_metadata_path(catalog_item_id: setup_catalog_item.id) %>
      <% end %>
      <%= render "shared/ui/button", label: "Edit bibliographic details", variant: :primary, url: bibliographic_edit_path %>
    <% end %>
    <% if setup_product.present? && Authorization.allowed?(user: current_user, permission_key: "items.catalog_items.update", store: current_store) %>
      <%= render "shared/ui/button",
                 label: "Quick add identifier",
                 variant: :secondary,
                 data: {
                   action: "item-setup-modal#prepareIdentifierCreate modal#open",
                   modal_target_id_param: "item-identifier-modal"
                 } %>
      <%= render "shared/ui/button",
                 label: "Generate house EAN (201)",
                 variant: :secondary,
                 url: items_setup_modals_generate_house_identifier_path(product_id: setup_product.id),
                 method: :post %>
    <% end %>
    <% if setup_catalog_item.present? %>
      <% if setup_catalog_item.active? %>
        <%= render "shared/ui/button",
                   label: "Inactivate catalog item",
                   variant: :secondary,
                   url: inactivate_items_catalog_item_path(setup_catalog_item, item_flow),
                   method: :patch %>
      <% else %>
        <%= render "shared/ui/button",
                   label: "Reactivate catalog item",
                   variant: :primary,
                   url: reactivate_items_catalog_item_path(setup_catalog_item, item_flow),
                   method: :patch %>
      <% end %>
    <% end %>
  </div>
<% end %>
