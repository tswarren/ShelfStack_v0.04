<% content_for :main_class, "ss-main--items" %>

<%= render "setup/shared/back_link", path: items_root_path, label: "Items" %>

<% unless @tab == "overview" %>
  <%= render "shared/ui/page_header",
             title: @item.title,
             description: items_tab_description(@tab) %>
<% end %>

<nav class="ss-tabs ss-item-tabs">
  <% Items::ItemsController::VALID_TABS.each do |tab| %>
    <%= link_to items_tab_label(tab), items_item_path_with_match(@item, tab: tab), class: (@tab == tab ? "active" : nil) %>
  <% end %>
</nav>

<div class="ss-tab-content">
  <% case @tab %>
  <% when "overview" %>
    <%= render "items/items/overview",
          item: @item,
          statuses: @statuses,
          variant: @highlight_variant,
          operations: @operations,
          overview: @overview,
          operational_warnings: @operational_warnings %>
  <% when "operations" %>
    <%= render "items/items/operations",
          item: @item,
          operations: @operations,
          operations_tab: @operations_tab,
          operational_warnings: @operational_warnings,
          overview: @overview %>
  <% when "item_setup" %>
    <%= render "items/items/item_setup",
          item: @item,
          identifiers: @identifiers,
          variants: @variants,
          highlight_variant: @highlight_variant,
          external_catalog_import: @external_catalog_import %>
  <% when "activity" %>
    <%= render "items/items/activity",
          item: @item,
          audit_events: @audit_events,
          ledger_entries: @ledger_entries,
          trail_nodes: @trail_nodes %>
  <% end %>
</div>

<% unless @tab.in?(%w[overview item_setup]) %>
  <% if @item.context_actions.any? %>
    <div class="ss-context-actions">
      <% @item.context_actions.each do |action| %>
        <%= render "shared/ui/button", label: action[:label], variant: :secondary, url: action[:url] %>
      <% end %>
    </div>
  <% end %>
<% end %>
