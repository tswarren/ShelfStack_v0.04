<% unless @tab == "overview" %>
  <h1><%= @item.title %></h1>
<% end %>

<nav class="ss-tabs ss-item-tabs">
  <% Items::ItemsController::VALID_TABS.each do |tab| %>
    <%= link_to items_tab_label(tab), @item.tab_path(tab), class: (@tab == tab ? "active" : nil) %>
  <% end %>
</nav>

<div class="ss-tab-content">
  <% case @tab %>
  <% when "overview" %>
    <%= render "items/items/overview",
          item: @item,
          statuses: @statuses,
          variant: @highlight_variant,
          operations: @operations,
          attention_items: @attention_items %>
  <% when "operations" %>
    <%= render "items/items/operations",
          item: @item,
          operations: @operations,
          operations_tab: @operations_tab,
          attention_items: @attention_items %>
  <% when "item_setup" %>
    <%= render "items/items/item_setup",
          item: @item,
          identifiers: @identifiers,
          variants: @variants,
          highlight_variant: @highlight_variant %>
  <% when "activity" %>
    <%= render "items/items/activity",
          item: @item,
          audit_events: @audit_events,
          ledger_entries: @ledger_entries,
          trail_nodes: @trail_nodes %>
  <% end %>
</div>

<% unless @tab.in?(%w[overview item_setup]) %>
  <div class="ss-context-actions">
    <% @item.context_actions.each do |action| %>
      <%= link_to action[:label], action[:url], class: "ss-btn ss-btn-secondary" %>
    <% end %>
  </div>
<% end %>
