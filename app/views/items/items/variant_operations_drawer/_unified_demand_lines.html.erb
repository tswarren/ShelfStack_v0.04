<table class="ss-table ss-table--compact">
  <thead>
    <tr>
      <th>Demand #</th>
      <th>Intent</th>
      <th>Customer</th>
      <th class="ss-num">Qty</th>
      <th>Buyer state</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% lines.each do |line| %>
      <tr>
        <td><%= line.demand_number %></td>
        <td><%= line.capture_intent.humanize %></td>
        <td><%= line.display_customer_name || "—" %></td>
        <td class="ss-num"><%= line.quantity_requested %></td>
        <td><%= buyer_state_label.call(line) %></td>
        <td><%= render "shared/ui/button", label: "View", variant: :link, url: demand_demand_line_path(line) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
