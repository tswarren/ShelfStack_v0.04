<table class="ss-table ss-table--compact">
  <thead>
    <tr>
      <th>Customer</th>
      <th class="ss-num">Qty</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% reserves.each do |reservation| %>
      <tr>
        <td><%= reservation.customer&.display_name || "—" %></td>
        <td class="ss-num"><%= reservation.quantity_reserved %></td>
        <td>
          <% if reservation.customer_request_line.present? %>
            <%= render "shared/ui/button",
                       label: "View request",
                       variant: :link,
                       url: customers_customer_request_path(reservation.customer_request_line.customer_request) %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
