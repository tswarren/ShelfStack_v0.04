<%# locals: drawer: VariantOperationsDrawerPresenter %>
<%= turbo_frame_tag "variant-ops-drawer-frame" do %>
<% variant = drawer.variant %>
<% row = drawer.variant_row %>
<% availability = drawer.availability_context %>

<% availability = drawer.availability_header %>

<section class="ss-drawer-section">
  <h3 class="ss-drawer-section-title">Availability</h3>
  <div class="ss-metric-strip ss-metric-strip--compact">
    <div class="ss-metric"><span class="ss-metric__label">On hand</span><span class="ss-metric__value ss-num"><%= availability[:on_hand] %></span></div>
    <div class="ss-metric"><span class="ss-metric__label">Reserved</span><span class="ss-metric__value ss-num"><%= availability[:reserved] %></span></div>
    <div class="ss-metric"><span class="ss-metric__label">Available</span><span class="ss-metric__value ss-num"><%= availability[:available] %></span></div>
    <div class="ss-metric"><span class="ss-metric__label">On order</span><span class="ss-metric__value ss-num"><%= availability[:on_order] %></span></div>
    <div class="ss-metric"><span class="ss-metric__label">Inbound allocated</span><span class="ss-metric__value ss-num"><%= availability[:inbound_allocated] %></span></div>
    <div class="ss-metric"><span class="ss-metric__label">Inbound available</span><span class="ss-metric__value ss-num"><%= availability[:inbound_available] %></span></div>
  </div>
  <% if drawer.recent_activity_one_liner.present? %>
    <p class="ss-muted"><%= drawer.recent_activity_one_liner %></p>
  <% end %>
</section>

<section class="ss-drawer-section">
  <h3 class="ss-drawer-section-title">Variant summary</h3>
  <dl class="ss-summary">
    <dt>SKU</dt><dd><%= variant.sku %></dd>
    <dt>Name</dt><dd><%= variant.name %></dd>
    <dt>Status</dt>
    <dd>
      <% ProductVariants::OperationalPolicy.for(variant).operational_badges.each do |badge| %>
        <span class="ss-badge ss-badge--muted"><%= badge.label %></span>
      <% end %>
    </dd>
    <% if row.present? %>
      <dt>Preferred vendor</dt><dd><%= row.preferred_vendor_name || "—" %></dd>
    <% end %>
  </dl>
</section>

<% if drawer.warnings.any? %>
  <section class="ss-drawer-section">
    <h3 class="ss-drawer-section-title">Warnings</h3>
    <ul class="ss-warning-list">
      <% drawer.warnings.each do |warning| %>
        <li class="ss-warning-list-item ss-warning-list-item--<%= warning.severity %>">
          <%= warning.message %>
          <% if warning.corrective_path.present? %>
            <%= link_to warning.corrective_label || "Review", warning.corrective_path, class: "ss-btn-link" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<% if drawer.recommended_actions.any? || drawer.demand_actions.any? %>
  <section class="ss-drawer-section">
    <% if drawer.demand_actions.any? %>
      <h3 class="ss-drawer-section-title">Demand actions</h3>
      <div class="ss-form-actions">
        <% drawer.demand_actions.each do |action| %>
          <button type="button"
                  class="ss-btn ss-btn-secondary ss-btn-small"
                  data-action="item-variant-ops-drawer#prepareDemandAction"
                  data-drawer-key="<%= action.drawer_key %>"
                  data-variant-id="<%= variant.id %>"
                  data-available="<%= availability&.available || 0 %>"
                  data-on-hand="<%= availability&.on_hand || 0 %>">
            <%= action.label %>
          </button>
        <% end %>
      </div>
    <% end %>
    <% if drawer.recommended_actions.any? %>
      <h3 class="ss-drawer-section-title">Operational actions</h3>
      <div class="ss-form-actions">
        <% drawer.recommended_actions.each do |action| %>
          <%= link_to action.label, action.url, class: "ss-btn ss-btn-secondary ss-btn-small" %>
        <% end %>
      </div>
    <% end %>
  </section>
<% end %>

<% tab = drawer.operations_tab %>

<% if drawer.customer_demand_visible? %>
  <section class="ss-drawer-section">
    <h3 class="ss-drawer-section-title">Open demand</h3>
    <% if drawer.unified_open_demand_lines.any? %>
      <%= render "items/items/variant_operations_drawer/unified_demand_lines",
            lines: drawer.unified_open_demand_lines,
            buyer_state_label: ->(line) { drawer.buyer_state_for(line) } %>
    <% else %>
      <p class="ss-muted">No open demand for this variant.</p>
    <% end %>

    <% if tab.variant_scoped_active_holds.any? %>
      <section class="ss-drawer-subsection">
        <h4 class="ss-drawer-subsection-title">Active holds</h4>
        <%= render "items/items/variant_operations_drawer/demand_allocations", allocations: tab.variant_scoped_active_holds %>
      </section>
    <% end %>

    <% if tab.variant_scoped_incoming_reserves.any? %>
      <section class="ss-drawer-subsection">
        <h4 class="ss-drawer-subsection-title">Inbound allocations</h4>
        <%= render "items/items/variant_operations_drawer/demand_allocations", allocations: tab.variant_scoped_incoming_reserves %>
      </section>
    <% end %>

    <% if drawer.add_to_po_path.present? %>
      <%= link_to "Add to PO", drawer.add_to_po_path, class: "ss-btn ss-btn-secondary ss-btn-small" %>
    <% end %>
  </section>
<% end %>

<% if drawer.legacy_activity_present? %>
  <details class="ss-drawer-section ss-collapsible">
    <summary class="ss-drawer-section-title">Legacy activity</summary>
    <p class="ss-hint">Historical v0.03 customer request records only. New demand uses the section above.</p>

    <% if tab.variant_scoped_customer_request_lines.any? %>
      <section class="ss-drawer-subsection">
        <h4 class="ss-drawer-subsection-title">Open customer requests</h4>
        <%= render "items/items/variant_operations_drawer/customer_request_lines", lines: tab.variant_scoped_customer_request_lines %>
      </section>
    <% end %>
  </details>
<% end %>

<% if tab.variant_scoped_purchase_order_lines.any? %>
  <details class="ss-drawer-section ss-collapsible">
    <summary class="ss-drawer-section-title">Open purchase orders</summary>
    <%= render "items/items/variant_operations_drawer/purchase_order_lines", lines: tab.variant_scoped_purchase_order_lines %>
  </details>
<% end %>

<% if tab.variant_scoped_receipt_lines.any? %>
  <details class="ss-drawer-section ss-collapsible">
    <summary class="ss-drawer-section-title">Recent receipts</summary>
    <%= render "items/items/variant_operations_drawer/receipt_lines", lines: tab.variant_scoped_receipt_lines.first(5) %>
  </details>
<% end %>

<% if tab.variant_scoped_rtv_lines.any? %>
  <section class="ss-drawer-section">
    <h3 class="ss-drawer-section-title">Returns to vendor</h3>
    <%= render "items/items/variant_operations_drawer/rtv_lines", lines: tab.variant_scoped_rtv_lines %>
  </section>
<% end %>

<% if tab.sales_visible? %>
  <% sales_rows = tab.sales_history_rows.select { |entry| entry.variant_sku == variant.sku } %>
  <% if sales_rows.any? %>
    <section class="ss-drawer-section">
      <h3 class="ss-drawer-section-title">Recent sales</h3>
      <%= render "items/items/variant_operations_drawer/sales_rows", rows: sales_rows.first(10) %>
    </section>
  <% end %>
<% end %>
<% end %>
