<% if item.product.blank? %>
  <p>Display and vendor links require a product.</p>
<% else %>
  <section class="ss-item-display-section">
    <h3>Product display defaults</h3>
    <dl class="ss-summary">
      <dt>Default display location</dt>
      <dd class="ss-summary-with-action">
        <span><%= item.product.default_display_location&.name || "—" %></span>
        <%= link_to "Edit", edit_items_product_path(item.product, anchor: "product_default_display_location_id") %>
      </dd>
    </dl>
  </section>

  <% if item.variants.any? %>
    <section class="ss-item-display-section">
      <h3>Variant display locations</h3>
      <table class="ss-table">
        <thead>
          <tr>
            <th>Variant</th>
            <th>SKU</th>
            <th>Category</th>
            <th>Display location</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% item.variants.each do |variant| %>
            <tr>
              <td><%= variant.condition&.short_name || variant.name %></td>
              <td><%= variant.sku %></td>
              <td><%= variant.sub_department&.name || "—" %></td>
              <td><%= variant.display_location&.name || "—" %></td>
              <td><%= link_to "Edit", edit_items_product_variant_path(variant, return_to: "item") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>

  <% if current_store.present? %>
    <% location_ids = [item.product.default_display_location_id, *item.variants.map(&:display_location_id)].compact.uniq %>
    <% store_locations = StoreDisplayLocation.active_records.joins(:display_location).where(store: current_store, display_location_id: location_ids).order("display_locations.sort_order", "display_locations.name") %>
    <% if store_locations.any? %>
      <section class="ss-item-display-section">
        <h3>Store display locations (<%= current_store.name %>)</h3>
        <ul class="ss-item-subjects">
          <% store_locations.each do |store_location| %>
            <li><%= store_location.display_location.name %></li>
          <% end %>
        </ul>
      </section>
    <% end %>
  <% end %>

  <section class="ss-item-display-section">
    <h3>Vendors</h3>
    <% if item.product.present? %>
      <% product_vendors = ProductVendor.active_records.includes(:vendor).where(product: item.product).order("vendors.name") %>
      <% if product_vendors.any? %>
        <table class="ss-table">
          <thead>
            <tr>
              <th>Vendor</th>
              <th>Item #</th>
              <th>Discount</th>
              <th>Preferred</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% product_vendors.each do |product_vendor| %>
              <tr>
                <td><%= product_vendor.vendor.name %></td>
                <td><%= product_vendor.vendor_item_number || "—" %></td>
                <td><%= product_vendor.supplier_discount_bps ? format_basis_points(product_vendor.supplier_discount_bps) : "—" %></td>
                <td><%= product_vendor.preferred? ? "Yes" : "No" %></td>
                <td><%= link_to "View", setup_product_vendor_path(product_vendor) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <p><%= link_to "Manage product vendors in Setup", setup_product_vendors_path %></p>
      <% else %>
        <p class="ss-muted">No product vendor sourcing records yet.</p>
        <p><%= link_to "Add product vendor in Setup", new_setup_product_vendor_path %></p>
      <% end %>
    <% end %>
  </section>

  <section class="ss-item-display-section">
    <h3>Variant vendor overrides</h3>
    <% if item.variants.any? %>
      <% if defined?(@variant_vendor_overrides) && @variant_vendor_overrides.any? %>
        <table class="ss-table">
          <thead>
            <tr>
              <th>Variant</th>
              <th>Vendor</th>
              <th>Item #</th>
              <th>Discount</th>
              <th>Returnability</th>
              <th>Preferred</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @variant_vendor_overrides.each do |variant_vendor| %>
              <tr class="<%= "ss-table-row--highlight" if local_assigns[:highlight_variant]&.id == variant_vendor.product_variant_id %>">
                <td><%= variant_vendor.product_variant.sku %></td>
                <td><%= variant_vendor.vendor.name %></td>
                <td><%= variant_vendor.vendor_item_number || "—" %></td>
                <td><%= variant_vendor.supplier_discount_bps ? format_basis_points(variant_vendor.supplier_discount_bps) : "—" %></td>
                <td><%= variant_vendor.returnability_status ? humanize_controlled_value(variant_vendor.returnability_status) : "—" %></td>
                <td><%= variant_vendor.preferred? ? "Yes" : "No" %></td>
                <td>
                  <% if Authorization.allowed?(user: current_user, permission_key: "setup.product_variant_vendors.update", store: current_store) %>
                    <%= link_to "Edit", edit_items_product_variant_product_variant_vendor_path(variant_vendor.product_variant, variant_vendor) %>
                  <% else %>
                    <%= link_to "View", setup_product_variant_vendor_path(variant_vendor) %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="ss-muted">No variant-level vendor overrides yet. Product-level vendors may still apply.</p>
      <% end %>

      <% if Authorization.allowed?(user: current_user, permission_key: "setup.product_variant_vendors.create", store: current_store) %>
        <div class="ss-catalog-actions">
          <% item.variants.each do |variant| %>
            <%= link_to "Add vendor for #{variant.sku}",
                  new_items_product_variant_product_variant_vendor_path(variant),
                  class: "ss-btn ss-btn-secondary" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p class="ss-muted">Add sellable SKUs before creating variant vendor overrides.</p>
    <% end %>
  </section>
<% end %>
