<div class="ss-item-classification-block">
  <dl class="ss-summary ss-summary-compact">
    <dt>Merchandise class</dt><dd><%= summary[:merchandise_class].presence || "—" %></dd>
    <dt>Merchandise category</dt><dd><%= summary[:merchandise_category].presence || "—" %></dd>
    <dt>Topic / section</dt><dd><%= summary[:topic_section].presence || "—" %></dd>
    <dt>Tax category</dt><dd><%= defaults.tax_category&.name || "—" %></dd>
    <dt>Sales account</dt><dd><%= defaults.sales_account_code.presence || "—" %></dd>
  </dl>
  <% if defaults.warnings.any? %>
    <ul class="ss-form-errors">
      <% defaults.warnings.each do |warning| %>
        <li><%= warning %></li>
      <% end %>
    </ul>
  <% end %>
</div>
