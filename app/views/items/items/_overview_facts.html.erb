<% facts = item.product_facts_for_overview.to_h %>
<% pairs = [
     [ "List Price", "Primary Identifier" ],
     [ "Format", "Details" ],
     [ "Publisher / Manufacturer", "Publication Date" ]
   ] %>
<% if facts.any? %>
  <section class="ss-item-section ss-item-overview-facts" aria-label="Product facts">
    <dl class="ss-item-facts-grid">
      <% pairs.each do |left_label, right_label| %>
        <% [ left_label, right_label ].each do |label| %>
          <div class="ss-item-facts-grid__cell">
            <dt><%= label %></dt>
            <dd>
              <% if label == "Publication Date" && item.publication_status_label.present? %>
                <span class="ss-item-released">
                  <%= facts[label] || "—" %>
                  <%= item_publication_status_badge(item.publication_status_label) %>
                </span>
              <% else %>
                <%= facts[label] || "—" %>
              <% end %>
            </dd>
          </div>
        <% end %>
      <% end %>
    </dl>
  </section>
<% elsif item.product.blank? && item.display_metadata.blank? %>
  <p class="ss-muted ss-item-no-catalog">This item has no product metadata yet. Create a product for operational use.</p>
<% elsif item.product.blank? %>
  <p class="ss-muted ss-item-no-catalog">Bibliographic metadata exists, but no product has been created for operational use.</p>
<% end %>
