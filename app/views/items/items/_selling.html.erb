<% if item.product.blank? %>
  <%= render "shared/ui/empty_state",
             title: "No selling setup yet",
             message: "Create a product to configure sellable SKUs, pricing, and operational defaults for this item." %>
<% else %>
  <% item_flow = { return_to: "item" } %>
  <dl class="ss-summary">
    <dt>Product name</dt><dd><%= item.product.name %></dd>
    <dt>SKU cache</dt><dd><%= item.product.sku %></dd>
    <dt>List price</dt><dd><%= format_cents(item.product.list_price_cents) %></dd>
    <dt>Variation type</dt><dd><%= humanize_controlled_value(item.product.variation_type) %></dd>
  </dl>

  <h2><%= items_user_facing_label("product_variants") %> Matrix</h2>
  <% attribute_variation = item.product.variation_type.in?(%w[variable matrix]) %>
  <% if variants.any? %>
    <table class="ss-table">
      <thead>
        <tr>
          <th>Condition</th>
          <th>Variant SKU</th>
          <th>Name</th>
          <th>Lookup codes</th>
          <th>Price</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% variants.each do |variant| %>
          <% lookup_codes = variant.product_variant_lookup_codes.active_records.order(:normalized_code) %>
          <tr class="<%= "ss-table-row--highlight" if local_assigns[:highlight_variant]&.id == variant.id %>">
            <td><%= attribute_variation ? "—" : (variant.condition&.short_name || "—") %></td>
            <td>
              <span class="ss-identifier-value ss-barcode-value"><%= variant.sku %></span>
            </td>
            <td><%= variant.list_label %></td>
            <td>
              <% if lookup_codes.any? %>
                <% lookup_codes.each do |code| %>
                  <span class="ss-identifier-value"><%= code.normalized_code %></span>
                <% end %>
              <% else %>
                —
              <% end %>
            </td>
            <td><%= format_cents(variant.selling_price_cents) %></td>
            <td>
              <% if Authorization.allowed?(user: current_user, permission_key: "items.product_variants.update", store: current_store) %>
                <%= render "shared/ui/button",
                           label: "Quick edit price",
                           variant: :link,
                           type: :button,
                           data: {
                             action: "item-setup-modal#openModalBody modal#open",
                             modal_target_id_param: "item-price-modal",
                             modal_body_url: items_edit_setup_modals_variant_price_path(variant),
                             modal_title: "Edit price — #{variant.sku}"
                           } %>
              <% end %>
              <%= link_to "Edit", edit_items_product_variant_path(variant, item_flow) %>
              <% if Inventory::Eligibility.eligible?(variant) && Authorization.allowed?(user: current_user, permission_key: "demand.create", store: current_store) %>
                | <%= link_to "Manual TBO", new_demand_demand_line_path(product_variant_id: variant.id, capture_intent: "manual_tbo") %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/ui/empty_state",
               title: "No active sellable SKUs yet",
               message: "Add a sellable SKU to make this product available for inventory and POS.",
               actions: render("shared/ui/button", label: "New sellable SKUs", variant: :primary, url: new_items_product_variant_path(product_id: item.product.id, **item_flow)) %>
  <% end %>

  <div class="ss-catalog-actions">
    <%= render "shared/ui/button", label: "New sellable SKUs", variant: :secondary, url: new_items_product_variant_path(product_id: item.product.id, **item_flow) %>
    <%= render "shared/ui/button", label: "Edit product", variant: :primary, url: edit_items_product_path(item.product, item_flow) %>
  </div>
<% end %>
