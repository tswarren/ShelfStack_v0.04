<% overview = local_assigns[:overview] %>
<% operations = local_assigns[:operations] %>

<div class="ss-item-detail ss-item-catalog"
     data-controller="drawer item-variant-ops-drawer"
     data-item-variant-ops-drawer-url-value="<%= items_variant_operations_drawer_path %>"
     data-action="drawer:closed->item-variant-ops-drawer#resetOnClose">
  <% if overview.present? %>
    <%= render "items/items/overview_summary_strip", overview: overview %>

    <div id="warnings" hidden aria-hidden="true"></div>

    <div class="ss-item-detail__body">
      <section class="ss-item-main" aria-label="Item overview">
        <%= render "items/items/overview_facts", item: item %>

        <%= render "items/items/overview_variant_table",
              overview: overview,
              operations: operations,
              item: item %>

        <% if item.description_text.present? %>
          <section class="ss-item-section ss-item-description-section" aria-label="Description">
            <h2>Description</h2>
            <%= item_description_block(item.description_text) %>
          </section>
        <% end %>
      </section>

      <aside class="ss-item-sidebar">
        <%= render "items/items/overview_subjects", item: item %>
      </aside>
    </div>
  <% end %>

  <%= render "items/items/variant_operations_drawer", operations: operations %>
</div>
