<% lock_product = local_assigns.fetch(:lock_product, false) %>
<% show_advanced = local_assigns.fetch(:show_advanced, false) %>

<% if lock_product %>
  <%= f.hidden_field :product_id, value: product.id %>
  <div class="ss-form-card ss-form-card--nested">
    <p class="ss-hint">
      <strong>Variation type:</strong> <%= humanize_controlled_value(product.variation_type) %>
      <% if local_assigns.fetch(:show_product_select, true) == false %>
        <%= link_to "Change variation type", edit_items_product_path(product, return_to: "item"), class: "ss-btn-link" %>
      <% end %>
    </p>
  </div>
<% elsif local_assigns.fetch(:show_product_select, true) %>
  <%= render layout: "shared/forms/section", locals: { title: "Product" } do %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: variant, field: :product_id, label: "Product", required: true } do %>
      <%= f.collection_select :product_id, products, :id, :name %>
    <% end %>
  <% end %>
<% end %>

<% classification_locals = {
  classification_defaults: local_assigns[:classification_defaults],
  vendors: local_assigns[:vendors]
} %>
<% case product.variation_type %>
<% when "conditional" %>
  <%= render "items/shared/variant_forms/conditional", f: f, variant: variant, product: product, sub_departments: sub_departments, conditions: conditions, display_locations: display_locations, **classification_locals %>
<% when "variable" %>
  <%= render "items/shared/variant_forms/variable", f: f, variant: variant, product: product, sub_departments: sub_departments, conditions: conditions, display_locations: display_locations, **classification_locals %>
<% when "matrix" %>
  <%= render "items/shared/variant_forms/matrix", f: f, variant: variant, product: product, sub_departments: sub_departments, conditions: conditions, display_locations: display_locations, **classification_locals %>
<% else %>
  <%= render "items/shared/variant_forms/standard", f: f, variant: variant, product: product, sub_departments: sub_departments, conditions: conditions, display_locations: display_locations, **classification_locals %>
<% end %>

<% if show_advanced %>
  <%= render "items/shared/variant_forms/advanced",
             f: f,
             variant: variant,
             manage_inventory_behavior: local_assigns.fetch(:manage_inventory_behavior, false) %>
<% end %>
