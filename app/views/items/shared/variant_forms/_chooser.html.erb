<% lock_product = local_assigns.fetch(:lock_product, false) %>
<% show_advanced = local_assigns.fetch(:show_advanced, false) %>

<% if lock_product %>
  <%= f.hidden_field :product_id, value: product.id %>
<% elsif local_assigns.fetch(:show_product_select, true) %>
  <%= render layout: "shared/forms/section", locals: { title: "Product" } do %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: variant, field: :product_id, label: "Product", required: true } do %>
      <%= f.collection_select :product_id, products, :id, :name %>
    <% end %>
  <% end %>
<% end %>

<% case product.variation_type %>
<% when "conditional" %>
  <%= render "items/shared/variant_forms/conditional", f: f, variant: variant, product: product, categories: categories, conditions: conditions, display_locations: display_locations %>
<% when "variable" %>
  <%= render "items/shared/variant_forms/variable", f: f, variant: variant, product: product, categories: categories, conditions: conditions, display_locations: display_locations %>
<% when "matrix" %>
  <%= render "items/shared/variant_forms/matrix", f: f, variant: variant, product: product, categories: categories, conditions: conditions, display_locations: display_locations %>
<% else %>
  <%= render "items/shared/variant_forms/standard", f: f, variant: variant, product: product, categories: categories, conditions: conditions, display_locations: display_locations %>
<% end %>

<% if show_advanced %>
  <%= render "items/shared/variant_forms/advanced", f: f, variant: variant %>
<% end %>
