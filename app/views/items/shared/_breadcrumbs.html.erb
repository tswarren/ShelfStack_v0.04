<nav class="ss-breadcrumbs" aria-label="Breadcrumb">
  <% if item.catalog_item %>
    <%= link_to "Catalog: #{item.title}", item.show_path %>
  <% else %>
    <%= link_to "Item: #{item.title}", item.show_path %>
  <% end %>
  <% if item.product %>
    · <%= link_to "Product: #{item.product.name} — SKU #{item.product.sku}", item.tab_path("selling") %>
  <% end %>
  <% if item.active_variant_count.positive? %>
    · <%= link_to "Variants: #{item.variant_summary_label}", item.tab_path("selling") %>
  <% end %>
  <% if local_assigns[:variant].present? %>
    · <span class="ss-muted">Variant: <%= variant.condition&.short_name || variant.name %></span>
  <% end %>
</nav>
