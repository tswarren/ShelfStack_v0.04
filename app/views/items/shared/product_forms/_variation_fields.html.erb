<% variation_default = local_assigns.fetch(:variation_default, "standard") %>

<div class="ss-form-grid ss-form-grid--2" data-product-form-target="variationBlock">
  <%= render layout: "shared/forms/field", locals: { f: f, record: product, field: :variation_type, label: "Variation type" } do %>
    <%= f.select :variation_type,
          Product::VARIATION_TYPES.map { |t| [humanize_controlled_value(t), t] },
          { selected: product.variation_type || variation_default },
          { data: { product_form_target: "variationType", action: "change->product-form#refresh" } } %>
  <% end %>
  <%= render layout: "shared/forms/field", locals: { f: f, record: product, field: :variant1_label, label: "Variant 1 label" } do %>
    <%= f.text_field :variant1_label, data: { product_form_target: "variant1Label" } %>
  <% end %>
  <%= render layout: "shared/forms/field", locals: { f: f, record: product, field: :variant2_label, label: "Variant 2 label" } do %>
    <%= f.text_field :variant2_label, data: { product_form_target: "variant2Label" } %>
  <% end %>
</div>
