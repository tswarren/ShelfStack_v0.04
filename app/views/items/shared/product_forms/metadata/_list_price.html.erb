<%= render layout: "shared/forms/field",
      locals: { f: f, record: record, field: :list_price_cents, label: "List price", required: local_assigns.fetch(:required, false) } do %>
  <div data-controller="currency-field" data-currency-field-cents-value="<%= record.list_price_cents.to_i %>">
    <span class="ss-input-prefix">$</span>
    <%= number_field_tag nil,
          record.list_price_cents.present? && record.list_price_cents.to_i.positive? ? format("%.2f", record.list_price_cents / 100.0) : nil,
          step: 0.01,
          min: 0,
          class: "ss-input ss-input--currency",
          data: { currency_field_target: "display", action: "input->currency-field#updateCents" } %>
    <%= f.hidden_field :list_price_cents, data: { currency_field_target: "cents" } %>
  </div>
<% end %>
