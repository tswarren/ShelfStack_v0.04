<%# locals: f, record, entry_context, store_category_nodes: nil, vendors: nil, display_locations: nil,
           primary_bisac_category_node_id: nil, primary_bisac_category_node_label: nil,
           bisac_category_node_ids: [], bisac_scheme_loaded: false,
           primary_genre_category_node_id: nil, primary_genre_category_node_label: nil,
           genre_category_node_ids: [], genre_scheme_loaded: false %>
<%= render layout: "items/shared/product_forms/metadata/field_shell",
      locals: { field_key: :creators, entry_context: entry_context } do %>
  <%= render layout: "shared/forms/section", locals: { title: "Contributors" } do %>
    <div data-controller="catalog-item-form">
      <%= render layout: "shared/forms/field", locals: { f: f, record: record, field: :creators } do %>
        <%= f.text_area :creators, rows: 2, data: { catalog_item_form_target: "creatorsSource" } %>
        <p class="ss-hint">Parsed preview: <span data-catalog-item-form-target="creatorsPreview"><%= metadata_creators_preview(record.creators) %></span></p>
      <% end %>
    </div>
  <% end %>
<% end %>

<div data-product-section-fields="digital store_category list_price preferred_vendor default_display_location" <%= "hidden" unless %i[digital store_category list_price preferred_vendor default_display_location].any? { |k| entry_context.visible?(k) } %>>
  <%= render "items/shared/product_forms/metadata/selling_classification",
        f: f, record: record, entry_context: entry_context,
        store_category_nodes: store_category_nodes,
        vendors: local_assigns[:vendors],
        display_locations: local_assigns[:display_locations] %>
</div>
<div data-product-section-fields="format publisher publication_status publication_date edition_statement year page_count running_time large_print language series_name periodical_metadata description" <%= "hidden" unless %i[format publisher publication_status publication_date edition_statement year page_count running_time large_print language series_name periodical_metadata description].any? { |k| entry_context.visible?(k) } %>>
  <%= render "items/shared/product_forms/metadata/format_metadata",
        f: f, record: record, entry_context: entry_context %>
</div>
<div data-product-section-fields="physical_dimensions weight" <%= "hidden" unless entry_context.visible?(:physical_dimensions) || entry_context.visible?(:weight) %>>
  <%= render "items/shared/product_forms/metadata/physical_logistics",
        f: f, record: record, entry_context: entry_context %>
</div>
<div data-product-section-fields="variation_type variant_label_1 variant_label_2" <%= "hidden" unless entry_context.visible?(:variation_type) || entry_context.visible?(:variant_label_1) || entry_context.visible?(:variant_label_2) %>>
  <%= render "items/shared/product_forms/metadata/variant_setup",
        f: f, record: record, entry_context: entry_context %>
</div>

<%= render "items/shared/product_forms/metadata/internal_controls",
      f: f, record: record, entry_context: entry_context,
      primary_bisac_category_node_id: primary_bisac_category_node_id,
      primary_bisac_category_node_label: primary_bisac_category_node_label,
      bisac_category_node_ids: bisac_category_node_ids,
      bisac_scheme_loaded: bisac_scheme_loaded,
      primary_genre_category_node_id: primary_genre_category_node_id,
      primary_genre_category_node_label: primary_genre_category_node_label,
      genre_category_node_ids: genre_category_node_ids,
      genre_scheme_loaded: genre_scheme_loaded %>
