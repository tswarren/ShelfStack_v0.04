<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "Edit Catalog Item",
           description: "Update metadata, classification, and catalog details for this item." %>

<%= form_with model: [:items, @catalog_item], class: "ss-form ss-form--wide" do |f| %>
  <%= render "items/shared/return_to_item" %>
  <%= render "form",
        f: f,
        catalog_item: @catalog_item,
        formats: @formats,
        include_identifier: false,
        primary_bisac_category_node_id: @primary_bisac_category_node_id,
        primary_bisac_category_node_label: @primary_bisac_category_node_label,
        bisac_category_node_ids: @bisac_category_node_ids,
        bisac_scheme_loaded: @bisac_scheme_loaded,
        store_category_nodes: @store_category_nodes %>
  <footer class="ss-form-actions">
    <%= f.submit "Update Catalog Item", class: "ss-btn" %>
    <%= link_to "Cancel", item_flow_cancel_path(@catalog_item, tab: "catalog"), class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
