<% primary_id = local_assigns.fetch(:primary_bisac_category_node_id) %>
<% primary_label = local_assigns.fetch(:primary_bisac_category_node_label, "") %>
<% additional_selections = local_assigns.fetch(:bisac_category_node_ids, []) %>
<% bisac_scheme_loaded = local_assigns.fetch(:bisac_scheme_loaded, false) %>

<div class="ss-field ss-field--full"
     data-controller="bisac-subjects"
     data-bisac-subjects-search-url-value="<%= items_bisac_subjects_search_path(format: :json) %>"
     data-bisac-subjects-primary-id-value="<%= primary_id.to_i %>"
     data-bisac-subjects-primary-label-value="<%= primary_label.to_s %>"
     data-bisac-subjects-additional-selections-value="<%= additional_selections.to_json %>">
  <% unless bisac_scheme_loaded %>
    <p class="ss-form-errors">BISAC subject tree is not loaded. Import subjects from Setup → BISAC Subjects before using structured pickers.</p>
  <% end %>

  <div class="ss-form-grid ss-form-grid--2">
    <div class="ss-field">
      <%= label_tag :primary_bisac_category_node_id, "Primary BISAC subject", class: "ss-label" %>
      <%= hidden_field_tag :primary_bisac_category_node_id, primary_id, data: { bisac_subjects_target: "primaryHidden" } %>
      <div class="ss-bisac-primary-selection">
        <p data-bisac-subjects-target="primaryDisplay" class="ss-muted"><%= primary_label.presence || "None selected" %></p>
        <button type="button"
                class="ss-btn ss-btn-secondary ss-btn-small"
                data-bisac-subjects-target="primaryClear"
                data-action="bisac-subjects#clearPrimary"
                <%= "hidden" if primary_id.blank? %>>
          Clear
        </button>
      </div>
      <input type="search"
             class="ss-input"
             placeholder="Search BISAC subjects"
             autocomplete="off"
             <%= "disabled" unless bisac_scheme_loaded %>
             data-bisac-subjects-target="primarySearch"
             data-action="input->bisac-subjects#searchPrimary">
    </div>

    <div class="ss-field">
      <label class="ss-label">Additional BISAC subjects</label>
      <div data-bisac-subjects-target="additionalContainer"></div>
      <input type="search"
             class="ss-input"
             placeholder="Search to add another subject"
             autocomplete="off"
             <%= "disabled" unless bisac_scheme_loaded %>
             data-action="input->bisac-subjects#searchAdditional">
    </div>
  </div>

  <p class="ss-hint">Linked preview: <span data-bisac-subjects-target="linkedPreview">—</span></p>

  <details class="ss-details">
    <summary>Advanced subject entry</summary>
    <div class="ss-field">
      <%= f.text_area :bisac_subjects,
                      rows: 2,
                      data: { bisac_subjects_target: "advancedField", preview_source: "subjects" } %>
      <p class="ss-hint">Paste Ingram or publisher subject strings. Unmatched entries stay as local subjects.</p>
      <p class="ss-hint">Parsed preview: <span data-preview="subjects-parsed"><%= metadata_subjects_preview(catalog_item.bisac_subjects) %></span></p>
    </div>
  </details>
</div>
