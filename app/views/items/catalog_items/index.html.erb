<% new_catalog_item_action = render("shared/ui/button", label: "New", variant: :primary, url: new_items_catalog_item_path) %>

<%= render "setup/shared/back_link", path: items_root_path, label: "Items" %>

<%= render "shared/ui/page_header",
           title: "Catalog Items",
           description: "Legacy admin list for catalog metadata records.",
           actions: new_catalog_item_action %>

<% if @catalog_items.any? %>
  <table class="ss-table">
    <thead><tr><th>Title</th><th>Type</th><th>Format</th><th>Primary ID</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @catalog_items.each do |item| %>
        <tr>
          <td><%= item.title %></td>
          <td><%= humanize_controlled_value(item.catalog_item_type) %></td>
          <td><%= item.format.short_name %></td>
          <td><%= item.primary_identifier&.normalized_identifier || "—" %></td>
          <td><%= ss_status_badge(status_label(item.active?), status: item.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", items_catalog_item_path(item) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No catalog items yet",
             message: "Create a catalog item or use Add Item from the Items workspace.",
             actions: new_catalog_item_action %>
<% end %>
