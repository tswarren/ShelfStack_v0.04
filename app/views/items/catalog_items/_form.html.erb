<%= render "shared/forms/errors", record: catalog_item %>

<%= render layout: "shared/forms/section", locals: { title: "Basic Details" } do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :catalog_item_type, label: "Type", required: true } do %>
      <%= f.select :catalog_item_type, CatalogItem::CATALOG_ITEM_TYPES.map { |t| [humanize_controlled_value(t), t] }, {}, data: { catalog_type: "select" } %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :title, required: true } do %>
      <%= f.text_field :title %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :format_id, label: "Format", required: true } do %>
      <%= f.collection_select :format_id, formats, :id, :name %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :publication_status } do %>
      <%= f.select :publication_status, CatalogItem::PUBLICATION_STATUSES.map { |s| [humanize_controlled_value(s), s] } %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :publisher } do %>
      <%= f.text_field :publisher %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :creators } do %>
      <%= f.text_area :creators, rows: 2, data: { preview_source: "creators" } %>
      <p class="ss-hint">Parsed preview: <span data-preview="creators-parsed"><%= metadata_creators_preview(catalog_item.creators) %></span></p>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :description } do %>
      <%= f.text_area :description, rows: 4 %>
    <% end %>
  </div>
  <%= render "shared/forms/checkbox", f: f, record: catalog_item, field: :active %>
<% end %>

<div data-catalog-fields="book periodical recorded_music videorecording audiobook ebook map game gift sideline other">
  <%= render layout: "shared/forms/section", locals: { title: "Publication" } do %>
    <div class="ss-form-grid ss-form-grid--2">
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :publication_date } do %>
        <%= f.date_field :publication_date %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :edition_statement } do %>
        <%= f.text_field :edition_statement %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :language_code } do %>
        <%= f.text_field :language_code, maxlength: 10 %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :series_name } do %>
        <%= f.text_field :series_name %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :series_enumeration } do %>
        <%= f.text_field :series_enumeration, maxlength: 15 %>
      <% end %>
    </div>
  <% end %>
</div>

<div data-catalog-fields="periodical">
  <%= render layout: "shared/forms/section", locals: { title: "Periodical" } do %>
    <div class="ss-form-grid ss-form-grid--2">
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :publication_frequency } do %>
        <%= f.select :publication_frequency, CatalogItem::PUBLICATION_FREQUENCIES.map { |v| [humanize_controlled_value(v), v] }, include_blank: true %>
      <% end %>
    </div>
  <% end %>
</div>

<div data-catalog-fields="calendar">
  <%= render layout: "shared/forms/section", locals: { title: "Calendar" } do %>
    <div class="ss-form-grid ss-form-grid--2">
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :year } do %>
        <%= f.text_field :year, maxlength: 4 %>
      <% end %>
    </div>
  <% end %>
</div>

<div data-catalog-fields="book calendar periodical recorded_music sideline videorecording audiobook map game gift other">
  <%= render layout: "shared/forms/section", locals: { title: "Physical Details" } do %>
    <div class="ss-form-grid ss-form-grid--2">
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :height } do %>
        <%= f.number_field :height, step: 0.01 %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :width } do %>
        <%= f.number_field :width, step: 0.01 %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :depth } do %>
        <%= f.number_field :depth, step: 0.01 %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :dimension_units } do %>
        <%= f.select :dimension_units, CatalogItem::DIMENSION_UNITS, include_blank: true %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :weight } do %>
        <%= f.number_field :weight, step: 0.01 %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :weight_units } do %>
        <%= f.select :weight_units, CatalogItem::WEIGHT_UNITS, include_blank: true %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :page_count } do %>
        <%= f.number_field :page_count %>
      <% end %>
    </div>
    <%= render "shared/forms/checkbox", f: f, record: catalog_item, field: :large_print %>
  <% end %>
</div>

<div data-catalog-fields="recorded_music videorecording audiobook other">
  <%= render layout: "shared/forms/section", locals: { title: "Media" } do %>
    <div class="ss-form-grid ss-form-grid--2">
      <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :duration_minutes } do %>
        <%= f.number_field :duration_minutes %>
      <% end %>
    </div>
    <%= render "shared/forms/checkbox", f: f, record: catalog_item, field: :digital %>
  <% end %>
</div>

<div data-catalog-fields="ebook audiobook_digital">
  <%= render layout: "shared/forms/section", locals: { title: "Digital" } do %>
    <%= render "shared/forms/checkbox", f: f, record: catalog_item, field: :digital %>
  <% end %>
</div>

<%= render layout: "shared/forms/section", locals: { title: "Classification" } do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render "items/catalog_items/bisac_subjects_picker",
          f: f,
          catalog_item: catalog_item,
          primary_bisac_category_node_id: local_assigns[:primary_bisac_category_node_id],
          primary_bisac_category_node_label: local_assigns[:primary_bisac_category_node_label],
          bisac_category_node_ids: local_assigns[:bisac_category_node_ids] || [],
          bisac_scheme_loaded: local_assigns.fetch(:bisac_scheme_loaded, false) %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :genres } do %>
      <%= f.text_area :genres, rows: 2 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :themes } do %>
      <%= f.text_area :themes, rows: 2 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :target_audiences, label: "Target audiences" } do %>
      <%= f.text_area :target_audiences, rows: 2 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: catalog_item, field: :access_restrictions, label: "Access restrictions" } do %>
      <%= f.text_area :access_restrictions, rows: 2 %>
    <% end %>
  </div>
<% end %>

<% if include_identifier %>
  <%= render layout: "shared/forms/section", locals: { title: "Initial Identifier" } do %>
    <div class="ss-form-grid ss-form-grid--2">
      <div class="ss-field">
        <%= label_tag "catalog_item[initial_identifier_type]", "Identifier type", class: "ss-label" %>
        <%= select_tag "catalog_item[initial_identifier_type]", options_for_select(CatalogItemIdentifier::IDENTIFIER_TYPES.map { |t| [t.upcase, t] }, "isbn13"), data: { preview_target: "identifier-type" } %>
      </div>
      <div class="ss-field">
        <%= label_tag "catalog_item[initial_identifier_value]", "Identifier value", class: "ss-label" %>
        <%= text_field_tag "catalog_item[initial_identifier_value]", nil, data: { preview_target: "identifier-value" } %>
      </div>
    </div>
    <p class="ss-hint">Normalized preview: <span data-preview="identifier-normalized">—</span></p>
  <% end %>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var typeSelect = document.querySelector("[data-catalog-type='select']");
    var fieldsets = document.querySelectorAll("[data-catalog-fields]");
    function updateCatalogFields() {
      var selected = typeSelect ? typeSelect.value : "book";
      fieldsets.forEach(function(fieldset) {
        var types = fieldset.getAttribute("data-catalog-fields").split(" ");
        fieldset.style.display = types.indexOf(selected) >= 0 ? "" : "none";
      });
    }
    if (typeSelect) {
      typeSelect.addEventListener("change", updateCatalogFields);
      updateCatalogFields();
    }

    var idType = document.querySelector("[data-preview-target='identifier-type']");
    var idValue = document.querySelector("[data-preview-target='identifier-value']");
    var idPreview = document.querySelector("[data-preview='identifier-normalized']");
    function updateIdentifierPreview() {
      if (!idType || !idValue || !idPreview) return;
      var value = idValue.value.trim();
      if (!value) { idPreview.textContent = "—"; return; }
      var normalized = value.replace(/[^0-9Xx]/g, "").toUpperCase();
      if (idType.value === "publisher_number") {
        normalized = value.replace(/[^A-Za-z0-9]/g, "").toUpperCase();
      }
      idPreview.textContent = normalized || "—";
    }
    if (idType && idValue) {
      idType.addEventListener("change", updateIdentifierPreview);
      idValue.addEventListener("input", updateIdentifierPreview);
    }

    function splitOutsideBrackets(input) {
      var parts = [];
      var current = "";
      var depth = 0;
      for (var i = 0; i < input.length; i++) {
        var char = input[i];
        if (char === "[") {
          depth += 1;
          current += char;
        } else if (char === "]") {
          if (depth > 0) depth -= 1;
          current += char;
        } else if (char === ";" && depth === 0) {
          parts.push(current);
          current = "";
        } else {
          current += char;
        }
      }
      if (current.length) parts.push(current);
      return parts;
    }

    function parseCreatorPreview(value) {
      return splitOutsideBrackets(value).map(function(entry) {
        entry = entry.trim();
        if (!entry) return null;
        return entry.replace(/\[[^\]]+\]\s*$/, "").trim();
      }).filter(Boolean).join("; ") || "—";
    }

    function parseSubjectPreview(value) {
      return splitOutsideBrackets(value).map(function(entry) {
        entry = entry.trim();
        if (!entry) return null;
        return entry.replace(/\[[A-Za-z0-9_]+(?:\/[^\]]+)?\]\s*$/, "").trim();
      }).filter(Boolean).join("; ") || "—";
    }

    function bindMetadataPreview(sourceName, previewName, parser) {
      var source = document.querySelector("[data-preview-source='" + sourceName + "']");
      var preview = document.querySelector("[data-preview='" + previewName + "']");
      if (!source || !preview) return;
      function update() {
        preview.textContent = parser(source.value);
      }
      source.addEventListener("input", update);
      source.addEventListener("change", update);
    }

    bindMetadataPreview("creators", "creators-parsed", parseCreatorPreview);
    bindMetadataPreview("subjects", "subjects-parsed", parseSubjectPreview);
  });
</script>
