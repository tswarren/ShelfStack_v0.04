<% if catalog_item.is_a?(Product) %>
  <% entry_context = local_assigns[:entry_context] || Products::EntryContext.build(
       product: catalog_item,
       staff_item_kind: params.dig(:product, :staff_item_kind).presence ||
         params.dig(:catalog_item, :staff_item_kind).presence ||
         Products::ItemKindNormalizer.staff_item_kind_from_catalog_item_type(
           params.dig(:product, :catalog_item_type).presence ||
             params.dig(:catalog_item, :catalog_item_type).presence ||
             catalog_item.catalog_item_type,
           product_type: catalog_item.try(:product_type)
         ),
       digital: catalog_item.digital,
       format: catalog_item.format,
       variation_type: catalog_item.variation_type,
       mode: catalog_item.persisted? ? :edit : :new
     ) %>
  <% genre_state = entry_context.controlled_scheme.present? && entry_context.controlled_scheme != Bisac::CategoryNodeImporter::SCHEME_KEY ?
       (defined?(@genre_form_state) ? @genre_form_state : {}) : {} %>
  <%= render "items/shared/product_forms/metadata/form",
        f: f,
        record: catalog_item,
        entry_context: entry_context,
        store_category_nodes: local_assigns[:store_category_nodes],
        include_identifier: local_assigns.fetch(:include_identifier, false),
        primary_bisac_category_node_id: local_assigns[:primary_bisac_category_node_id],
        primary_bisac_category_node_label: local_assigns[:primary_bisac_category_node_label],
        bisac_category_node_ids: local_assigns[:bisac_category_node_ids] || [],
        bisac_scheme_loaded: local_assigns.fetch(:bisac_scheme_loaded, false),
        primary_genre_category_node_id: genre_state[:primary_genre_category_node_id],
        primary_genre_category_node_label: genre_state[:primary_genre_category_node_label],
        genre_category_node_ids: genre_state[:genre_category_node_ids] || [],
        genre_scheme_loaded: genre_state[:genre_scheme_loaded] %>
<% else %>
<%= render "items/catalog_items/legacy_form",
      f: f,
      catalog_item: catalog_item,
      formats: formats,
      include_identifier: local_assigns.fetch(:include_identifier, false),
      primary_bisac_category_node_id: local_assigns[:primary_bisac_category_node_id],
      primary_bisac_category_node_label: local_assigns[:primary_bisac_category_node_label],
      bisac_category_node_ids: local_assigns[:bisac_category_node_ids] || [],
      bisac_scheme_loaded: local_assigns.fetch(:bisac_scheme_loaded, false),
      store_category_nodes: local_assigns[:store_category_nodes] %>
<% end %>
