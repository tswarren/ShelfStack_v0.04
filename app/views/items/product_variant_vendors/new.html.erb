<% cancel_path = Items::ReturnPath.for(
     record: @product_variant,
     return_to: params[:return_to].presence || "item",
     tab: params[:return_to] == "from_tbo" ? nil : "item_setup",
     variant_id: @product_variant.id,
     anchor: params[:return_to] == "from_tbo" ? nil : "vendor-sourcing",
     from_tbo_filters: {
       view: params[:from_tbo_view],
       vendor_id: params[:from_tbo_vendor_id],
       sourced_only: params[:from_tbo_sourced_only],
       department_id: params[:from_tbo_department_id],
       format_id: params[:from_tbo_format_id]
     }.compact
   ) %>

<%= render "setup/shared/back_link", path: cancel_path, label: "Cancel" %>

<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "Add Variant Vendor",
           description: "#{@product_variant.sku} — #{@product_variant.name}" %>

<%= form_with model: @product_variant_vendor,
      url: items_product_variant_product_variant_vendors_path(@product_variant),
      class: "ss-form ss-form--standard" do |f| %>
  <% if params[:return_to] == "from_tbo" %>
    <%= hidden_field_tag :return_to, "from_tbo" %>
    <%= hidden_field_tag :from_tbo_view, params[:from_tbo_view] %>
    <%= hidden_field_tag :from_tbo_vendor_id, params[:from_tbo_vendor_id] %>
    <%= hidden_field_tag :from_tbo_sourced_only, params[:from_tbo_sourced_only] %>
    <%= hidden_field_tag :from_tbo_department_id, params[:from_tbo_department_id] %>
    <%= hidden_field_tag :from_tbo_format_id, params[:from_tbo_format_id] %>
  <% end %>
  <%= render "shared/forms/product_variant_vendor_fields",
        f: f,
        product_variant_vendor: @product_variant_vendor,
        lock_variant: true %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Add Variant Vendor", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: cancel_path %>
  </footer>
<% end %>
