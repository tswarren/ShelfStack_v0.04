<% if @total_pages > 1 %>
  <nav class="ss-pagination" aria-label="Items pagination">
    <% if @page > 1 %>
      <%= link_to "Previous", items_root_path(request.query_parameters.merge("page" => @page - 1)), class: "ss-btn ss-btn-secondary" %>
    <% end %>
    <span class="ss-pagination__summary">Page <%= @page %> of <%= @total_pages %> (<%= @total_count %> items)</span>
    <% if @page < @total_pages %>
      <%= link_to "Next", items_root_path(request.query_parameters.merge("page" => @page + 1)), class: "ss-btn ss-btn-secondary" %>
    <% end %>
  </nav>
<% elsif @total_count.positive? %>
  <p class="ss-pagination__summary"><%= @total_count %> <%= "item".pluralize(@total_count) %></p>
<% end %>
