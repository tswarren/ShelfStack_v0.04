<table class="ss-table">
  <thead>
    <tr>
      <th>Item</th>
      <th>Status</th>
      <th>Product SKU</th>
      <th>Variants</th>
      <th>Price</th>
      <% if local_assigns[:warning_summaries].present? || operational_summaries.present? %>
        <th>Signals</th>
      <% end %>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% results.each do |result| %>
      <% item = result.presenter %>
      <% summary = operational_summaries[item] %>
      <% warning_summary = summary&.warning_summary || warning_summaries[item] %>
      <% active_variants = item.variants.select(&:active?) %>
      <tr>
        <td>
          <div class="ss-search-item-cell">
            <%= item_cover_thumbnail(item, size: :search) %>
            <div>
              <strong><%= link_to item.title, items_item_path_with_match(item), class: "ss-search-item-title" %></strong><br>
              <span class="ss-muted"><%= item.creator_line %> · <%= item.format_name %> · <%= item.primary_identifier_display %></span>
            </div>
          </div>
        </td>
        <td>
          <% item.search_statuses.each do |status| %>
            <%= item_lifecycle_status_badge(status) %>
          <% end %>
        </td>
        <td><%= item.product_sku || "—" %></td>
        <td><%= item.variant_summary_label %></td>
        <td><%= item.price_range_label %></td>
        <% if local_assigns[:warning_summaries].present? || operational_summaries.present? %>
          <td class="ss-num">
            <% if warning_summary&.worst_severity.present? %>
              <div><%= item_warning_severity_badge(warning_summary.worst_severity) %></div>
            <% end %>
            <% if summary.present? %>
              <div>Avail. <%= summary.available %></div>
              <div>TBO <%= summary.open_tbo %> · Order <%= summary.on_order %></div>
              <% if summary.last_received_at.present? %>
                <div class="ss-muted">Rcvd <%= l(summary.last_received_at.to_date) %></div>
              <% end %>
            <% elsif warning_summary.blank? %>
              —
            <% end %>
          </td>
        <% end %>
        <td class="ss-search-action-cell">
          <% if local_assigns[:match_context]&.valid? &&
                Authorization.allowed?(user: current_user, permission_key: "customer_requests.update", store: current_store) %>
            <% if active_variants.size == 1 %>
              <%= button_to "Match to request",
                    match_variant_customers_customer_request_path(match_context.request_record),
                    method: :post,
                    params: {
                      line_id: match_context.line_id,
                      product_variant_id: active_variants.first.id
                    },
                    class: "ss-btn ss-btn-small" %>
            <% elsif active_variants.any? %>
              <%= link_to "Pick variant",
                    items_item_path_with_match(item, tab: "operations", variant_id: active_variants.first.id),
                    class: "ss-search-view-link" %>
            <% end %>
          <% end %>
          <% if summary&.actions.present? %>
            <% summary.actions.each do |action| %>
              <%= link_to action.label, action.url, class: "ss-search-view-link" %>
            <% end %>
          <% else %>
            <%= link_to "View Item", items_item_path_with_match(item), class: "ss-search-view-link" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
