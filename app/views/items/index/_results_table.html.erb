<table class="ss-table">
  <thead>
    <tr>
      <th>Item</th>
      <th>Status</th>
      <th>Product SKU</th>
      <th>Variants</th>
      <th>Price</th>
      <% if operational_summaries.present? %>
        <th>Stock / Orders</th>
      <% end %>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% results.each do |result| %>
      <% item = result.presenter %>
      <% summary = operational_summaries[item] %>
      <tr>
        <td>
          <div class="ss-search-item-cell">
            <%= item_cover_thumbnail(item, size: :search) %>
            <div>
              <strong><%= link_to item.title, item.show_path, class: "ss-search-item-title" %></strong><br>
              <span class="ss-muted"><%= item.creator_line %> · <%= item.format_name %> · <%= item.primary_identifier_display %></span>
            </div>
          </div>
        </td>
        <td>
          <% item.search_statuses.each do |status| %>
            <%= item_lifecycle_status_badge(status) %>
          <% end %>
        </td>
        <td><%= item.product_sku || "—" %></td>
        <td><%= item.variant_summary_label %></td>
        <td><%= item.price_range_label %></td>
        <% if operational_summaries.present? %>
          <td class="ss-num">
            <% if summary.present? %>
              <div>Avail. <%= summary.available %></div>
              <div>TBO <%= summary.open_tbo %> · Order <%= summary.on_order %></div>
              <% if summary.last_received_at.present? %>
                <div class="ss-muted">Rcvd <%= l(summary.last_received_at.to_date) %></div>
              <% end %>
            <% else %>
              —
            <% end %>
          </td>
        <% end %>
        <td class="ss-search-action-cell">
          <% if summary&.actions.present? %>
            <% summary.actions.each do |action| %>
              <%= link_to action.label, action.url, class: "ss-search-view-link" %>
            <% end %>
          <% else %>
            <%= link_to "View Item", item.show_path, class: "ss-search-view-link" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
