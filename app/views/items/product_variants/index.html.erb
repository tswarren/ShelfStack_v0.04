<% new_variant_action = render("shared/ui/button", label: "New", variant: :primary, url: new_items_product_variant_path) %>

<%= render "setup/shared/back_link", path: items_root_path, label: "Items" %>

<%= render "shared/ui/page_header",
           title: "Product Variants",
           description: "Legacy admin list for sellable SKUs.",
           actions: new_variant_action %>

<% if @product_variants.any? %>
  <table class="ss-table">
    <thead><tr><th>Product</th><th>Name</th><th>SKU</th><th>Price</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @product_variants.each do |variant| %>
        <tr>
          <td><%= variant.product.name %></td>
          <td><%= variant.name %></td>
          <td><%= variant.sku %></td>
          <td><%= format_cents(variant.selling_price_cents) %></td>
          <td><%= ss_status_badge(status_label(variant.active?), status: variant.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", items_product_variant_path(variant) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No product variants yet",
             message: "Create sellable SKUs from an item's setup tab or this admin list.",
             actions: new_variant_action %>
<% end %>
