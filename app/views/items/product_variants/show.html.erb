<% item = Items::ItemPresenter.from_product_variant(@product_variant) %>
<% item_flow = { return_to: "item" } %>

<%= render "setup/shared/back_link", path: item.tab_path("item_setup", variant_id: @product_variant.id), label: "Item setup" %>

<%
  secondary_actions = []
  if Inventory::Eligibility.eligible?(@product_variant) && Authorization.allowed?(user: current_user, permission_key: "inventory.ledger.view", store: current_store)
    secondary_actions << render("shared/ui/button", label: "Inventory Ledger", variant: :secondary, url: inventory_variant_path(@product_variant))
  end
  if Inventory::Eligibility.eligible?(@product_variant) && Authorization.allowed?(user: current_user, permission_key: "demand.create", store: current_store)
    secondary_actions << render("shared/ui/button", label: "Manual TBO", variant: :secondary, url: new_demand_demand_line_path(product_variant_id: @product_variant.id, capture_intent: "manual_tbo"))
  end
  secondary_actions << render("shared/ui/button", label: "Regenerate Name", variant: :secondary, url: regenerate_name_items_product_variant_path(@product_variant, item_flow), method: :patch)

  header_actions = if @product_variant.active?
                     safe_join([
                       *secondary_actions,
                       render("shared/ui/button", label: "Inactivate", variant: :secondary, url: inactivate_items_product_variant_path(@product_variant, item_flow), method: :patch),
                       render("shared/ui/button", label: "Edit", variant: :primary, url: edit_items_product_variant_path(@product_variant, item_flow))
                     ])
                   else
                     safe_join([
                       *secondary_actions,
                       render("shared/ui/button", label: "Edit", variant: :secondary, url: edit_items_product_variant_path(@product_variant, item_flow)),
                       render("shared/ui/button", label: "Reactivate", variant: :primary, url: reactivate_items_product_variant_path(@product_variant, item_flow), method: :patch)
                     ])
                   end
%>

<%= render "shared/ui/page_header", title: @product_variant.name, actions: header_actions %>

<dl class="ss-summary">
  <dt>Product</dt><dd><%= @product_variant.product.name %></dd>
  <dt>SKU</dt><dd><%= @product_variant.sku %></dd>
  <dt>Subdepartment</dt><dd><%= @product_variant.sub_department.name %></dd>
  <dt>Condition</dt><dd><%= @product_variant.condition&.name || "—" %></dd>
  <dt>Selling price</dt><dd><%= format_cents(@product_variant.selling_price_cents) %></dd>
  <dt>Inventory tracking</dt><dd><%= humanize_controlled_value(@product_variant.inventory_tracking) %></dd>
  <% if @source_hint %>
    <dt><%= inventory_source_hint_label(@source_hint) %></dt><dd><%= @source_hint.label %></dd>
  <% end %>
  <% if Inventory::Eligibility.eligible?(@product_variant) && Authorization.allowed?(user: current_user, permission_key: "inventory.balances.view", store: current_store) %>
    <dt>On hand (<%= current_store.name %>)</dt>
    <dd><%= Inventory::Availability.on_hand(store: current_store, variant: @product_variant) %></dd>
    <% if @order_quantity %>
      <dt>On order (<%= current_store.name %>)</dt>
      <dd><%= @order_quantity.on_order %></dd>
      <dt>Pending (<%= current_store.name %>)</dt>
      <dd><%= @order_quantity.pending %></dd>
    <% end %>
  <% end %>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@product_variant.active?), status: @product_variant.active? ? :active : :inactive) %></dd>
</dl>

<% if @manage_inventory_behavior %>
  <details class="ss-form-subsection">
    <summary>Support: legacy inventory behavior</summary>
    <dl class="ss-summary">
      <dt>Inventory behavior</dt><dd><%= humanize_controlled_value(@product_variant.inventory_behavior) %></dd>
    </dl>
  </details>
<% end %>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "product-variant-danger-zone-heading",
           message: "Delete removes the variant only when nothing references it. Prefer inactivating.",
           delete_label: "Delete variant",
           delete_path: items_product_variant_path(@product_variant, item_flow),
           confirm_message: "Delete this variant?" %>
