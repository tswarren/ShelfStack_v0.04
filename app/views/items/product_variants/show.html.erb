<% item = Items::ItemPresenter.from_product_variant(@product_variant) %>
<% item_flow = { return_to: "item" } %>

<h1><%= @product_variant.name %></h1>
<dl class="ss-summary">
  <dt>Product</dt><dd><%= @product_variant.product.name %></dd>
  <dt>SKU</dt><dd><%= @product_variant.sku %></dd>
  <dt>Subdepartment</dt><dd><%= @product_variant.sub_department.name %></dd>
  <dt>Condition</dt><dd><%= @product_variant.condition&.name || "—" %></dd>
  <dt>Selling price</dt><dd><%= format_cents(@product_variant.selling_price_cents) %></dd>
  <dt>Inventory tracking</dt><dd><%= humanize_controlled_value(@product_variant.inventory_tracking) %></dd>
  <% if @source_hint %>
    <dt><%= inventory_source_hint_label(@source_hint) %></dt><dd><%= @source_hint.label %></dd>
  <% end %>
  <% if Inventory::Eligibility.eligible?(@product_variant) && Authorization.allowed?(user: current_user, permission_key: "inventory.balances.view", store: current_store) %>
    <dt>On hand (<%= current_store.name %>)</dt>
    <dd><%= Inventory::Availability.on_hand(store: current_store, variant: @product_variant) %></dd>
    <% if @order_quantity %>
      <dt>On order (<%= current_store.name %>)</dt>
      <dd><%= @order_quantity.on_order %></dd>
      <dt>Pending (<%= current_store.name %>)</dt>
      <dd><%= @order_quantity.pending %></dd>
    <% end %>
  <% end %>
  <dt>Status</dt><dd><span class="<%= status_class(@product_variant.active?) %>"><%= status_label(@product_variant.active?) %></span></dd>
</dl>

<% if @manage_inventory_behavior %>
  <details class="ss-form-subsection">
    <summary>Support: legacy inventory behavior</summary>
    <dl class="ss-summary">
      <dt>Inventory behavior</dt><dd><%= humanize_controlled_value(@product_variant.inventory_behavior) %></dd>
    </dl>
  </details>
<% end %>

<div class="ss-detail-actions">
  <%= link_to "Back to Item", item.tab_path("item_setup", variant_id: @product_variant.id), class: "ss-btn ss-btn-secondary" %>
  <% if Inventory::Eligibility.eligible?(@product_variant) && Authorization.allowed?(user: current_user, permission_key: "inventory.ledger.view", store: current_store) %>
    <%= link_to "Inventory Ledger", inventory_variant_path(@product_variant), class: "ss-btn ss-btn-secondary" %>
  <% end %>
  <% if Inventory::Eligibility.eligible?(@product_variant) && Authorization.allowed?(user: current_user, permission_key: "demand.create", store: current_store) %>
    <%= link_to "Manual TBO", new_demand_demand_line_path(product_variant_id: @product_variant.id, capture_intent: "manual_tbo"), class: "ss-btn ss-btn-secondary" %>
  <% end %>
  <%= link_to "Edit", edit_items_product_variant_path(@product_variant, item_flow), class: "ss-btn" %>
  <%= button_to "Regenerate Name", regenerate_name_items_product_variant_path(@product_variant, item_flow), method: :patch, class: "ss-btn ss-btn-secondary" %>
  <% if @product_variant.active? %>
    <%= button_to "Inactivate", inactivate_items_product_variant_path(@product_variant, item_flow), method: :patch, class: "ss-btn ss-btn-secondary" %>
  <% else %>
    <%= button_to "Reactivate", reactivate_items_product_variant_path(@product_variant, item_flow), method: :patch, class: "ss-btn" %>
  <% end %>
  <%= button_to "Delete", items_product_variant_path(@product_variant, item_flow), method: :delete, class: "ss-btn ss-btn-secondary", data: { turbo_confirm: "Delete this variant?" } %>
</div>
<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
