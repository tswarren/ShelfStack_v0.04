<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "Edit Product Variant",
           description: "Update SKU identity, condition attributes, pricing, and availability." %>

<%= form_with model: [:items, @product_variant], class: "ss-form ss-form--wide" do |f| %>
  <%= hidden_field_tag :return_to, "item" %>
  <%= render "form",
             f: f,
             product_variant: @product_variant,
             products: @products,
             sub_departments: @sub_departments,
             conditions: @conditions,
             display_locations: @display_locations,
             vendors: @vendors,
             category_nodes: @category_nodes,
             primary_category_node_id: @primary_category_node_id,
             classification_defaults: @classification_defaults,
             show_advanced: true,
             manage_inventory_behavior: @manage_inventory_behavior %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Update Variant", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: item_flow_cancel_path(@product_variant.product, tab: "item_setup", variant_id: @product_variant.id) %>
  </footer>
<% end %>
