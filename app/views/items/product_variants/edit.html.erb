<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "Edit Product Variant",
           description: "Update SKU identity, condition attributes, pricing, and availability." %>

<%= form_with model: [:items, @product_variant], class: "ss-form ss-form--wide" do |f| %>
  <%= render "form", f: f, product_variant: @product_variant, products: @products, categories: @categories, conditions: @conditions, display_locations: @display_locations %>
  <footer class="ss-form-actions">
    <%= f.submit "Update Variant", class: "ss-btn" %>
    <%= link_to "Cancel", items_product_variant_path(@product_variant), class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
