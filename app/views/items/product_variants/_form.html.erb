<% if product_variant.errors.any? %>
  <div class="flash flash-alert"><%= product_variant.errors.full_messages.to_sentence %></div>
<% end %>
<fieldset class="ss-form-section">
  <legend>Product Variant</legend>
  <%= f.label :product_id, "Product" %>
  <%= f.collection_select :product_id, products, :id, :name %>
  <%= f.label :category_id, "Category" %>
  <%= f.collection_select :category_id, categories, :id, :name %>
  <%= f.label :condition_id, "Condition" %>
  <%= f.collection_select :condition_id, conditions, :id, :name, include_blank: true, data: { preview_target: "variant-condition" } %>
  <%= f.label :name %><%= f.text_field :name %>
  <%= f.label :name_override, "Name override" %><%= f.text_field :name_override, data: { preview_target: "variant-name-override" } %>
  <%= f.label :sku, "SKU (leave blank to generate)" %><%= f.text_field :sku, maxlength: 50, data: { preview_target: "variant-sku-manual" } %>
  <%= f.label :attribute1_value, "Attribute 1 value" %><%= f.text_field :attribute1_value, data: { preview_target: "variant-attr1-value" } %>
  <%= f.label :attribute1_sku_component, "Attribute 1 SKU component" %><%= f.text_field :attribute1_sku_component, maxlength: 5, data: { preview_target: "variant-attr1-sku" } %>
  <%= f.label :attribute2_value, "Attribute 2 value" %><%= f.text_field :attribute2_value, data: { preview_target: "variant-attr2-value" } %>
  <%= f.label :attribute2_sku_component, "Attribute 2 SKU component" %><%= f.text_field :attribute2_sku_component, maxlength: 5, data: { preview_target: "variant-attr2-sku" } %>
  <p class="ss-hint">SKU preview: <span data-preview="variant-sku"><%= product_variant.sku.presence || "—" %></span></p>
  <p class="ss-hint">Source: product SKU + condition/attribute suffixes</p>
  <p class="ss-hint">Name preview: <span data-preview="variant-name"><%= product_variant.rendered_name %></span></p>
  <p class="ss-hint">Name source: <span data-preview="variant-name-source">Generated from product name and variant attributes</span></p>
  <%= f.label :selling_price_cents, "Selling price (cents)" %><%= f.number_field :selling_price_cents, min: 0 %>
  <%= f.label :inventory_behavior, "Inventory behavior" %>
  <%= f.select :inventory_behavior, ProductVariant::INVENTORY_BEHAVIORS.map { |b| [humanize_controlled_value(b), b] } %>
  <%= f.label :display_location_id, "Display location" %>
  <%= f.collection_select :display_location_id, display_locations, :id, :name, include_blank: true %>
  <%= f.label :active %><%= f.check_box :active %>
</fieldset>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    var productSelect = document.querySelector("#product_variant_product_id");
    var conditionSelect = document.querySelector("[data-preview-target='variant-condition']");
    var attr1Value = document.querySelector("[data-preview-target='variant-attr1-value']");
    var attr2Value = document.querySelector("[data-preview-target='variant-attr2-value']");
    var nameOverride = document.querySelector("[data-preview-target='variant-name-override']");
    var attr1Sku = document.querySelector("[data-preview-target='variant-attr1-sku']");
    var attr2Sku = document.querySelector("[data-preview-target='variant-attr2-sku']");
    var skuPreview = document.querySelector("[data-preview='variant-sku']");
    var namePreview = document.querySelector("[data-preview='variant-name']");
    var nameSourcePreview = document.querySelector("[data-preview='variant-name-source']");
    var products = <%= raw products.map { |p| { id: p.id, sku: p.sku, name: p.name, variation_type: p.variation_type } }.to_json %>;
    var conditions = <%= raw conditions.map { |c| { id: c.id, sku_component: c.sku_component, short_name: c.short_name } }.to_json %>;

    function selectedProduct() {
      var id = parseInt(productSelect.value, 10);
      return products.find(function(p) { return p.id === id; });
    }

    function selectedCondition() {
      if (!conditionSelect || !conditionSelect.value) return null;
      var id = parseInt(conditionSelect.value, 10);
      return conditions.find(function(c) { return c.id === id; });
    }

    function previewSku() {
      var product = selectedProduct();
      if (!product || !product.sku) { skuPreview.textContent = "—"; return; }
      var base = product.sku;
      var condition = selectedCondition();
      var a1 = attr1Sku ? attr1Sku.value.trim().toUpperCase() : "";
      var a2 = attr2Sku ? attr2Sku.value.trim().toUpperCase() : "";
      var parts = [];
      if (condition && condition.sku_component) {
        parts.push(condition.sku_component);
      }
      if (product.variation_type === "variable" && a1) {
        parts.push(a1);
      } else if (product.variation_type === "matrix") {
        if (a1) parts.push(a1);
        if (a2) parts.push(a2);
      }
      var sku = parts.length ? base + "-" + parts.join("-") : base;
      skuPreview.textContent = sku;
    }

    function previewName() {
      var product = selectedProduct();
      if (!product || !namePreview || !nameSourcePreview) return;

      var override = nameOverride ? nameOverride.value.trim() : "";
      if (override) {
        namePreview.textContent = override;
        nameSourcePreview.textContent = "Name override";
        return;
      }

      var base = product.name || "—";
      var condition = selectedCondition();
      var a1 = attr1Value ? attr1Value.value.trim() : "";
      var a2 = attr2Value ? attr2Value.value.trim() : "";
      var name = base;
      var source = "Product name";

      if (product.variation_type === "conditional" && condition && condition.short_name) {
        name = base + " - " + condition.short_name;
        source = "Product name + condition";
      } else if (product.variation_type === "variable" && a1) {
        name = base + " - " + a1;
        source = "Product name + attribute 1";
      } else if (product.variation_type === "matrix") {
        if (a1 && a2) {
          name = base + " - " + a1 + " / " + a2;
          source = "Product name + attributes 1 and 2";
        } else if (a1) {
          name = base + " - " + a1;
          source = "Product name + attribute 1";
        } else if (condition && condition.short_name) {
          name = base + " - " + condition.short_name;
          source = "Product name + condition";
        }
      }

      namePreview.textContent = name;
      nameSourcePreview.textContent = source;
    }

    function refreshPreviews() {
      previewSku();
      previewName();
    }

    [productSelect, conditionSelect, attr1Sku, attr2Sku, attr1Value, attr2Value, nameOverride].forEach(function(el) {
      if (el) el.addEventListener("change", refreshPreviews);
      if (el && el.tagName === "INPUT") el.addEventListener("input", refreshPreviews);
    });
    refreshPreviews();
  });
</script>
