<%= render "shared/forms/page_header",
           eyebrow: "Items",
           title: "New Product Variant",
           description: "Create a sellable SKU with condition, attributes, and display settings." %>

<%= form_with model: [:items, @product_variant], class: "ss-form ss-form--wide" do |f| %>
  <%= hidden_field_tag :return_to, "item" %>
  <%= render "form",
             f: f,
             product_variant: @product_variant,
             products: @products,
             sub_departments: @sub_departments,
             conditions: @conditions,
             display_locations: @display_locations,
             vendors: @vendors,
             category_nodes: @category_nodes,
             primary_category_node_id: @primary_category_node_id,
             classification_defaults: @classification_defaults,
             show_advanced: false,
             manage_inventory_behavior: @manage_inventory_behavior %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create Variant", type: :submit, variant: :primary, name: "commit" %>
    <% if @product_variant.product.present? && @product_variant.product.variation_type.in?(%w[variable matrix conditional]) %>
      <%= render "shared/ui/button", label: "Create Variant and Add Another", type: :submit, variant: :secondary, name: "commit" %>
    <% end %>
    <% cancel_path = @product_variant.product.present? ? item_flow_cancel_path(@product_variant.product, tab: "item_setup") : items_product_variants_path %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: cancel_path %>
  </footer>
<% end %>
