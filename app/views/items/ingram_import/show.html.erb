<% content_for(:title, "Ingram Import") %>

<%= render "shared/forms/page_header",
           title: "Ingram Catalog Import",
           description: "Upload an Ingram list to create or update catalog items and products, then add new-condition sellable SKUs when missing." %>

<div class="ss-form ss-form--wide">
  <%= form_with url: items_ingram_import_preview_path, method: :post, html: { multipart: true, class: "ss-form-card" } do |f| %>
    <%= render "shared/forms/section", title: "Import options" do %>
      <div class="ss-form-grid ss-form-grid--2">
        <div class="ss-field">
          <%= label_tag :sub_department_id, ss_required_label("Default subdepartment"), class: "ss-label" %>
          <%= select_tag :sub_department_id,
                         options_from_collection_for_select(@sub_departments, :id, :name, @selected_sub_department_id),
                         include_blank: "Select a subdepartment",
                         required: true,
                         class: "ss-input" %>
          <p class="ss-help">Applied to all newly created sellable SKUs.</p>
        </div>

        <% if @store_category_nodes.any? %>
          <div class="ss-field">
            <%= label_tag :store_category_id, "Default store category", class: "ss-label" %>
            <%= tree_select_tag :store_category_id,
                  @store_category_nodes,
                  selected: @selected_store_category_id,
                  include_blank: "Select store category",
                  html_options: { class: "ss-input" } %>
          </div>
        <% end %>

        <div class="ss-field">
          <%= label_tag :display_location_id, "Default display location", class: "ss-label" %>
          <%= tree_select_tag :display_location_id,
                @display_locations,
                selected: @selected_display_location_id,
                include_blank: "None",
                html_options: { class: "ss-input" } %>
        </div>
      </div>
      <div class="ss-form-grid ss-form-grid--2">
        <div class="ss-check-field">
          <%= check_box_tag :set_preferred_vendor, "1", params[:set_preferred_vendor].nil? ? true : ActiveModel::Type::Boolean.new.cast(params[:set_preferred_vendor]) %>
          <div>
            <%= label_tag :set_preferred_vendor, "Set Ingram as preferred vendor" %>
            <p class="ss-help">Applied to imported products and variants.</p>
          </div>
        </div>
        <div class="ss-check-field">
          <%= check_box_tag :overwrite_existing_preferred_vendor, "1", ActiveModel::Type::Boolean.new.cast(params[:overwrite_existing_preferred_vendor]) %>
          <div>
            <%= label_tag :overwrite_existing_preferred_vendor, "Overwrite existing preferred vendor" %>
          </div>
        </div>
        <div class="ss-check-field">
          <%= check_box_tag :create_or_update_vendor_sources, "1", params[:create_or_update_vendor_sources].nil? ? true : ActiveModel::Type::Boolean.new.cast(params[:create_or_update_vendor_sources]) %>
          <div>
            <%= label_tag :create_or_update_vendor_sources, "Create or update vendor sources" %>
          </div>
        </div>
      </div>
    <% end %>

    <%= render "shared/forms/section", title: "Spreadsheet file" do %>
      <div class="ss-field">
        <%= label_tag :import_file, ss_required_label("Ingram list file"), class: "ss-label" %>
        <%= file_field_tag :import_file, accept: ".xls,.xlsx", required: true, class: "ss-input" %>
        <p class="ss-help">Accepts Ingram .xls or .xlsx exports with standard column headers.</p>
      </div>
    <% end %>

    <div class="ss-form-actions">
      <%= submit_tag "Preview file", class: "ss-button ss-button--primary" %>
      <%= link_to "Back to Items", items_root_path, class: "ss-button ss-button--secondary" %>
    </div>
  <% end %>

  <% if @preview_rows.present? %>
    <%= render "preview", preview_rows: @preview_rows, row_count: @row_count %>

    <%= form_with url: items_ingram_import_run_path, method: :post, class: "ss-form-card" do %>
      <%= hidden_field_tag :sub_department_id, @selected_sub_department_id %>
      <%= hidden_field_tag :store_category_id, @selected_store_category_id %>
      <%= hidden_field_tag :display_location_id, @selected_display_location_id %>
      <%= hidden_field_tag :set_preferred_vendor, params[:set_preferred_vendor] %>
      <%= hidden_field_tag :overwrite_existing_preferred_vendor, params[:overwrite_existing_preferred_vendor] %>
      <%= hidden_field_tag :create_or_update_vendor_sources, params[:create_or_update_vendor_sources] %>
      <div class="ss-form-actions">
        <%= submit_tag "Run import", class: "ss-button ss-button--primary", data: { turbo_confirm: "Run import for #{@row_count} rows?" } %>
      </div>
    <% end %>
  <% end %>

  <% if @import_result.present? %>
    <%= render "results", import_result: @import_result %>
  <% end %>
</div>
