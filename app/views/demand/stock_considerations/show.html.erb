<%= render "setup/shared/back_link", path: demand_stock_considerations_path, label: "Stock considerations" %>

<%
  header_actions = safe_join([
    (render("shared/ui/button", label: "Convert to demand", variant: :primary, url: convert_demand_stock_consideration_path(@stock_consideration), method: :post) if !@stock_consideration.terminal? && Authorization.allowed?(user: current_user, permission_key: "stock_considerations.convert", store: current_store))
  ].compact)
%>

<%= render "shared/ui/page_header",
           title: "Stock consideration",
           description: "Review item context before converting to demand or dismissing.",
           actions: header_actions.presence %>

<dl class="ss-summary">
  <dt>Status</dt><dd><%= stock_consideration_status_badge(@stock_consideration.status) %></dd>
  <dt>Item</dt>
  <dd>
    <% if @stock_consideration.product_variant.present? %>
      <%= @stock_consideration.product_variant.sku %> — <%= @stock_consideration.product_variant.name %>
    <% else %>
      <%= @stock_consideration.provisional_title || "—" %>
    <% end %>
  </dd>
  <dt>Reason</dt><dd><%= @stock_consideration.reason.presence || "—" %></dd>
  <dt>Notes</dt><dd><%= simple_format(@stock_consideration.notes.presence || "—") %></dd>
  <dt>Created</dt><dd><%= display_time(@stock_consideration.created_at) %></dd>
</dl>

<% if @stock_consideration.converted_demand_line.present? %>
  <p><%= link_to "View demand #{@stock_consideration.converted_demand_line.demand_number}",
        demand_demand_line_path(@stock_consideration.converted_demand_line) %></p>
<% end %>

<% unless @stock_consideration.terminal? %>
  <% if Authorization.allowed?(user: current_user, permission_key: "stock_considerations.dismiss", store: current_store) %>
    <section aria-labelledby="stock-consideration-dismiss-heading">
      <h2 id="stock-consideration-dismiss-heading">Danger zone</h2>
      <p class="ss-muted">Dismiss removes this consideration from the open queue. Provide a reason for the audit trail.</p>
      <%= form_with url: dismiss_demand_stock_consideration_path(@stock_consideration), method: :patch, class: "ss-form" do %>
        <div class="ss-field">
          <%= label_tag :dismiss_reason, "Dismiss reason", class: "ss-label" %>
          <%= text_field_tag :dismiss_reason, nil, class: "ss-input", required: true %>
        </div>
        <footer class="ss-form-actions">
          <%= render "shared/ui/button", label: "Dismiss", type: :submit, variant: :danger %>
        </footer>
      <% end %>
    </section>
  <% end %>
<% end %>
