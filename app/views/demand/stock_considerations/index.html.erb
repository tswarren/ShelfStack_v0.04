<%= render "setup/shared/back_link", path: demand_root_path, label: "Demand" %>

<%
  header_actions = safe_join([
    (render("shared/ui/button", label: "Demand lines", variant: :secondary, url: demand_root_path) if Authorization.allowed?(user: current_user, permission_key: "demand.access", store: current_store)),
    (render("shared/ui/button", label: "New", variant: :primary, url: new_demand_stock_consideration_path) if Authorization.allowed?(user: current_user, permission_key: "stock_considerations.create", store: current_store))
  ].compact)
%>

<%= render "shared/ui/page_header",
           title: "Stock considerations",
           description: "Review provisional stocking ideas before converting them to demand lines.",
           actions: header_actions.presence %>

<%= form_with url: demand_stock_considerations_path, method: :get, class: "ss-form" do %>
  <%= hidden_field_tag :queue, "open" if params[:queue] == "open" %>
  <%= render "shared/ui/button",
             label: (params[:queue] == "open" ? "Show all" : "Open queue only"),
             type: :submit,
             variant: :secondary %>
<% end %>

<% if @stock_considerations.any? %>
  <table class="ss-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Status</th>
        <th>Reason</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @stock_considerations.each do |row| %>
        <tr>
          <td>
            <% if row.product_variant.present? %>
              <%= row.product_variant.sku %> — <%= row.product_variant.name %>
            <% else %>
              <%= row.provisional_title || "—" %>
            <% end %>
          </td>
          <td><%= stock_consideration_status_badge(row.status) %></td>
          <td><%= row.reason.presence || "—" %></td>
          <td><%= display_time(row.created_at) %></td>
          <td><%= link_to "View", demand_stock_consideration_path(row) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <% empty_actions = render("shared/ui/button", label: "New stock consideration", variant: :primary, url: new_demand_stock_consideration_path) if Authorization.allowed?(user: current_user, permission_key: "stock_considerations.create", store: current_store) %>
  <%= render "shared/ui/empty_state",
             title: "No stock considerations",
             message: "Capture stocking ideas here before they become demand lines.",
             actions: empty_actions %>
<% end %>
