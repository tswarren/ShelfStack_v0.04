<%
  header_actions = safe_join([
    (render("shared/ui/button", label: "Stock considerations", variant: :secondary, url: demand_stock_considerations_path) if Authorization.allowed?(user: current_user, permission_key: "stock_considerations.access", store: current_store)),
    (render("shared/ui/button", label: "New", variant: :primary, url: new_demand_demand_line_path) if Authorization.allowed?(user: current_user, permission_key: "demand.create", store: current_store))
  ].compact)
%>

<%= render "shared/ui/page_header",
           title: "Demand",
           eyebrow: (@active_queue.present? ? customers_queue_label(@active_queue) : nil),
           description: "Operational demand queue — capture intent, allocation state, and fulfillment progress.",
           actions: header_actions.presence %>

<div class="ss-filter-bar">
  <%= link_to customers_queue_link_label(nil), demand_root_path, class: customers_queue_filter_chip_class(nil) %>
  <% DemandLines::QueueScope::OPERATIONAL_QUEUE_KEYS.each do |queue_key| %>
    <%= link_to customers_queue_link_label(queue_key), demand_demand_lines_path(queue: queue_key), class: customers_queue_filter_chip_class(queue_key) %>
  <% end %>
</div>

<%= form_with url: demand_root_path, method: :get, class: "ss-filter-bar ss-form" do %>
  <%= hidden_field_tag :queue, params[:queue] if params[:queue].present? %>
  <%= select_tag :status,
        options_for_select([["All statuses", ""]] + DemandLine::STATUSES.map { |s| [demand_status_label(s), s] }, params[:status]),
        class: "ss-input" %>
  <%= select_tag :capture_intent,
        options_for_select([["All intents", ""]] + DemandLine::CAPTURE_INTENTS.map { |i| [demand_capture_intent_label(i), i] }, params[:capture_intent]),
        class: "ss-input" %>
  <%= select_tag :allocation_state,
        options_for_select(
          [
            ["All allocation states", ""],
            ["Unallocated", "unallocated"],
            ["Partially allocated", "partially_allocated"],
            ["Allocated", "allocated"],
            ["Fulfilled", "fulfilled"]
          ],
          params[:allocation_state]
        ),
        class: "ss-input" %>
  <%= select_tag :allocation_kind,
        options_for_select(
          [
            ["All allocation kinds", ""],
            ["On hand", "on_hand"],
            ["Inbound PO", "inbound_purchase_order"]
          ],
          params[:allocation_kind]
        ),
        class: "ss-input" %>
  <%= text_field_tag :q, params[:q], placeholder: "Search demand number, customer, SKU, title…", class: "ss-input" %>
  <%= render "shared/ui/button", label: "Filter", type: :submit, variant: :secondary %>
<% end %>

<% if @demand_lines.any? %>
  <table class="ss-table">
    <thead>
      <tr>
        <th>Demand</th>
        <th>Intent</th>
        <th>Customer</th>
        <th>Item</th>
        <th>Status</th>
        <th>Allocation</th>
        <th>Qty</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @demand_lines.each do |line| %>
        <tr>
          <td><%= link_to line.demand_number, demand_demand_line_path(line) %></td>
          <td><%= demand_capture_intent_label(line.capture_intent) %></td>
          <td><%= line.display_customer_name.presence || "—" %></td>
          <td><%= demand_item_label(line) %></td>
          <td><%= demand_status_badge(line.status) %></td>
          <td><%= demand_allocation_state_label(line) %></td>
          <td class="ss-num"><%= line.quantity_requested %></td>
          <td><%= display_time(line.created_at) %></td>
          <td><%= link_to "View", demand_demand_line_path(line) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <% empty_actions = render("shared/ui/button", label: "New demand", variant: :primary, url: new_demand_demand_line_path) if Authorization.allowed?(user: current_user, permission_key: "demand.create", store: current_store) %>
  <%= render "shared/ui/empty_state",
             title: "No demand lines match",
             message: "Adjust queue filters or create a new demand line to capture customer requests.",
             actions: empty_actions %>
<% end %>
