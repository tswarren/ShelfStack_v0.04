<%# locals: workflow %>
<% action = workflow.next_action %>
<section class="ss-panel ss-demand-next-action" id="demand-next-action-panel">
  <h2 class="ss-demand-next-action__title"><%= action.title %></h2>
  <% if action.body.present? %>
    <p class="ss-muted"><%= action.body %></p>
  <% end %>

  <% action_buttons = capture do %>
    <% case action.key %>
    <% when :create_po, :planned_po %>
      <% if Authorization.allowed?(user: current_user, permission_key: "orders.purchase_orders.create", store: current_store) %>
        <%= link_to "Create PO draft",
              new_orders_demand_po_builder_path(demand_line_ids: [workflow.demand_line.id]),
              class: "ss-btn" %>
        <% if action.secondary_path.present? %>
          <%= link_to action.secondary_label,
                add_to_po_demand_demand_line_path(workflow.demand_line),
                class: "ss-btn ss-btn-secondary" %>
        <% end %>
      <% end %>
    <% when :start_sourcing, :review_sourcing %>
      <% if workflow.active_sourcing_run.present? %>
        <%= link_to "Open sourcing run", sourcing_run_path(workflow.active_sourcing_run), class: "ss-btn" %>
      <% else %>
        <%= link_to "Start sourcing", "##{action.anchor || "demand-sourcing-panel"}", class: "ss-btn" %>
      <% end %>
    <% when :review_inbound, :allocate_on_hand, :match_variant %>
      <% if action.primary_label.present? %>
        <%= link_to action.primary_label, "##{action.anchor}", class: "ss-btn" %>
      <% end %>
    <% when :ready_for_pickup %>
      <%= link_to action.primary_label, action.primary_path, class: "ss-btn" if action.primary_path.present? %>
      <%= link_to action.secondary_label, action.secondary_path, class: "ss-btn ss-btn-secondary" if action.secondary_path.present? %>
    <% when :vendor_backorder %>
      <%= link_to action.primary_label, action.primary_path, class: "ss-btn" if action.primary_path.present? %>
    <% when :notify_customer %>
      <%= link_to action.primary_label, action.primary_path, class: "ss-btn" if action.primary_path.present? %>
      <%= link_to action.secondary_label, action.secondary_path, class: "ss-btn ss-btn-secondary" if action.secondary_path.present? %>
    <% end %>
  <% end %>

  <% if action_buttons.present? %>
    <div class="ss-detail-actions"><%= action_buttons %></div>
  <% end %>
</section>
