<%= render "shared/forms/page_header",
           title: "New demand line",
           description: "Capture customer demand with intent, item, and quantity before allocation." %>

<%= form_with url: demand_demand_lines_path, method: :post, class: "ss-form ss-form--standard" do %>
  <div class="ss-field">
    <%= label_tag :capture_intent, "Capture intent", class: "ss-label" %>
    <%= select_tag :capture_intent,
          options_for_select(@capture_intents.map { |i| [demand_capture_intent_label(i), i] }, @demand_line.capture_intent),
          class: "ss-input", required: true %>
  </div>

  <div data-controller="inventory-variant-lookup"
       data-inventory-variant-lookup-url-value="<%= customers_variant_lookup_path %>"
       data-inventory-variant-lookup-require-eligible-value="false"
       <% if @selected_variant.present? %>
         data-inventory-variant-lookup-initial-sku-value="<%= @selected_variant.sku %>"
         data-inventory-variant-lookup-initial-variant-id-value="<%= @selected_variant.id %>"
         data-inventory-variant-lookup-initial-label-value="<%= @selected_variant.name %>"
       <% end %>>
    <div class="ss-field">
      <%= label_tag :variant_lookup, "Item / SKU / ISBN", class: "ss-label" %>
      <%= text_field_tag :variant_lookup, @selected_variant&.sku,
            class: "ss-input",
            placeholder: "Scan or search variant…",
            autocomplete: "off",
            data: {
              inventory_variant_lookup_target: "lookupInput",
              action: "keydown->inventory-variant-lookup#lookupExact input->inventory-variant-lookup#search"
            } %>
      <%= hidden_field_tag :product_variant_id, @selected_variant&.id, data: { inventory_variant_lookup_target: "variantId" } %>
      <p class="ss-hint" data-inventory-variant-lookup-target="preview"></p>
      <p class="ss-hint" data-inventory-variant-lookup-target="message"></p>
      <div class="ss-pos-choices" data-inventory-variant-lookup-target="choices"></div>
      <p class="ss-hint">Leave blank for research/provisional demand only.</p>
    </div>
  </div>

  <% if @supply_preview.present? %>
    <%= render "supply_preview", supply_summary: @supply_preview %>
  <% end %>

  <div data-controller="customer-lookup"
       data-customer-lookup-url-value="<%= customers_customer_lookup_path %>">
    <div class="ss-form-grid ss-form-grid--2">
      <div class="ss-field">
        <%= label_tag :customer_lookup, "Customer", class: "ss-label" %>
        <%= text_field_tag :customer_lookup, @selected_customer&.display_name,
              class: "ss-input",
              placeholder: "Search by name, email, or phone…",
              autocomplete: "off",
              data: {
                customer_lookup_target: "lookupInput",
                action: "keydown->customer-lookup#lookupExact input->customer-lookup#search"
              } %>
        <%= hidden_field_tag :customer_id, @selected_customer&.id, data: { customer_lookup_target: "customerId" } %>
        <div class="ss-pos-choices" data-customer-lookup-target="choices"></div>
      </div>
      <div class="ss-field">
        <%= label_tag :customer_name_snapshot, "Walk-in name", class: "ss-label" %>
        <%= text_field_tag :customer_name_snapshot, @demand_line.customer_name_snapshot, class: "ss-input" %>
      </div>
    </div>
  </div>

  <div class="ss-form-grid ss-form-grid--2">
    <div class="ss-field">
      <%= label_tag :provisional_title, "Provisional title", class: "ss-label" %>
      <%= text_field_tag :provisional_title, @demand_line.provisional_title, class: "ss-input" %>
    </div>
    <div class="ss-field">
      <%= label_tag :provisional_identifier, "Provisional identifier", class: "ss-label" %>
      <%= text_field_tag :provisional_identifier, @demand_line.provisional_identifier, class: "ss-input" %>
    </div>
  </div>

  <div class="ss-form-grid ss-form-grid--2">
    <div class="ss-field">
      <%= label_tag :quantity, "Quantity", class: "ss-label" %>
      <%= number_field_tag :quantity, @demand_line.quantity_requested || 1, min: 1, class: "ss-input" %>
    </div>
    <div class="ss-field">
      <%= label_tag :needed_by_date, "Needed by", class: "ss-label" %>
      <%= date_field_tag :needed_by_date, @demand_line.needed_by_date, class: "ss-input" %>
    </div>
  </div>

  <div class="ss-field">
    <%= label_tag :notes, "Notes", class: "ss-label" %>
    <%= text_area_tag :notes, @demand_line.notes, rows: 2, class: "ss-input" %>
  </div>

  <%= render "shared/forms/errors", record: @demand_line %>

  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create demand", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: demand_root_path %>
  </footer>
<% end %>
