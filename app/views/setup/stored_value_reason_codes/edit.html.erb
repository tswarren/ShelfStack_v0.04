<%= render "setup/shared/back_link", path: setup_stored_value_reason_code_path(@reason_code), label: @reason_code.name %>

<h1>Edit Stored Value Reason Code</h1>
<%= form_with model: @reason_code, url: setup_stored_value_reason_code_path(@reason_code), method: :patch, class: "ss-form ss-form--standard" do |f| %>
  <%= render "shared/forms/errors", record: @reason_code %>
  <div class="ss-form-grid ss-form-grid--2">
    <div class="ss-field">
      <%= f.label :reason_key, class: "ss-label" %>
      <%= f.text_field :reason_key %>
    </div>
    <div class="ss-field">
      <%= f.label :name, class: "ss-label" %>
      <%= f.text_field :name %>
    </div>
  </div>
  <div class="ss-field">
    <%= f.label :description, class: "ss-label" %>
    <%= f.text_area :description, rows: 3 %>
  </div>
  <div class="ss-field">
    <%= f.label :active, class: "ss-label" %>
    <%= f.check_box :active %>
  </div>
  <footer class="ss-form-actions">
    <%= f.submit "Save changes", class: "ss-btn" %>
    <%= link_to "Cancel", setup_stored_value_reason_code_path(@reason_code), class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
