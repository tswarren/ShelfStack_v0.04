<h1><%= @merchandise_class.name %></h1>
<dl class="ss-summary">
  <dt>Merchandise class key</dt><dd><%= @merchandise_class.merchandise_class_key %></dd>
  <dt>Short name</dt><dd><%= @merchandise_class.short_name %></dd>
  <dt>Default pricing model</dt><dd><%= @merchandise_class.default_pricing_model ? humanize_controlled_value(@merchandise_class.default_pricing_model) : "—" %></dd>
  <dt>Default tax category</dt><dd><%= @merchandise_class.default_tax_category.name %></dd>
  <dt>Default margin target</dt><dd><%= @merchandise_class.default_margin_target_bps ? format_basis_points(@merchandise_class.default_margin_target_bps) : "—" %></dd>
  <dt>Default supplier discount</dt><dd><%= @merchandise_class.default_supplier_discount_bps ? format_basis_points(@merchandise_class.default_supplier_discount_bps) : "—" %></dd>
  <dt>Default sales account</dt><dd><%= @merchandise_class.default_sales_account_code || "—" %></dd>
  <dt>Has list price</dt><dd><%= @merchandise_class.has_list_price? ? "Yes" : "No" %></dd>
  <dt>Used sales allowed</dt><dd><%= @merchandise_class.used_sales_allowed? ? "Yes" : "No" %></dd>
  <dt>Buyback allowed</dt><dd><%= @merchandise_class.buyback_allowed? ? "Yes" : "No" %></dd>
  <dt>Status</dt><dd><span class="<%= status_class(@merchandise_class.active?) %>"><%= status_label(@merchandise_class.active?) %></span></dd>
</dl>
<div class="ss-detail-actions">
  <%= link_to "Edit", edit_setup_merchandise_class_path(@merchandise_class), class: "ss-btn" %>
  <% if @merchandise_class.active? %>
    <%= button_to "Inactivate", inactivate_setup_merchandise_class_path(@merchandise_class), method: :patch, class: "ss-btn ss-btn-secondary" %>
  <% else %>
    <%= button_to "Reactivate", reactivate_setup_merchandise_class_path(@merchandise_class), method: :patch, class: "ss-btn" %>
  <% end %>
  <%= button_to "Delete", setup_merchandise_class_path(@merchandise_class), method: :delete, class: "ss-btn ss-btn-secondary", data: { turbo_confirm: "Delete this merchandise class?" } %>
</div>
<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
