<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Merchandise Class",
           description: "Define operational behavior defaults for a merchandise class." %>

<%= form_with model: [:setup, @merchandise_class], class: "ss-form ss-form--wide" do |f| %>
  <%= render "form", f: f, merchandise_class: @merchandise_class, tax_categories: @tax_categories %>
  <footer class="ss-form-actions">
    <%= f.submit "Create Merchandise Class", class: "ss-btn" %>
    <%= link_to "Cancel", setup_merchandise_classes_path, class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
