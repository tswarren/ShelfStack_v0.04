<h1>Sales Account Mappings <%= link_to "New", new_setup_accounting_mapping_path, class: "ss-btn" %></h1>
<table class="ss-table">
  <thead><tr><th>Merchandise Class</th><th>Condition</th><th>Sales Account</th><th>Reporting Bucket</th><th>Status</th><th></th></tr></thead>
  <tbody>
    <% @accounting_mappings.each do |mapping| %>
      <tr>
        <td><%= mapping.merchandise_class&.name || "Any" %></td>
        <td><%= mapping.condition&.short_name || "Any" %></td>
        <td><%= mapping.sales_account_code %></td>
        <td><%= mapping.reporting_bucket || "—" %></td>
        <td><span class="<%= status_class(mapping.active?) %>"><%= status_label(mapping.active?) %></span></td>
        <td><%= link_to "View", setup_accounting_mapping_path(mapping) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
