<%= render "setup/shared/back_link", path: setup_root_path, label: "Setup" %>

<%
  header_actions = safe_join([
    (@scheme.present? ? render("shared/ui/button", label: "View scheme", variant: :secondary, url: setup_category_scheme_path(@scheme)) : nil),
    render(
      "shared/ui/button",
      label: "Load / Update BISAC subjects",
      variant: :primary,
      url: import_setup_bisac_subjects_path,
      method: :post,
      data: { turbo_confirm: "Load or update approximately 3,900 BISAC subject nodes?" }
    )
  ].compact)
%>

<%= render "shared/ui/page_header",
           title: "BISAC Subject Headings",
           description: "Load the industry BISAC subject tree into a dedicated category scheme for catalog reference, reporting, and store category suggestions. BISAC subjects do not replace the store category picker on catalog items.",
           actions: header_actions %>

<dl class="ss-summary">
  <dt>Scheme</dt>
  <dd><%= @scheme&.name || "Not loaded yet" %></dd>
  <dt>Scheme key</dt>
  <dd><%= Bisac::CategoryNodeImporter::SCHEME_KEY %></dd>
  <dt>Loaded nodes</dt>
  <dd><%= @node_count.positive? ? @node_count : "—" %></dd>
  <dt>Source file</dt>
  <dd><%= @source_path.to_s %></dd>
  <dt>Source updated</dt>
  <dd><%= @source_mtime ? l(@source_mtime, format: :long) : "—" %></dd>
  <dt>Last import</dt>
  <dd>
    <% if @last_import %>
      <%= l(@last_import.occurred_at, format: :long) %>
      <% if @last_import.event_details.present? %>
        (<%= @last_import.event_details["created"] %> created, <%= @last_import.event_details["updated"] %> updated)
      <% end %>
    <% else %>
      —
    <% end %>
  </dd>
</dl>
