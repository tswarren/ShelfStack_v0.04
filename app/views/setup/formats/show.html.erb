<h1><%= @format.name %></h1>
<dl class="ss-summary">
  <dt>Format key</dt><dd><%= @format.format_key %></dd>
  <dt>Short name</dt><dd><%= @format.short_name %></dd>
  <dt>Code</dt><dd><%= @format.code || "—" %></dd>
  <dt>Virtual</dt><dd><%= @format.virtual? ? "Yes" : "No" %></dd>
  <dt>Status</dt><dd><span class="<%= status_class(@format.active?) %>"><%= status_label(@format.active?) %></span></dd>
</dl>
<div class="ss-detail-actions">
  <%= link_to "Edit", edit_setup_format_path(@format), class: "ss-btn" %>
  <% if @format.active? %>
    <%= button_to "Inactivate", inactivate_setup_format_path(@format), method: :patch, class: "ss-btn ss-btn-secondary" %>
  <% else %>
    <%= button_to "Reactivate", reactivate_setup_format_path(@format), method: :patch, class: "ss-btn" %>
  <% end %>
  <%= button_to "Delete", setup_format_path(@format), method: :delete, class: "ss-btn ss-btn-secondary", data: { turbo_confirm: "Delete this format?" } %>
</div>
<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
