<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "Edit Format",
           description: "Formats describe the physical or digital form of catalog items." %>

<%= form_with model: @format, url: setup_format_path(@format), class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, format: @format %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Update Format", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_format_path(@format) %>
  </footer>
<% end %>
