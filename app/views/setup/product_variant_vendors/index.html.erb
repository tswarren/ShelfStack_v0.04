<% new_variant_vendor_action = render("shared/ui/button", label: "New", variant: :primary, url: new_setup_product_variant_vendor_path) %>

<%= render "shared/ui/page_header", title: "Variant Vendors", actions: new_variant_vendor_action %>

<% if @product_variant_vendors.any? %>
  <table class="ss-table">
    <thead><tr><th>SKU</th><th>Vendor</th><th>Item #</th><th>Preferred</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @product_variant_vendors.each do |product_variant_vendor| %>
        <tr>
          <td><%= product_variant_vendor.product_variant.sku %></td>
          <td><%= product_variant_vendor.vendor.name %></td>
          <td><%= product_variant_vendor.vendor_item_number || "—" %></td>
          <td><%= product_variant_vendor.preferred? ? "Yes" : "No" %></td>
          <td><%= ss_status_badge(status_label(product_variant_vendor.active?), status: product_variant_vendor.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", setup_product_variant_vendor_path(product_variant_vendor) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No variant vendors yet",
             message: "Link sellable SKUs to vendors for variant-level sourcing overrides.",
             actions: new_variant_vendor_action %>
<% end %>
