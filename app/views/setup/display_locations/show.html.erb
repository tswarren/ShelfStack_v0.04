<%= render "setup/shared/back_link", path: setup_display_locations_path, label: "Display Locations" %>

<%
  header_actions = render(
    "setup/shared/detail_lifecycle_header_actions",
    record: @display_location,
    edit_path: edit_setup_display_location_path(@display_location),
    inactivate_path: inactivate_setup_display_location_path(@display_location),
    reactivate_path: reactivate_setup_display_location_path(@display_location)
  )
%>

<%= render "shared/ui/page_header", title: @display_location.name, actions: header_actions %>

<dl class="ss-summary">
  <dt>Short name</dt><dd><%= @display_location.short_name %></dd>
  <dt>Parent</dt><dd><%= @display_location.parent&.name || "—" %></dd>
  <dt>Sort order</dt><dd><%= @display_location.sort_order %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@display_location.active?), status: @display_location.active? ? :active : :inactive) %></dd>
</dl>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "display-location-danger-zone-heading",
           message: "Delete removes the display location only when nothing references it. Prefer inactivating.",
           delete_label: "Delete display location",
           delete_path: setup_display_location_path(@display_location),
           confirm_message: "Delete this display location? This cannot be undone." %>
