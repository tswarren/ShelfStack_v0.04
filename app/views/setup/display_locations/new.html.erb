<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Display Location",
           description: "Display locations organize where items appear on the sales floor." %>

<%= form_with model: [:setup, @display_location], class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, display_location: @display_location, parents: @parents %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create Display Location", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_display_locations_path %>
  </footer>
<% end %>
