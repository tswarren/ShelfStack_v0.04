<h1><%= @user.display_name %></h1>

<dl class="ss-summary">
  <dt>Username</dt><dd><%= @user.username %></dd>
  <dt>Type</dt><dd><%= @user.user_type %></dd>
  <dt>Status</dt><dd><span class="<%= status_class(@user.active?) %>"><%= status_label(@user.active?) %></span></dd>
  <dt>Clerk number</dt><dd><%= @user.clerk_number || "—" %></dd>
</dl>

<div class="ss-detail-actions">
  <% unless @user.system_user? %>
    <%= link_to "Edit", edit_setup_user_path(@user), class: "ss-btn" %>
  <% else %>
    <p class="flash flash-notice" style="display:inline-block;margin:0;">System user is read-only.</p>
  <% end %>
  <% if @user.active? && !@user.system_user? %>
    <%= button_to "Inactivate", inactivate_setup_user_path(@user), method: :patch, class: "ss-btn ss-btn-secondary" %>
  <% elsif !@user.active? %>
    <%= button_to "Reactivate", reactivate_setup_user_path(@user), method: :patch, class: "ss-btn" %>
  <% end %>
</div>

<%= render "role_assignments" %>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
