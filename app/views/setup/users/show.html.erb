<%= render "setup/shared/back_link", path: setup_users_path, label: "Users" %>

<% if @user.system_user? %>
  <%= render "shared/ui/page_header", title: @user.display_name %>
<% else %>
  <%
    header_actions = render(
      "setup/shared/detail_lifecycle_header_actions",
      record: @user,
      edit_path: edit_setup_user_path(@user),
      inactivate_path: inactivate_setup_user_path(@user),
      reactivate_path: reactivate_setup_user_path(@user)
    )
  %>
  <%= render "shared/ui/page_header", title: @user.display_name, actions: header_actions %>
<% end %>

<% if @user.system_user? %>
  <%= render "shared/ui/alert", variant: :info, message: "System user is read-only." %>
<% end %>

<dl class="ss-summary">
  <dt>Username</dt><dd><%= @user.username %></dd>
  <dt>Type</dt><dd><%= @user.user_type %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@user.active?), status: @user.active? ? :active : :inactive) %></dd>
  <dt>Clerk number</dt><dd><%= @user.clerk_number || "—" %></dd>
</dl>

<%= render "role_assignments" %>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<% unless @user.system_user? %>
  <%= render "setup/shared/detail_danger_zone",
             heading_id: "user-danger-zone-heading",
             message: "Delete removes the user only when nothing references the account. Prefer inactivating to preserve audit history.",
             delete_label: "Delete user",
             delete_path: setup_user_path(@user),
             confirm_message: "Delete this user? This cannot be undone." %>
<% end %>
