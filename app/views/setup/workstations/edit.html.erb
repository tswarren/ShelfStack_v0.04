<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "Edit #{@workstation.name}",
           description: "Update workstation identity and store assignment." %>

<%= form_with model: @workstation, url: setup_workstation_path(@workstation), method: :patch, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, workstation: @workstation, stores: @stores %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Save", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_workstation_path(@workstation) %>
  </footer>
<% end %>
