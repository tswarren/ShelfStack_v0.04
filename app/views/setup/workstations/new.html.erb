<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Workstation",
           description: "Register a terminal or back-office workstation for a store." %>

<%= form_with model: @workstation, url: setup_workstations_path, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, workstation: @workstation, stores: @stores %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create Workstation", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_workstations_path %>
  </footer>
<% end %>
