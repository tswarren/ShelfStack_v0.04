<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Product Condition",
           description: "Conditions drive SKU suffixes, variant names, and used-book pricing factors." %>

<%= form_with model: @product_condition, url: setup_product_conditions_path, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, product_condition: @product_condition %>
  <footer class="ss-form-actions">
    <%= f.submit "Create Condition", class: "ss-btn" %>
    <%= link_to "Cancel", setup_product_conditions_path, class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
