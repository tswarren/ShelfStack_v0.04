<% if product_condition.errors.any? %>
  <div class="flash flash-alert"><%= product_condition.errors.full_messages.to_sentence %></div>
<% end %>
<fieldset class="ss-form-section">
  <legend>Product Condition</legend>
  <%= f.label :condition_key %><%= f.text_field :condition_key %>
  <%= f.label :name %><%= f.text_field :name %>
  <%= f.label :short_name %><%= f.text_field :short_name, maxlength: 20 %>
  <%= f.label :sku_component, "SKU component" %><%= f.text_field :sku_component, maxlength: 5 %>
  <%= f.label :sort_order %><%= f.number_field :sort_order %>
  <%= f.label :new_condition %><%= f.check_box :new_condition %>
  <%= f.label :default_list_price_factor_bps, "List price factor (bps)" %>
  <%= f.number_field :default_list_price_factor_bps, data: { preview_target: "condition-factor-bps" } %>
  <p class="ss-hint">Factor preview: <span data-preview="condition-factor"><%= format_basis_points(product_condition.default_list_price_factor_bps) %></span></p>
  <%= f.label :description %><%= f.text_area :description, rows: 3 %>
  <%= f.label :active %><%= f.check_box :active %>
</fieldset>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    var input = document.querySelector("[data-preview-target='condition-factor-bps']");
    var output = document.querySelector("[data-preview='condition-factor']");
    if (!input || !output) return;
    input.addEventListener("input", function() {
      var bps = parseInt(input.value, 10);
      output.textContent = isNaN(bps) ? "—" : (bps / 100.0).toFixed(2) + "%";
    });
  });
</script>
