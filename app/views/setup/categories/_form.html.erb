<%= render "shared/forms/errors", record: category %>

<%= render layout: "shared/forms/section", locals: {
  title: "Basic Details",
  description: "Merchandise categories bridge legacy reporting buckets to merchandise classes."
} do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :department_id, label: "Department", required: true } do %>
      <%= f.collection_select :department_id, departments, :id, ->(d) { "#{d.department_number} — #{d.name}" }, { include_blank: "Select department" } %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :merchandise_class_id, label: "Merchandise class" } do %>
      <%= f.collection_select :merchandise_class_id, merchandise_classes, :id, :name, include_blank: "Select merchandise class" %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :name, required: true } do %>
      <%= f.text_field :name %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :short_name, required: true } do %>
      <%= f.text_field :short_name, maxlength: 20 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :sort_order } do %>
      <%= f.number_field :sort_order, step: 1 %>
    <% end %>
  </div>
  <%= render "shared/forms/checkbox", f: f, record: category, field: :active,
             help: "Inactive categories remain for history but cannot be selected for new sellable SKUs." %>
<% end %>

<%= render layout: "shared/forms/section", locals: {
  title: "Defaults for Future SKUs",
  description: "These values are copied or suggested when creating sellable SKUs."
} do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :default_pricing_model, label: "Default pricing model" } do %>
      <%= f.select :default_pricing_model, Category::PRICING_MODELS.map { |m| [m.humanize, m] }, { include_blank: "None" } %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :default_tax_category_id, label: "Default tax category", required: true } do %>
      <%= f.collection_select :default_tax_category_id, tax_categories, :id, :name, { include_blank: "Select tax category" } %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :default_margin_target_bps, label: "Default margin target (bps)" } do %>
      <%= f.number_field :default_margin_target_bps, step: 1, min: 0, max: 10000 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: category, field: :default_supplier_discount_bps, label: "Default supplier discount (bps)" } do %>
      <%= f.number_field :default_supplier_discount_bps, step: 1, min: 0, max: 10000 %>
    <% end %>
  </div>
<% end %>
