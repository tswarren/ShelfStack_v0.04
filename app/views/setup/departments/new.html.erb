<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Department",
           description: "Departments group categories for reporting and merchandising." %>

<%= form_with model: @department, url: setup_departments_path, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, department: @department %>
  <footer class="ss-form-actions">
    <%= f.submit "Create Department", class: "ss-btn" %>
    <%= link_to "Cancel", setup_departments_path, class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
