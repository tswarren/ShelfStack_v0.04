<h1><%= @department.name %></h1>
<dl class="ss-summary">
  <dt>Department number</dt><dd><%= @department.department_number %></dd>
  <dt>Short name</dt><dd><%= @department.short_name %></dd>
  <dt>GL account code</dt><dd><%= @department.gl_account_code || "—" %></dd>
  <dt>Description</dt><dd><%= @department.description.presence || "—" %></dd>
  <dt>Status</dt><dd><span class="<%= status_class(@department.active?) %>"><%= status_label(@department.active?) %></span></dd>
</dl>
<h2>Subdepartments</h2>
<% if @sub_departments.any? %>
  <table class="ss-table">
    <thead><tr><th>Name</th><th>Key</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @sub_departments.each do |sub_department| %>
        <tr>
          <td><%= sub_department.name %></td>
          <td><%= sub_department.sub_department_key %></td>
          <td><span class="<%= status_class(sub_department.active?) %>"><%= status_label(sub_department.active?) %></span></td>
          <td><%= link_to "View", setup_sub_department_path(sub_department) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="ss-muted">No subdepartments linked to this department yet.</p>
<% end %>
<div class="ss-detail-actions">
  <%= link_to "Edit", edit_setup_department_path(@department), class: "ss-btn" %>
  <% if @department.active? %>
    <%= button_to "Inactivate", inactivate_setup_department_path(@department), method: :patch, class: "ss-btn ss-btn-secondary" %>
  <% else %>
    <%= button_to "Reactivate", reactivate_setup_department_path(@department), method: :patch, class: "ss-btn" %>
  <% end %>
  <%= button_to "Delete", setup_department_path(@department), method: :delete, class: "ss-btn ss-btn-secondary", data: { turbo_confirm: "Delete this department?" } %>
</div>
<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
