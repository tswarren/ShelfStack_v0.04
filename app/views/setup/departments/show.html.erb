<%= render "setup/shared/back_link", path: setup_departments_path, label: "Departments" %>

<%
  header_actions = render(
    "setup/shared/detail_lifecycle_header_actions",
    record: @department,
    edit_path: edit_setup_department_path(@department),
    inactivate_path: inactivate_setup_department_path(@department),
    reactivate_path: reactivate_setup_department_path(@department)
  )
%>

<%= render "shared/ui/page_header", title: @department.name, actions: header_actions %>

<dl class="ss-summary">
  <dt>Department number</dt><dd><%= @department.department_number %></dd>
  <dt>Short name</dt><dd><%= @department.short_name %></dd>
  <dt>GL account code</dt><dd><%= @department.gl_account_code || "—" %></dd>
  <dt>Description</dt><dd><%= @department.description.presence || "—" %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@department.active?), status: @department.active? ? :active : :inactive) %></dd>
</dl>

<h2>Subdepartments</h2>
<% if @sub_departments.any? %>
  <table class="ss-table">
    <thead><tr><th>Name</th><th>Key</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @sub_departments.each do |sub_department| %>
        <tr>
          <td><%= sub_department.name %></td>
          <td><%= sub_department.sub_department_key %></td>
          <td><%= ss_status_badge(status_label(sub_department.active?), status: sub_department.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", setup_sub_department_path(sub_department) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="ss-muted">No subdepartments linked to this department yet.</p>
<% end %>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "department-danger-zone-heading",
           message: "Delete removes the department only when nothing references it. Prefer inactivating to preserve classification history.",
           delete_label: "Delete department",
           delete_path: setup_department_path(@department),
           confirm_message: "Delete this department? This cannot be undone." %>
