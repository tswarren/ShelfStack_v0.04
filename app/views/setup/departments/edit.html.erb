<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "Edit Department",
           description: "Departments group categories for reporting and merchandising." %>

<%= form_with model: @department, url: setup_department_path(@department), class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, department: @department %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Update Department", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_department_path(@department) %>
  </footer>
<% end %>
