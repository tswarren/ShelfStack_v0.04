<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Subdepartment",
           description: "Define operational behavior defaults for a subdepartment." %>

<%= form_with model: [:setup, @sub_department], class: "ss-form ss-form--wide" do |f| %>
  <%= render "form", f: f, sub_department: @sub_department, tax_categories: @tax_categories, departments: @departments %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create Subdepartment", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_sub_departments_path %>
  </footer>
<% end %>
