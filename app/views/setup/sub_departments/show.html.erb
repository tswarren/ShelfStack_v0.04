<%= render "setup/shared/back_link", path: setup_sub_departments_path, label: "Subdepartments" %>

<%
  header_actions = render(
    "setup/shared/detail_lifecycle_header_actions",
    record: @sub_department,
    edit_path: edit_setup_sub_department_path(@sub_department),
    inactivate_path: inactivate_setup_sub_department_path(@sub_department),
    reactivate_path: reactivate_setup_sub_department_path(@sub_department)
  )
%>

<%= render "shared/ui/page_header", title: @sub_department.name, actions: header_actions %>

<dl class="ss-summary">
  <dt>Department</dt>
  <dd><%= link_to "#{@sub_department.department.department_number} — #{@sub_department.department.name}", setup_department_path(@sub_department.department) %></dd>
  <dt>Subdepartment key</dt><dd><%= @sub_department.sub_department_key %></dd>
  <dt>Short name</dt><dd><%= @sub_department.short_name %></dd>
  <dt>Default pricing model</dt><dd><%= @sub_department.default_pricing_model ? humanize_controlled_value(@sub_department.default_pricing_model) : "—" %></dd>
  <dt>Default tax category</dt><dd><%= @sub_department.default_tax_category.name %></dd>
  <dt>Vendor returnable default</dt><dd><%= @sub_department.vendor_returnable_default? ? "Yes" : "No" %></dd>
  <dt>Buyback allowed</dt><dd><%= @sub_department.buyback_allowed? ? "Yes" : "No" %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@sub_department.active?), status: @sub_department.active? ? :active : :inactive) %></dd>
</dl>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "sub-department-danger-zone-heading",
           message: "Delete removes the subdepartment only when nothing references it. Prefer inactivating to preserve classification history.",
           delete_label: "Delete subdepartment",
           delete_path: setup_sub_department_path(@sub_department),
           confirm_message: "Delete this subdepartment? This cannot be undone." %>
