<%= render "setup/shared/back_link", path: setup_sub_departments_path, label: "Subdepartments" %>
<h1><%= @sub_department.name %></h1>
<dl class="ss-summary">
  <dt>Department</dt>
  <dd><%= link_to "#{@sub_department.department.department_number} — #{@sub_department.department.name}", setup_department_path(@sub_department.department) %></dd>
  <dt>Subdepartment key</dt><dd><%= @sub_department.sub_department_key %></dd>
  <dt>Short name</dt><dd><%= @sub_department.short_name %></dd>
  <dt>Default pricing model</dt><dd><%= @sub_department.default_pricing_model ? humanize_controlled_value(@sub_department.default_pricing_model) : "—" %></dd>
  <dt>Default tax category</dt><dd><%= @sub_department.default_tax_category.name %></dd>
  <dt>Vendor returnable default</dt><dd><%= @sub_department.vendor_returnable_default? ? "Yes" : "No" %></dd>
  <dt>Buyback allowed</dt><dd><%= @sub_department.buyback_allowed? ? "Yes" : "No" %></dd>
  <dt>Status</dt><dd><span class="<%= status_class(@sub_department.active?) %>"><%= status_label(@sub_department.active?) %></span></dd>
</dl>
<div class="ss-detail-actions">
  <%= link_to "Edit", edit_setup_sub_department_path(@sub_department), class: "ss-btn" %>
  <% if @sub_department.active? %>
    <%= button_to "Inactivate", inactivate_setup_sub_department_path(@sub_department), method: :patch, class: "ss-btn ss-btn-secondary" %>
  <% else %>
    <%= button_to "Reactivate", reactivate_setup_sub_department_path(@sub_department), method: :patch, class: "ss-btn" %>
  <% end %>
  <%= button_to "Delete", setup_sub_department_path(@sub_department), method: :delete, class: "ss-btn ss-btn-secondary", data: { turbo_confirm: "Delete this subdepartment?" } %>
</div>
<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
