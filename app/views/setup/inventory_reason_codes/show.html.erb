<%= render "setup/shared/back_link", path: setup_inventory_reason_codes_path, label: "Inventory Reason Codes" %>

<%
  header_actions = render(
    "setup/shared/detail_lifecycle_header_actions",
    record: @reason_code,
    edit_path: edit_setup_inventory_reason_code_path(@reason_code),
    inactivate_path: inactivate_setup_inventory_reason_code_path(@reason_code),
    reactivate_path: reactivate_setup_inventory_reason_code_path(@reason_code)
  )
%>

<%= render "shared/ui/page_header", title: @reason_code.name, actions: header_actions %>

<dl class="ss-summary">
  <dt>Key</dt><dd><code><%= @reason_code.reason_key %></code></dd>
  <dt>Sort order</dt><dd><%= @reason_code.sort_order %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@reason_code.active?), status: @reason_code.active? ? :active : :inactive) %></dd>
</dl>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "inventory-reason-code-danger-zone-heading",
           message: "Delete removes the reason code only when no inventory history references it. Prefer inactivating.",
           delete_label: "Delete reason code",
           delete_path: setup_inventory_reason_code_path(@reason_code),
           confirm_message: "Delete this inventory reason code? This cannot be undone." %>
