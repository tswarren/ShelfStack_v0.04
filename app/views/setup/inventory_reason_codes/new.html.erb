<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Inventory Reason Code",
           description: "Reason codes staff select when posting inventory adjustments." %>

<%= form_with model: @reason_code, url: setup_inventory_reason_codes_path, class: "ss-form ss-form--standard" do |f| %>
  <%= render "shared/forms/errors", record: @reason_code %>
  <div class="ss-form-grid ss-form-grid--2">
    <div class="ss-field">
      <%= f.label :reason_key, class: "ss-label" %>
      <%= f.text_field :reason_key, class: "ss-input" %>
    </div>
    <div class="ss-field">
      <%= f.label :name, class: "ss-label" %>
      <%= f.text_field :name, class: "ss-input" %>
    </div>
    <div class="ss-field">
      <%= f.label :sort_order, class: "ss-label" %>
      <%= f.number_field :sort_order, class: "ss-input" %>
    </div>
  </div>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create reason code", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_inventory_reason_codes_path %>
  </footer>
<% end %>
