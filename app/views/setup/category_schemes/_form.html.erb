<%= form_with model: [:setup, @category_scheme], class: "ss-form ss-form--standard" do |f| %>
  <%= render "shared/forms/errors", record: @category_scheme %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: @category_scheme, field: :scheme_key, label: "Scheme key", required: true } do %>
      <%= f.text_field :scheme_key, maxlength: 30 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: @category_scheme, field: :name, required: true } do %>
      <%= f.text_field :name %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: @category_scheme, field: :purpose, required: true } do %>
      <%= f.select :purpose, CategoryScheme::PURPOSES.map { |p| [humanize_scheme_purpose(p), p] } %>
    <% end %>
  </div>
  <%= render "shared/forms/checkbox", f: f, record: @category_scheme, field: :active %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button",
               label: (@category_scheme.persisted? ? "Update Category Scheme" : "Create Category Scheme"),
               type: :submit,
               variant: :primary %>
    <%= render "shared/ui/button",
               label: "Cancel",
               variant: :tertiary,
               url: (@category_scheme.persisted? ? setup_category_scheme_path(@category_scheme) : setup_category_schemes_path) %>
  </footer>
<% end %>
