<h1><%= @category_scheme.name %></h1>
<dl class="ss-summary">
  <dt>Scheme key</dt><dd><%= @category_scheme.scheme_key %></dd>
  <dt>Purpose</dt><dd><%= humanize_scheme_purpose(@category_scheme.purpose) %></dd>
  <dt>Status</dt><dd><span class="<%= status_class(@category_scheme.active?) %>"><%= status_label(@category_scheme.active?) %></span></dd>
</dl>
<div class="ss-detail-actions">
  <%= link_to "Edit", edit_setup_category_scheme_path(@category_scheme), class: "ss-btn" %>
  <%= link_to "Manage Nodes", setup_category_scheme_category_nodes_path(@category_scheme), class: "ss-btn ss-btn-secondary" %>
</div>
<h2>Category Nodes</h2>
<table class="ss-table">
  <thead><tr><th>Name</th><th>Key</th><th>Parent</th><th>Status</th></tr></thead>
  <tbody>
    <% @category_nodes.each do |node| %>
      <tr>
        <td><%= link_to node.name, setup_category_scheme_category_node_path(@category_scheme, node) %></td>
        <td><%= node.node_key %></td>
        <td><%= node.parent&.name || "—" %></td>
        <td><span class="<%= status_class(node.active?) %>"><%= status_label(node.active?) %></span></td>
      </tr>
    <% end %>
  </tbody>
</table>
<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
