<%= render "setup/shared/back_link", path: setup_category_schemes_path, label: "Category Schemes" %>

<%
  header_actions = if @category_scheme.active?
                     safe_join([
                       render("shared/ui/button", label: "Manage Nodes", variant: :secondary, url: setup_category_scheme_category_nodes_path(@category_scheme)),
                       render("shared/ui/button", label: "Inactivate", variant: :secondary, url: inactivate_setup_category_scheme_path(@category_scheme), method: :patch),
                       render("shared/ui/button", label: "Edit", variant: :primary, url: edit_setup_category_scheme_path(@category_scheme))
                     ])
                   else
                     safe_join([
                       render("shared/ui/button", label: "Manage Nodes", variant: :secondary, url: setup_category_scheme_category_nodes_path(@category_scheme)),
                       render("shared/ui/button", label: "Edit", variant: :secondary, url: edit_setup_category_scheme_path(@category_scheme)),
                       render("shared/ui/button", label: "Reactivate", variant: :primary, url: reactivate_setup_category_scheme_path(@category_scheme), method: :patch)
                     ])
                   end
%>

<%= render "shared/ui/page_header", title: @category_scheme.name, actions: header_actions %>

<dl class="ss-summary">
  <dt>Scheme key</dt><dd><%= @category_scheme.scheme_key %></dd>
  <dt>Purpose</dt><dd><%= humanize_scheme_purpose(@category_scheme.purpose) %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@category_scheme.active?), status: @category_scheme.active? ? :active : :inactive) %></dd>
</dl>

<h2>Category Nodes</h2>
<% if @category_nodes.any? %>
  <table class="ss-table">
    <thead><tr><th>Name</th><th>Key</th><th>Parent</th><th>Status</th></tr></thead>
    <tbody>
      <% @category_nodes.each do |node| %>
        <tr>
          <td><%= link_to node.name, setup_category_scheme_category_node_path(@category_scheme, node) %></td>
          <td><%= node.node_key %></td>
          <td><%= node.parent&.name || "—" %></td>
          <td><%= ss_status_badge(status_label(node.active?), status: node.active? ? :active : :inactive) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="ss-muted">No nodes in this scheme yet.</p>
<% end %>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "category-scheme-danger-zone-heading",
           message: "Delete removes the scheme only when no nodes reference it. Prefer inactivating to preserve history.",
           delete_label: "Delete category scheme",
           delete_path: setup_category_scheme_path(@category_scheme),
           confirm_message: "Delete this category scheme? This cannot be undone." %>
