<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Vendor",
           description: "Vendors supply products and may provide default pricing terms." %>

<%= form_with model: [:setup, @vendor], class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, vendor: @vendor, parent_vendors: @parent_vendors %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create Vendor", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_vendors_path %>
  </footer>
<% end %>
