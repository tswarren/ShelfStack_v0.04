<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "Edit Tax Category",
           description: "Tax categories describe item taxability for store tax mappings." %>

<%= form_with model: @tax_category, url: setup_tax_category_path(@tax_category), class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, tax_category: @tax_category %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Update Tax Category", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_tax_category_path(@tax_category) %>
  </footer>
<% end %>
