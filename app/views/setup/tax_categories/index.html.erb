<% new_tax_category_action = render("shared/ui/button", label: "New", variant: :primary, url: new_setup_tax_category_path) %>

<%= render "shared/ui/page_header", title: "Tax Categories", actions: new_tax_category_action %>

<% if @tax_categories.any? %>
  <table class="ss-table">
    <thead><tr><th>Name</th><th>Short Name</th><th>Sort</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% @tax_categories.each do |tax_category| %>
        <tr>
          <td><%= tax_category.name %></td>
          <td><%= tax_category.short_name %></td>
          <td><%= tax_category.sort_order %></td>
          <td><%= ss_status_badge(status_label(tax_category.active?), status: tax_category.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", setup_tax_category_path(tax_category) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No tax categories yet",
             message: "Create a tax category to describe item taxability for store tax mappings.",
             actions: new_tax_category_action %>
<% end %>
