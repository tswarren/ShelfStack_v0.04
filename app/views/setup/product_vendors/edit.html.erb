<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "Edit Product Vendor",
           description: "Update vendor sourcing defaults for this product." %>

<%= form_with model: [:setup, @product_vendor], url: setup_product_vendor_path(@product_vendor), class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, product_vendor: @product_vendor %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Update Product Vendor", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_product_vendor_path(@product_vendor) %>
  </footer>
<% end %>
