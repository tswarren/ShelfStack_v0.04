<h1><%= @category_scheme.store_category_scheme? ? "Store Categories" : "#{@category_scheme.name} Nodes" %> <%= link_to "New", new_setup_category_scheme_category_node_path(@category_scheme), class: "ss-btn" %></h1>
<%= link_to "Back to scheme", setup_category_scheme_path(@category_scheme), class: "ss-btn ss-btn-secondary" %>
<table class="ss-table ss-table--tree">
  <thead>
    <tr>
      <th>Name</th>
      <th>Key</th>
      <% if @category_scheme.store_category_scheme? %>
        <th>Default subdepartment</th>
        <th>Default display location</th>
      <% end %>
      <th>Status</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @category_node_rows.each do |row| %>
      <% node = row.record %>
      <tr class="<%= "ss-tree-row--root" if row.depth.zero? %>">
        <td class="ss-tree-name-cell" style="--tree-depth: <%= row.depth %>">
          <%= node.name %>
        </td>
        <td><%= node.node_key %></td>
        <% if @category_scheme.store_category_scheme? %>
          <td><%= node.default_sub_department&.name || "—" %></td>
          <td><%= node.default_display_location&.name || "—" %></td>
        <% end %>
        <td><span class="<%= status_class(node.active?) %>"><%= status_label(node.active?) %></span></td>
        <td><%= link_to "View", setup_category_scheme_category_node_path(@category_scheme, node) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
