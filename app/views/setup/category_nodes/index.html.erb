<%= render "setup/shared/back_link", path: setup_category_scheme_path(@category_scheme), label: @category_scheme.name %>

<%
  page_title = @category_scheme.store_category_scheme? ? "Store Categories" : "#{@category_scheme.name} Nodes"
  new_node_action = render("shared/ui/button", label: "New", variant: :primary, url: new_setup_category_scheme_category_node_path(@category_scheme))
%>

<%= render "shared/ui/page_header", title: page_title, actions: new_node_action %>

<% if @category_node_rows.any? %>
  <table class="ss-table ss-table--tree">
    <thead>
      <tr>
        <th>Name</th>
        <th>Key</th>
        <% if @category_scheme.store_category_scheme? %>
          <th>Default subdepartment</th>
          <th>Default display location</th>
        <% end %>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @category_node_rows.each do |row| %>
        <% node = row.record %>
        <tr class="<%= "ss-tree-row--root" if row.depth.zero? %>">
          <td class="ss-tree-name-cell" style="--tree-depth: <%= row.depth %>">
            <%= node.name %>
          </td>
          <td><%= node.node_key %></td>
          <% if @category_scheme.store_category_scheme? %>
            <td><%= node.default_sub_department&.name || "—" %></td>
            <td><%= node.default_display_location&.name || "—" %></td>
          <% end %>
          <td><%= ss_status_badge(status_label(node.active?), status: node.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", setup_category_scheme_category_node_path(@category_scheme, node) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No category nodes yet",
             message: "Add nodes to build the tree for this scheme.",
             actions: new_node_action %>
<% end %>
