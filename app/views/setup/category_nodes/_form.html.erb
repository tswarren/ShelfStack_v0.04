<%= form_with model: [:setup, @category_scheme, @category_node], class: "ss-form ss-form--standard" do |f| %>
  <%= render "shared/forms/errors", record: @category_node %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: @category_node, field: :node_key, label: "Node key", required: true } do %>
      <%= f.text_field :node_key, maxlength: 30 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: @category_node, field: :name, required: true } do %>
      <%= f.text_field :name %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: @category_node, field: :parent_id, label: "Parent node" } do %>
      <%= tree_collection_select(f, :parent_id, @parent_nodes, include_blank: "Top level") %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: @category_node, field: :sort_order } do %>
      <%= f.number_field :sort_order, min: 0, step: 1 %>
    <% end %>

    <% if @category_scheme.scheme_key == CategoryNode::STORE_CATEGORIES_SCHEME_KEY %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: @category_node, field: :default_sub_department_id, label: "Default subdepartment" } do %>
        <%= f.collection_select :default_sub_department_id, @sub_departments, :id, :name, include_blank: "None" %>
      <% end %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: @category_node, field: :default_display_location_id, label: "Default display location" } do %>
        <%= tree_collection_select(f, :default_display_location_id, @display_locations, include_blank: "None") %>
      <% end %>
    <% end %>

    <% if @category_scheme.scheme_key == Bisac::CategoryNodeImporter::SCHEME_KEY %>
      <%= render layout: "shared/forms/field", locals: { f: f, record: @category_node, field: :default_store_category_id, label: "Default store category" } do %>
        <%= tree_collection_select(f, :default_store_category_id, @store_category_nodes, include_blank: "None") %>
      <% end %>
    <% end %>
  </div>
  <%= render "shared/forms/checkbox", f: f, record: @category_node, field: :active %>
  <footer class="ss-form-actions">
    <%= f.submit class: "ss-btn" %>
    <%= link_to "Cancel", setup_category_scheme_category_nodes_path(@category_scheme), class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
