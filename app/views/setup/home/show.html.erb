<%= render "shared/ui/page_header",
           title: "Setup",
           description: "Configure stores, users, classification, catalog reference data, and inventory settings." %>

<div class="ss-setup-home">
  <% if @setup_sections.any? %>
    <% @setup_sections.each do |section| %>
      <section class="ss-setup-section">
        <h2><%= section.title %></h2>
        <div class="ss-card-grid">
          <% section.links.each do |link| %>
            <%= render "setup/shared/nav_card", link: link %>
          <% end %>
        </div>
      </section>
    <% end %>
  <% else %>
    <%= render "shared/ui/empty_state",
               title: "No setup areas available",
               message: "Your account has setup access but no individual setup permissions. Ask an administrator to assign the relevant setup roles." %>
  <% end %>
</div>
