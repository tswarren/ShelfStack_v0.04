<%= render "shared/forms/errors", record: store %>

<%= render layout: "shared/forms/section", locals: { title: "Identity", description: "Store number and display name used across ShelfStack." } do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :store_number, required: true } do %>
      <%= f.text_field :store_number, maxlength: 4 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :store_group } do %>
      <%= f.text_field :store_group, maxlength: 5 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :name, required: true } do %>
      <%= f.text_field :name, maxlength: 80 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :shopping_center } do %>
      <%= f.text_field :shopping_center %>
    <% end %>
  </div>
<% end %>

<%= render layout: "shared/forms/section", locals: { title: "Address" } do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :address_line1, label: "Address line 1" } do %>
      <%= f.text_field :address_line1 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :address_line2, label: "Address line 2" } do %>
      <%= f.text_field :address_line2 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :city } do %>
      <%= f.text_field :city %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :region_code, label: "State / region" } do %>
      <%= f.text_field :region_code, maxlength: 2 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :postal_code } do %>
      <%= f.text_field :postal_code, maxlength: 20 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :country_code } do %>
      <%= f.text_field :country_code, maxlength: 2 %>
    <% end %>
  </div>
<% end %>

<%= render layout: "shared/forms/section", locals: { title: "Contact" } do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :phone } do %>
      <%= f.text_field :phone, maxlength: 20 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :fax } do %>
      <%= f.text_field :fax, maxlength: 20 %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :email } do %>
      <%= f.email_field :email %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :website_url, label: "Website" } do %>
      <%= f.url_field :website_url %>
    <% end %>
  </div>
<% end %>

<%= render layout: "shared/forms/section", locals: { title: "Operations" } do %>
  <div class="ss-form-grid">
    <%= render layout: "shared/forms/field", locals: { f: f, record: store, field: :time_zone } do %>
      <%= f.text_field :time_zone %>
    <% end %>
  </div>
<% end %>
