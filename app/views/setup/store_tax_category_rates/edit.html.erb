<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "Edit Store Tax Mapping",
           description: "This rule determines which store tax rate applies to a tax category during a date range." %>

<%= form_with model: @store_tax_category_rate, url: setup_store_tax_category_rate_path(@store_tax_category_rate), class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, store_tax_category_rate: @store_tax_category_rate, stores: @stores, tax_categories: @tax_categories, store_tax_rates: @store_tax_rates %>
  <footer class="ss-form-actions">
    <%= f.submit "Update Tax Mapping", class: "ss-btn" %>
    <%= link_to "Cancel", setup_store_tax_category_rate_path(@store_tax_category_rate), class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
