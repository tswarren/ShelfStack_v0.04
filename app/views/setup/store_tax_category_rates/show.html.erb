<%= render "setup/shared/back_link", path: setup_store_tax_category_rates_path, label: "Tax Mappings" %>

<%
  header_actions = render(
    "setup/shared/detail_lifecycle_header_actions",
    record: @store_tax_category_rate,
    edit_path: edit_setup_store_tax_category_rate_path(@store_tax_category_rate),
    inactivate_path: inactivate_setup_store_tax_category_rate_path(@store_tax_category_rate),
    reactivate_path: reactivate_setup_store_tax_category_rate_path(@store_tax_category_rate)
  )
%>

<%= render "shared/ui/page_header", title: "Tax Mapping", actions: header_actions %>

<dl class="ss-summary">
  <dt>Store</dt><dd><%= @store_tax_category_rate.store.name %> (<%= @store_tax_category_rate.store.store_number %>)</dd>
  <dt>Tax category</dt><dd><%= @store_tax_category_rate.tax_category.name %></dd>
  <dt>Store tax rate</dt><dd><%= @store_tax_category_rate.store_tax_rate.name %> (<%= format_basis_points(@store_tax_category_rate.store_tax_rate.tax_rate_bps) %>)</dd>
  <dt>Effective on</dt><dd><%= @store_tax_category_rate.effective_on %></dd>
  <dt>Ends on</dt><dd><%= @store_tax_category_rate.ends_on || "Open-ended" %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@store_tax_category_rate.active?), status: @store_tax_category_rate.active? ? :active : :inactive) %></dd>
</dl>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "tax-mapping-danger-zone-heading",
           message: "Delete removes the mapping only when it is safe to do so. Prefer inactivating to preserve tax history.",
           delete_label: "Delete tax mapping",
           delete_path: setup_store_tax_category_rate_path(@store_tax_category_rate),
           confirm_message: "Delete this tax mapping? This cannot be undone." %>
