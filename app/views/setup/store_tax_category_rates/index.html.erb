<h1>Tax Mappings <%= link_to "New", new_setup_store_tax_category_rate_path, class: "ss-btn" %></h1>

<% if @stores.many? %>
  <p>
    Filter:
    <%= link_to "All stores", setup_store_tax_category_rates_path, class: params[:store_id].blank? ? "ss-link-active" : nil %>
    <% @stores.each do |store| %>
      | <%= link_to store.store_number, setup_store_tax_category_rates_path(store_id: store.id), class: params[:store_id].to_s == store.id.to_s ? "ss-link-active" : nil %>
    <% end %>
  </p>
<% end %>

<table class="ss-table">
  <thead><tr><th>Store</th><th>Tax Category</th><th>Rate</th><th>Effective</th><th>Ends</th><th>Status</th><th></th></tr></thead>
  <tbody>
    <% @store_tax_category_rates.each do |mapping| %>
      <tr>
        <td><%= mapping.store.store_number %></td>
        <td><%= mapping.tax_category.name %></td>
        <td><%= mapping.store_tax_rate.name %> (<%= format_basis_points(mapping.store_tax_rate.tax_rate_bps) %>)</td>
        <td><%= mapping.effective_on %></td>
        <td><%= mapping.ends_on || "Open-ended" %></td>
        <td><span class="<%= status_class(mapping.active?) %>"><%= status_label(mapping.active?) %></span></td>
        <td><%= link_to "View", setup_store_tax_category_rate_path(mapping) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
