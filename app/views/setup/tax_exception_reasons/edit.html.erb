<h1>Edit Tax Exception Reason</h1>
<%= form_with model: @tax_exception_reason, url: setup_tax_exception_reason_path(@tax_exception_reason), method: :patch, class: "ss-form" do |f| %>
  <%= render "form", f: f, tax_exception_reason: @tax_exception_reason %>
  <%= f.submit "Save", class: "ss-btn" %>
<% end %>
