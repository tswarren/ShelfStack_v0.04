<%= render "shared/forms/errors", record: store_display_location %>

<%= render layout: "shared/forms/section", locals: {
  title: "Store Assignment",
  description: "Link a global display location to a store with optional linear feet."
} do %>
  <div class="ss-form-grid ss-form-grid--2">
    <%= render layout: "shared/forms/field", locals: { f: f, record: store_display_location, field: :store_id, label: "Store", required: true } do %>
      <%= f.collection_select :store_id, stores, :id, :name %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store_display_location, field: :display_location_id, label: "Display location", required: true } do %>
      <%= tree_collection_select(f, :display_location_id, display_locations) %>
    <% end %>
    <%= render layout: "shared/forms/field", locals: { f: f, record: store_display_location, field: :linear_feet, label: "Linear feet" } do %>
      <%= f.number_field :linear_feet, min: 0 %>
    <% end %>
  </div>
<% end %>

<%= render layout: "shared/forms/section", locals: { title: "Status" } do %>
  <%= render "shared/forms/checkbox", f: f, record: store_display_location, field: :active,
             help: "Inactive assignments remain for history but are not used for new variants." %>
<% end %>
