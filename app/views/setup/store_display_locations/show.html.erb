<%= render "setup/shared/back_link", path: setup_store_display_locations_path, label: "Store Display Locations" %>

<%
  header_actions = render(
    "setup/shared/detail_lifecycle_header_actions",
    record: @store_display_location,
    edit_path: edit_setup_store_display_location_path(@store_display_location),
    inactivate_path: inactivate_setup_store_display_location_path(@store_display_location),
    reactivate_path: reactivate_setup_store_display_location_path(@store_display_location)
  )
%>

<%= render "shared/ui/page_header",
           title: "#{@store_display_location.store.name} — #{@store_display_location.display_location.name}",
           actions: header_actions %>

<dl class="ss-summary">
  <dt>Store</dt><dd><%= @store_display_location.store.name %> (<%= @store_display_location.store.store_number %>)</dd>
  <dt>Display location</dt><dd><%= @store_display_location.display_location.name %></dd>
  <dt>Linear feet</dt><dd><%= @store_display_location.linear_feet %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@store_display_location.active?), status: @store_display_location.active? ? :active : :inactive) %></dd>
</dl>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>

<%= render "setup/shared/detail_danger_zone",
           heading_id: "store-display-location-danger-zone-heading",
           message: "Delete removes the store assignment only when nothing references it. Prefer inactivating.",
           delete_label: "Delete store display location",
           delete_path: setup_store_display_location_path(@store_display_location),
           confirm_message: "Delete this store display location?" %>
