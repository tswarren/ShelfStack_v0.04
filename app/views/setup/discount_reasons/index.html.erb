<% new_discount_reason_action = render("shared/ui/button", label: "New", variant: :primary, url: new_setup_discount_reason_path) %>

<%= render "shared/ui/page_header", title: "Discount Reasons", actions: new_discount_reason_action %>

<% if @discount_reasons.any? %>
  <table class="ss-table">
    <thead>
      <tr>
        <th>Key</th>
        <th>Name</th>
        <th>Sort</th>
        <th>Note</th>
        <th>Auth</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @discount_reasons.each do |discount_reason| %>
        <tr>
          <td><code><%= discount_reason.reason_key %></code></td>
          <td><%= discount_reason.name %></td>
          <td><%= discount_reason.sort_order %></td>
          <td><%= discount_reason.requires_note? ? "Yes" : "No" %></td>
          <td><%= discount_reason.requires_authorization? ? "Yes" : "No" %></td>
          <td><%= ss_status_badge(status_label(discount_reason.active?), status: discount_reason.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", setup_discount_reason_path(discount_reason) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No discount reasons yet",
             message: "Create discount reasons for structured POS line and transaction discounts.",
             actions: new_discount_reason_action %>
<% end %>
