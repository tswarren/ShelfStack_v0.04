<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Discount Reason",
           description: "Discount reasons drive structured POS discounts with optional note and authorization requirements." %>

<%= form_with model: @discount_reason, url: setup_discount_reasons_path, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, discount_reason: @discount_reason %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create Discount Reason", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_discount_reasons_path %>
  </footer>
<% end %>
