<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "Edit Discount Reason",
           description: "Update discount reason settings for structured POS discounts." %>

<%= form_with model: @discount_reason, url: setup_discount_reason_path(@discount_reason), method: :patch, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, discount_reason: @discount_reason %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Update Discount Reason", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_discount_reason_path(@discount_reason) %>
  </footer>
<% end %>
