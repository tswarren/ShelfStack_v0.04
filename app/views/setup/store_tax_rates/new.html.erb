<%= render "shared/forms/page_header",
           eyebrow: "Setup",
           title: "New Store Tax Rate",
           description: "Define a named tax rate for a store. Map tax categories to this rate separately." %>

<%= form_with model: @store_tax_rate, url: setup_store_tax_rates_path, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, store_tax_rate: @store_tax_rate, stores: @stores %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Create Store Tax Rate", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: setup_store_tax_rates_path %>
  </footer>
<% end %>
