<%# locals: f, record, field, label: nil, help: nil %>
<div class="ss-check-field">
  <%= f.check_box field %>
  <div>
    <%= f.label field, local_assigns.fetch(:label, nil) || field.to_s.humanize %>
    <% if local_assigns.fetch(:help, nil).present? %>
      <p class="ss-help"><%= help %></p>
    <% end %>
    <%= ss_field_error(record, field) %>
  </div>
</div>
