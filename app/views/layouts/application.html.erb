<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "ShelfStack" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <%= tag.body(**shelfstack_body_attributes) do %>
    <%= link_to "Skip to content", "#main_content", class: "ss-skip-link" %>
    <%= render "layouts/header" %>
    <%= render "layouts/nav" %>
    <main id="main_content" class="<%= shelfstack_class_names("ss-main", content_for(:main_class)) %>">
      <%= render "shared/feedback/flash_region" %>
      <%= yield %>
    </main>
    <%= render "layouts/footer" %>
    <%= render "shared/interaction/toast_region" %>
    <div id="modal_close_triggers" aria-hidden="true"></div>
    <div id="demand_form_reset_triggers" aria-hidden="true"></div>
  <% end %>
</html>
