<nav class="ss-nav">
  <%= link_to "Dashboard", root_path, class: (current_page?(root_path) ? "active" : nil) %>
  <% if Authorization.allowed?(user: current_user, permission_key: "pos.access", store: current_store) %>
    <%= link_to "POS", pos_root_path, class: (request.path.start_with?("/pos") ? "active" : nil) %>
  <% else %>
    <span class="disabled">POS</span>
  <% end %>
  <% if Authorization.allowed?(user: current_user, permission_key: "inventory.access", store: current_store) %>
    <%= link_to "Inventory", inventory_root_path, class: (request.path.start_with?("/inventory") ? "active" : nil) %>
  <% else %>
    <span class="disabled">Inventory</span>
  <% end %>
  <%= link_to "Items", items_root_path, class: (request.path.start_with?("/items") ? "active" : nil) %>
  <% if Authorization.allowed?(user: current_user, permission_key: "orders.access", store: current_store) %>
    <%= link_to "Orders", orders_root_path, class: (request.path.start_with?("/orders") ? "active" : nil) %>
  <% else %>
    <span class="disabled">Orders</span>
  <% end %>
  <span class="disabled">Customers</span>
  <span class="disabled">Reports</span>
  <%= link_to "Setup", setup_root_path, class: (request.path.start_with?("/setup") ? "active" : nil) %>
</nav>
