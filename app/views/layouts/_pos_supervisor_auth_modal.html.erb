<%= render "shared/interaction/modal",
      id: "pos-supervisor-auth-modal",
      title: "Manager approval",
      size: :pos,
      close_on_backdrop: true,
      dirty_guard: true do %>
  <div data-controller="pos-supervisor-auth">
    <p class="ss-hint" data-pos-supervisor-auth-target="message">A manager must enter their username and PIN to approve this action.</p>
    <%= form_with url: pos_authorizations_path, method: :post, html: { data: { pos_supervisor_auth_target: "form", action: "submit->pos-supervisor-auth#submit" } } do %>
      <%= hidden_field_tag :authorization_type, nil, data: { pos_supervisor_auth_target: "authorizationType" } %>
      <%= hidden_field_tag :pos_transaction_id, nil, data: { pos_supervisor_auth_target: "transactionId" } %>
      <%= hidden_field_tag :pos_register_session_id, nil, data: { pos_supervisor_auth_target: "registerSessionId" } %>
      <div class="ss-field">
        <%= label_tag :manager_username, "Manager username" %>
        <%= text_field_tag :manager_username, nil, autocomplete: "username", data: { pos_supervisor_auth_target: "managerUsername" } %>
      </div>
      <div class="ss-field">
        <%= label_tag :manager_pin, "Manager PIN" %>
        <%= password_field_tag :manager_pin, nil, autocomplete: "current-password", data: { pos_supervisor_auth_target: "managerPin" } %>
      </div>
      <p class="ss-hint ss-hint--warning" data-pos-supervisor-auth-target="error" hidden></p>
      <div class="ss-form__actions">
        <%= submit_tag "Authorize", class: "ss-btn" %>
        <button type="button"
                class="ss-btn ss-btn-secondary"
                data-action="modal#close"
                data-modal-target-id-param="pos-supervisor-auth-modal">
          Cancel
        </button>
      </div>
    <% end %>
  </div>
<% end %>
