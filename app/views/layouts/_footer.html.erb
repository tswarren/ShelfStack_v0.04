<footer class="ss-footer">
  <div class="ss-footer__version">ShelfStack v0.04.12</div>
  <div class="ss-footer__copyright">© <%= Time.current.year %> ShelfStack</div>
  <div class="ss-footer__actions">
    <% if current_user_session&.active? %>
      <%= button_to "Lock Session", session_lock_path, method: :post, params: { return_to: request.fullpath }, class: "ss-btn ss-btn-ghost ss-btn-small", form: { class: "ss-inline-form ss-footer__lock-form" } %>
    <% end %>
  </div>
</footer>
