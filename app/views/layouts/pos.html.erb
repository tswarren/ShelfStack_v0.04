<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "POS — ShelfStack" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <%= tag.body(**shelfstack_body_attributes("ss-pos-body")) do %>
    <%= link_to "Skip to content", "#main_content", class: "ss-skip-link" %>
    <%= render "layouts/header" %>
    <%= render "layouts/nav" %>
    <main id="main_content" class="<%= shelfstack_class_names("ss-main", "ss-pos-main", content_for(:main_class)) %>">
      <% if flash[:notice] %><div class="flash flash-notice"><%= flash[:notice] %></div><% end %>
      <% if flash[:warning] %><div class="flash flash-warning"><%= flash[:warning] %></div><% end %>
      <% if flash[:alert] %><div class="flash flash-alert"><%= flash[:alert] %></div><% end %>
      <%= yield %>
    </main>
    <%= render "layouts/pos_supervisor_auth_modal" %>
    <%= render "layouts/footer" %>
    <%= render "shared/interaction/toast_region" %>
  <% end %>
</html>
