<section class="ss-stored-value-slip">
  <h1 class="ss-stored-value-slip__title"><%= presenter.document_title %></h1>

  <div class="ss-receipt-row">
    <span>Buyback</span>
    <strong><%= presenter.buyback_number %></strong>
  </div>

  <div class="ss-receipt-row">
    <span>Seller</span>
    <strong><%= presenter.seller_name %></strong>
  </div>

  <div class="ss-receipt-row">
    <span>Credit code</span>
    <strong><%= presenter.formatted_identifier %></strong>
  </div>

  <div class="ss-receipt-row ss-stored-value-slip__value-row">
    <span class="ss-stored-value-slip__value-label">Value</span>
    <strong class="ss-stored-value-slip__value-amount"><%= buyback_money(presenter.amount_cents) %></strong>
  </div>

  <div class="ss-receipt-row">
    <span>New balance</span>
    <strong><%= buyback_money(presenter.balance_after_cents) %></strong>
  </div>
</section>

<p class="ss-muted">Present this code at POS or select the trade credit account in Customers to redeem.</p>
