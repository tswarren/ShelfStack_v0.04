<%# locals: buyback_session, workflow %>
<section class="ss-panel" id="intake-panel" data-buyback-intake-target="panel">
  <h2>Intake</h2>
  <% if workflow.intake_queue_text.present? %>
    <p class="ss-muted ss-buyback-queue-summary"><%= workflow.intake_queue_text %></p>
  <% end %>
  <%= form_with url: buybacks_session_lines_path(buyback_session), class: "ss-form ss-form-inline", data: { buyback_intake_target: "form", action: "submit->buyback-intake#submit" } do %>
    <%= text_field_tag :identifier, nil, placeholder: "ISBN / identifier", autofocus: true, data: { buyback_intake_target: "identifier" } %>
    <%= text_field_tag :title, nil, placeholder: "Title (if no identifier)", data: { buyback_intake_target: "title" } %>
    <%= render "shared/ui/button", label: "Add line", type: :submit, variant: :primary, data: { buyback_intake_target: "submit" } %>
  <% end %>
  <p class="ss-hint">Press <kbd>/</kbd> to focus scan field. <kbd>N</kbd> jumps to the next item needing work.</p>
</section>
