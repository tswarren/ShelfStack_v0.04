<%# locals: lines, session, conditions, sub_departments, reject_reasons, workflow %>
<div class="ss-buyback-line-drawer__backdrop" data-buyback-line-drawer-target="backdrop" data-action="click->buyback-line-drawer#close" hidden></div>
<aside class="ss-buyback-line-drawer__panel" data-buyback-line-drawer-target="panel" hidden aria-label="Work item detail">
  <header class="ss-buyback-line-drawer__header">
    <h2 data-buyback-line-drawer-target="title">Work item</h2>
    <%= render "shared/ui/button", label: "Close", variant: :secondary, size: :small, type: :button, data: { action: "buyback-line-drawer#close" } %>
  </header>
  <div class="ss-buyback-line-drawer__body" data-buyback-line-drawer-target="body">
    <%= turbo_frame_tag "buyback-line-detail-frame", data: { buyback_line_drawer_target: "frame" } do %>
      <div id="buyback-line-detail-content">
        <p class="ss-muted">Select a work item to view details.</p>
      </div>
    <% end %>
  </div>
</aside>
