<h1>Buyback proposal</h1>
<p><strong><%= @buyback_session.buyback_number %></strong></p>
<p>Seller: <%= @buyback_session.customer.display_name %></p>
<p class="ss-muted">This proposal does not imply payout. Customer decisions and payout selection happen after review.</p>

<table class="ss-table">
  <thead>
    <tr>
      <th>#</th>
      <th>Item</th>
      <th>Condition</th>
      <th>Proposed sale</th>
      <th>Cash offer</th>
      <th>Trade credit</th>
    </tr>
  </thead>
  <tbody>
    <% @proposal.lines.each do |line| %>
      <tr>
        <td><%= line.line_number %></td>
        <td><%= line.title_snapshot %></td>
        <td><%= line.condition_snapshot || line.product_condition&.name %></td>
        <td><%= buyback_money(line.proposed_resale_price_cents) %></td>
        <td><%= buyback_money(line.proposed_cash_offer_cents) %></td>
        <td><%= buyback_money(line.proposed_trade_credit_offer_cents) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p>Cash total: <%= buyback_money(@proposal.totals[:cash_offer_cents]) %></p>
<p>Trade credit total: <%= buyback_money(@proposal.totals[:trade_credit_offer_cents]) %></p>

<p><%= link_to "Back to session", buybacks_session_path(@buyback_session) %></p>
