<%# locals: line, session, conditions, sub_departments, reject_reasons, workflow %>
<% if line.product.blank? || (session.editable? && !line.status.in?(%w[posted voided])) %>
  <%= render "shared/ui/button",
        label: "Work item",
        variant: :secondary,
        size: :small,
        type: :button,
        data: {
          action: "buyback-line-drawer#open",
          line_id: line.id,
          line_title: line.title_snapshot,
          detail_url: detail_buybacks_session_line_path(session, line)
        } %>
<% end %>
