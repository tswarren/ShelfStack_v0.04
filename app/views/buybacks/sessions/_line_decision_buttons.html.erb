<%# locals: line, session %>
<div class="ss-buyback-line-decisions">
  <% if line.outcome == "declined_by_customer" %>
    <p class="ss-muted">Declined</p>
    <%= render "shared/ui/button",
          label: "Mark donated",
          variant: :secondary,
          size: :small,
          url: record_decision_buybacks_session_line_path(session, line),
          method: :patch,
          params: { outcome: "donated_by_customer" },
          form: { data: { turbo_stream: true } } %>
  <% elsif line.status.in?(%w[offered decided]) && line.outcome.blank? %>
    <div class="ss-form-actions">
      <%= render "shared/ui/button",
            label: "Accept",
            variant: :primary,
            size: :small,
            url: record_decision_buybacks_session_line_path(session, line),
            method: :patch,
            params: { outcome: "accepted_by_customer" },
            form: { data: { turbo_stream: true } } %>
      <%= render "shared/ui/button",
            label: "Decline",
            variant: :secondary,
            size: :small,
            url: record_decision_buybacks_session_line_path(session, line),
            method: :patch,
            params: { outcome: "declined_by_customer" },
            form: { data: { turbo_stream: true } } %>
      <%= render "shared/ui/button",
            label: "Donate",
            variant: :secondary,
            size: :small,
            url: record_decision_buybacks_session_line_path(session, line),
            method: :patch,
            params: { outcome: "donated_by_customer" },
            form: { data: { turbo_stream: true } } %>
    </div>
  <% elsif line.outcome.present? %>
    <p class="ss-muted"><%= buyback_line_workflow_label(line) %></p>
  <% end %>
</div>
