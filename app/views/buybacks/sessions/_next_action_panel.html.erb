<%# locals: workflow, buyback_session %>
<section class="ss-panel ss-buyback-next-action" id="next-action-panel">
  <h2 class="ss-buyback-next-action__title"><%= workflow.next_action.label %></h2>
  <% action = workflow.next_action %>
  <% case action.kind %>
  <% when :anchor %>
    <%= link_to action.label, "##{action.anchor}", class: "ss-btn" %>
  <% when :disabled %>
    <button type="button" class="ss-btn ss-btn--disabled" disabled><%= action.label %></button>
    <% state = workflow.action_state(:save_proposal) %>
    <% if state.reason.present? %>
      <p class="ss-hint"><%= state.reason %></p>
    <% end %>
  <% when :info %>
    <p class="ss-muted"><%= action.label %></p>
  <% end %>
  <% if action.secondary_label.present? %>
    <% if buyback_session.quoted? && !buyback_session.decision? %>
      <%= link_to action.secondary_label, print_proposal_buybacks_session_path(buyback_session), class: "ss-btn ss-btn-secondary", target: "_blank" %>
    <% end %>
  <% end %>
  <% if workflow.repriced_lines_blocking_batch? %>
    <p class="ss-hint ss-hint-warning">Some lines changed since customer decision. Save proposal again before recording decisions.</p>
  <% end %>
</section>
