<%# locals: buyback_session, proposal, workflow %>
<% if buyback_session.quoted? || buyback_session.decision? %>
  <section class="ss-panel" id="buyback-proposal-panel">
    <h2>Proposal</h2>
    <div class="ss-buyback-proposal-card">
      <p class="ss-buyback-proposal-card__number"><strong><%= buyback_session.buyback_number %></strong></p>
      <% if proposal.present? %>
        <p>Items offered: <strong><%= proposal.offered_lines.size %></strong></p>
        <p>Cash value: <strong><%= buyback_money(proposal.totals[:cash_offer_cents]) %></strong></p>
        <p>Trade credit value: <strong><%= buyback_money(proposal.totals[:trade_credit_offer_cents]) %></strong></p>
      <% end %>
      <% if buyback_session.proposal_printed_at.present? %>
        <p class="ss-muted">Proposal printed at <%= l(buyback_session.proposal_printed_at, format: :short) %></p>
      <% end %>
      <% if workflow.proposal_revision_needed? %>
        <p class="ss-hint ss-hint-warning">Proposal revision needed. Reprice lines, save the revised proposal, then reprint.</p>
      <% elsif workflow.proposal_stale? %>
        <p class="ss-hint ss-hint-warning">Proposal changed since last print.</p>
      <% end %>
      <div class="ss-form-actions">
        <%= render "shared/ui/button", label: "Print proposal", variant: :secondary, url: print_proposal_buybacks_session_path(buyback_session), target: "_blank" %>
        <%= render "shared/ui/button", label: "Revise proposal", variant: :secondary, url: "#work-items-panel" %>
        <% if buyback_session.quoted? && !buyback_session.decision? %>
          <% open_state = workflow.action_state(:open_decision) %>
          <%= buyback_action_button(
                path: open_decision_buybacks_session_path(buyback_session),
                method: :patch,
                label: "Open customer decisions",
                enabled: open_state.enabled,
                reason: open_state.reason
              ) %>
        <% end %>
      </div>
    </div>
    <% if buyback_session.editable? && (buyback_session.draft? || workflow.proposal_revision_needed? || workflow.queue_summary.ready_for_proposal_count.positive?) %>
      <% save_state = workflow.action_state(:save_proposal) %>
      <%= buyback_action_button(
            path: save_proposal_buybacks_session_path(buyback_session),
            method: :patch,
            label: workflow.save_proposal_label,
            enabled: save_state.enabled,
            reason: save_state.reason
          ) %>
      <% if workflow.proposal_revision_needed? %>
        <p class="ss-hint">Save the revised proposal, reprint it, then reopen customer decisions if needed.</p>
      <% elsif !buyback_session.draft? %>
        <p class="ss-hint">Re-save the proposal after repricing lines before recording customer decisions.</p>
      <% end %>
    <% end %>
  </section>
<% elsif buyback_session.editable? && buyback_session.draft? %>
  <section class="ss-panel" id="buyback-proposal-panel">
    <h2>Proposal</h2>
    <p class="ss-muted">Save the proposal to assign a buyback number and prepare for customer review.</p>
    <% save_state = workflow.action_state(:save_proposal) %>
    <%= buyback_action_button(
          path: save_proposal_buybacks_session_path(buyback_session),
          method: :patch,
          label: workflow.save_proposal_label,
          enabled: save_state.enabled,
          reason: save_state.reason
        ) %>
  </section>
<% end %>
