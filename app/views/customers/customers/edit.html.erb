<%= render "shared/forms/page_header",
           eyebrow: "Customers",
           title: "Edit Customer",
           description: "Update contact details and notes." %>

<%= form_with model: @customer, url: customers_customer_path(@customer), class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, customer: @customer %>
  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Save Changes", type: :submit, variant: :primary %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: customers_customer_path(@customer) %>
  </footer>
<% end %>
