<%= render "customers/shared/workspace_nav", active: :customers %>

<%
  header_actions = safe_join([
    (render("shared/ui/button", label: "New demand", variant: :secondary, url: new_demand_demand_line_path) if Authorization.allowed?(user: current_user, permission_key: "demand.create", store: current_store)),
    (render("shared/ui/button", label: "New", variant: :primary, url: new_customers_customer_path) if Authorization.allowed?(user: current_user, permission_key: "customers.create", store: current_store))
  ].compact)
%>

<%= render "shared/ui/page_header",
           title: "Customers",
           description: "Search customer profiles for demand, holds, pickup, and stored value.",
           actions: header_actions.presence %>

<%= form_with url: customers_customers_path, method: :get, class: "ss-form" do %>
  <%= label_tag :q, "Search customers", class: "ss-sr-only" %>
  <%= text_field_tag :q, params[:q], placeholder: "Search by name" %>
  <%= render "shared/ui/button", label: "Search", type: :submit, variant: :secondary %>
<% end %>

<% if @customers.any? %>
  <table class="ss-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Preferred contact</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @customers.each do |customer| %>
        <tr>
          <td><%= customer.display_name %></td>
          <td><%= customer.email.presence || "—" %></td>
          <td><%= customer.phone.presence || "—" %></td>
          <td><%= customer.preferred_contact_method.present? ? customers_preferred_contact_label(customer.preferred_contact_method) : "—" %></td>
          <td><%= ss_status_badge(status_label(customer.active?), status: customer.active? ? :active : :inactive) %></td>
          <td><%= link_to "View", customers_customer_path(customer) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <% empty_actions = render("shared/ui/button", label: "New", variant: :primary, url: new_customers_customer_path) if Authorization.allowed?(user: current_user, permission_key: "customers.create", store: current_store) %>
  <%= render "shared/ui/empty_state",
             title: params[:q].present? ? "No customers found" : "No customers yet",
             message: params[:q].present? ? "No customers match your search. Try a different name." : "Create a customer profile to capture demand, holds, and pickup.",
             actions: empty_actions %>
<% end %>
