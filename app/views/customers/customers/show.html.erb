<%= render "setup/shared/back_link", path: customers_customers_path, label: "Customers" %>

<%
  lifecycle_actions = if @customer.active?
                        safe_join([
                          (render("shared/ui/button", label: "Inactivate", variant: :secondary, url: inactivate_customers_customer_path(@customer), method: :patch) if Authorization.allowed?(user: current_user, permission_key: "customers.inactivate", store: current_store)),
                          (render("shared/ui/button", label: "Edit", variant: :primary, url: edit_customers_customer_path(@customer)) if Authorization.allowed?(user: current_user, permission_key: "customers.update", store: current_store))
                        ].compact)
                      else
                        safe_join([
                          (render("shared/ui/button", label: "Edit", variant: :secondary, url: edit_customers_customer_path(@customer)) if Authorization.allowed?(user: current_user, permission_key: "customers.update", store: current_store)),
                          (render("shared/ui/button", label: "Reactivate", variant: :primary, url: reactivate_customers_customer_path(@customer), method: :patch) if Authorization.allowed?(user: current_user, permission_key: "customers.reactivate", store: current_store))
                        ].compact)
                      end
%>

<%= render "shared/ui/page_header", title: @customer.display_name, actions: lifecycle_actions.presence %>

<dl class="ss-summary">
  <dt>Email</dt><dd><%= @customer.email.presence || "—" %></dd>
  <dt>Phone</dt><dd><%= @customer.phone.presence || "—" %></dd>
  <dt>Preferred contact</dt>
  <dd><%= @customer.preferred_contact_method.present? ? customers_preferred_contact_label(@customer.preferred_contact_method) : "—" %></dd>
  <dt>Status</dt><dd><%= ss_status_badge(status_label(@customer.active?), status: @customer.active? ? :active : :inactive) %></dd>
  <% if @customer.notes.present? %>
    <dt>Notes</dt><dd><%= simple_format(@customer.notes) %></dd>
  <% end %>
</dl>

<% if @profile_presenter %>
  <section class="ss-section-actions ss-profile-actions">
    <% if @profile_presenter.can_create_demand? %>
      <%= render "shared/ui/button", label: "New demand", variant: :primary, url: @profile_presenter.new_demand_path %>
    <% elsif @profile_presenter.can_create_request? %>
      <%= render "shared/ui/button", label: "New request", variant: :primary, url: @profile_presenter.new_request_path %>
    <% end %>
    <% if @profile_presenter.can_view_requests? && @profile_presenter.ready_for_pickup_line_count.positive? %>
      <%= render "shared/ui/button",
                 label: "View ready pickups (#{@profile_presenter.ready_for_pickup_line_count})",
                 variant: :secondary,
                 url: @profile_presenter.ready_pickups_path %>
    <% end %>
    <% if @profile_presenter.can_view_requests? && @profile_presenter.active_hold_count.positive? %>
      <%= render "shared/ui/button",
                 label: "View active holds (#{@profile_presenter.active_hold_count})",
                 variant: :secondary,
                 url: @profile_presenter.active_holds_path %>
    <% end %>
    <% if @profile_presenter.can_record_contact? %>
      <details class="ss-collapsible-inline">
        <summary class="ss-btn ss-btn-secondary">Record contact</summary>
        <%= render "customers/customers/contact_form", customer: @customer %>
      </details>
    <% end %>
    <% if Authorization.allowed?(user: current_user, permission_key: "stored_value.accounts.view", store: current_store) %>
      <%= render "shared/ui/button",
                 label: "Stored value accounts",
                 variant: :secondary,
                 url: customers_stored_value_accounts_path(customer_id: @customer.id) %>
    <% end %>
  </section>
  <p class="ss-muted">
    <%= @profile_presenter.open_request_count %> open request<%= @profile_presenter.open_request_count == 1 ? "" : "s" %>
  </p>
<% end %>

<h2>Demand lines</h2>
<% if @demand_lines.any? %>
  <table class="ss-table">
    <thead>
      <tr>
        <th>Demand</th>
        <th>Intent</th>
        <th>Status</th>
        <th>Allocation</th>
        <th>Item</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @demand_lines.each do |line| %>
        <tr>
          <td><%= line.demand_number %></td>
          <td><%= demand_capture_intent_label(line.capture_intent) %></td>
          <td><%= demand_status_label(line.status) %></td>
          <td><%= demand_allocation_state_label(line) %></td>
          <td><%= demand_item_label(line) %></td>
          <td><%= display_time(line.created_at) %></td>
          <td>
            <% if Authorization.allowed?(user: current_user, permission_key: "demand.access", store: current_store) %>
              <%= link_to "View", demand_demand_line_path(line) %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No demand lines yet",
             message: "Demand lines for this customer will appear here after staff capture requests or holds." %>
<% end %>

<h2>Contact history</h2>
<% if @contact_events.any? %>
  <table class="ss-table">
    <thead>
      <tr>
        <th>When</th>
        <th>Method</th>
        <th>Status</th>
        <th>Summary</th>
      </tr>
    </thead>
    <tbody>
      <% @contact_events.each do |event| %>
        <tr>
          <td><%= display_time(event.occurred_at) %></td>
          <td><%= customers_preferred_contact_label(event.contact_method) %></td>
          <td><%= event.status.titleize %></td>
          <td><%= event.summary %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render "shared/ui/empty_state",
             title: "No contact events recorded",
             message: "Record a contact attempt from the profile actions above when you reach out to this customer." %>
<% end %>

<%= render "orders/shared/collapsible_panel", title: "Audit timeline" do %>
  <%= render "shared/audit_timeline", audit_events: @audit_events %>
<% end %>
