<%= render "customers/shared/workspace_nav", active: :stored_value_accounts %>

<%= render "shared/forms/page_header",
           eyebrow: "Customers",
           title: "Edit stored value account",
           description: stored_value_account_title(@account) %>

<%= form_with model: @account, url: customers_stored_value_account_path(@account), method: :patch, class: "ss-form ss-form--standard" do |f| %>
  <%= render "form", f: f, account: @account, stores: @stores, customers: @customers %>
  <footer class="ss-form-actions">
    <%= f.submit "Save changes", class: "ss-btn" %>
    <%= link_to "Cancel", customers_stored_value_account_path(@account), class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
