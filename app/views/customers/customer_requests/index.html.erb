<%= render "customers/shared/workspace_nav", active: :requests %>

<h1>Customer Requests
  <% if Authorization.allowed?(user: current_user, permission_key: "customer_requests.create", store: current_store) %>
    <%= link_to "New", new_customers_customer_request_path, class: "ss-btn" %>
  <% end %>
</h1>

<%= render "customers/shared/queue_nav" %>

<%= form_with url: customers_customer_requests_path, method: :get, class: "ss-form" do %>
  <%= hidden_field_tag :queue, params[:queue] if params[:queue].present? %>
  <%= text_field_tag :q, params[:q], placeholder: "Search request, customer, phone, ISBN, title, SKU…" %>
  <%= submit_tag "Search", class: "ss-btn ss-btn-secondary" %>
<% end %>

<table class="ss-table">
  <thead>
    <tr>
      <th>Request</th>
      <th>Customer</th>
      <th>Item</th>
      <th>Status</th>
      <th>Needed / age</th>
      <th>Next action</th>
      <th class="ss-num">Available</th>
      <th>Assigned</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @index_rows.each do |row| %>
      <tr>
        <td><%= link_to row.request_number, row.request_path %></td>
        <td>
          <%= row.customer_name %><br>
          <span class="ss-muted"><%= row.contact_line %></span>
        </td>
        <td><%= row.primary_item %></td>
        <td><%= render "customers/shared/status_badge", status: row.status %></td>
        <td><%= row.timing_label %></td>
        <td><%= link_to row.next_action.label, row.next_action.path %></td>
        <td class="ss-num"><%= row.available_qty.nil? ? "—" : row.available_qty %></td>
        <td><%= row.assigned_name.presence || "—" %></td>
        <td><%= link_to "View", row.request_path %></td>
      </tr>
    <% end %>
  </tbody>
</table>
