<%# locals: customer_request:, line:, active_reservations:, availability:, draft_po_lines:, vendors:, line_card: nil %>
<div class="ss-detail-actions">
  <% if line.request_type == "research" && line.matched? &&
        Authorization.allowed?(user: current_user, permission_key: "customer_requests.update", store: current_store) %>
    <% CustomerRequestLine::REQUEST_TYPES.reject { |t| t == "research" }.each do |request_type| %>
      <%= button_to request_type.tr("_", " ").titleize,
            update_line_type_customers_customer_request_path(customer_request, line_id: line.id, request_type: request_type),
            method: :patch,
            class: "ss-btn ss-btn-small ss-btn-secondary" %>
    <% end %>
  <% end %>

  <% if line.matched? && line.request_type == "notify" &&
        Authorization.allowed?(user: current_user, permission_key: "customer_requests.update", store: current_store) %>
    <%= button_to "Awaiting response",
          mark_awaiting_response_customers_customer_request_path(customer_request, line_id: line.id),
          method: :post,
          class: "ss-btn ss-btn-small ss-btn-secondary" %>
    <% if availability.present? && availability[:available].to_i.positive? %>
      <span class="ss-muted"><%= availability[:available] %> available</span>
    <% end %>
  <% end %>

  <% if line.matched? && line.request_type == "special_order" && line.special_order.blank? &&
        customer_request.customer.present? &&
        Authorization.allowed?(user: current_user, permission_key: "special_orders.create", store: current_store) %>
    <%= button_to "Special order",
          create_special_order_customers_customer_request_path(customer_request, line_id: line.id),
          method: :post,
          class: "ss-btn ss-btn-small" %>
  <% elsif line.special_order.present? && line.special_order.status == "approved" %>
    <% if Authorization.allowed?(user: current_user, permission_key: "special_orders.attach_to_po", store: current_store) %>
      <%= render "attach_special_order_panel",
            customer_request: customer_request,
            line: line,
            special_order: line.special_order,
            draft_po_lines: draft_po_lines,
            vendors: vendors %>
    <% end %>
  <% end %>

  <% if line_card&.can_create_hold? &&
        Authorization.allowed?(user: current_user, permission_key: "inventory_reservations.create", store: current_store) %>
    <%= render "hold_form",
          customer_request: customer_request,
          line: line,
          availability: availability %>
  <% end %>

  <%= render "reservation_list",
        customer_request: customer_request,
        line: line,
        reservations: active_reservations %>
</div>
