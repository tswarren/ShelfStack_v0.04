<%# locals: customer_request:, request_types:, sources:, submit_label:, selected_customer: nil %>
<% selected_customer ||= customer_request.customer %>
<%= form_with model: customer_request,
              url: (customer_request.persisted? ? customers_customer_request_path(customer_request) : customers_customer_requests_path),
              class: "ss-form ss-form--standard" do |f| %>
  <%= render "shared/forms/errors", record: customer_request %>

  <div data-controller="customer-lookup"
       data-customer-lookup-url-value="<%= customers_customer_lookup_path %>"
       <% if selected_customer.present? %>
         data-customer-lookup-initial-customer-id-value="<%= selected_customer.id %>"
         data-customer-lookup-initial-label-value="<%= selected_customer.display_name %>"
         data-customer-lookup-initial-email-value="<%= selected_customer.email %>"
         data-customer-lookup-initial-phone-value="<%= selected_customer.phone %>"
       <% end %>>
    <%= render layout: "shared/forms/section", locals: {
      title: "Customer",
      description: "Search for an existing customer or capture a walk-in snapshot below."
    } do %>
      <%= render "customers/shared/customer_lookup_field", f: f, customer: selected_customer %>

      <div data-customer-lookup-target="walkInFields"<%= " hidden" if selected_customer.present? %>>
        <div class="ss-form-grid ss-form-grid--2">
          <%= render layout: "shared/forms/field", locals: { f: f, record: customer_request, field: :source } do %>
            <%= f.select :source, sources.map { |s| [s.tr("_", " ").titleize, s] } %>
          <% end %>
          <%= render layout: "shared/forms/field", locals: { f: f, record: customer_request, field: :customer_name_snapshot, label: "Walk-in name" } do %>
            <%= f.text_field :customer_name_snapshot %>
          <% end %>
          <%= render layout: "shared/forms/field", locals: { f: f, record: customer_request, field: :preferred_contact_method, label: "Preferred contact" } do %>
            <%= f.select :preferred_contact_method,
                  CustomerRequest::PREFERRED_CONTACT_METHODS.map { |m| [customers_preferred_contact_label(m), m] },
                  include_blank: true %>
          <% end %>
          <%= render layout: "shared/forms/field", locals: { f: f, record: customer_request, field: :customer_email_snapshot, label: "Walk-in email" } do %>
            <%= f.email_field :customer_email_snapshot %>
          <% end %>
          <%= render layout: "shared/forms/field", locals: { f: f, record: customer_request, field: :customer_phone_snapshot, label: "Walk-in phone" } do %>
            <%= f.text_field :customer_phone_snapshot %>
          <% end %>
          <%= render layout: "shared/forms/field", locals: { f: f, record: customer_request, field: :needed_by_date, label: "Needed by" } do %>
            <%= f.date_field :needed_by_date %>
          <% end %>
        </div>
      </div>

      <%= render layout: "shared/forms/field", locals: { f: f, record: customer_request, field: :notes } do %>
        <%= f.text_area :notes, rows: 3 %>
      <% end %>
    <% end %>
  </div>

  <%= render "shared/forms/nested_lines",
        f: f,
        association: :customer_request_lines,
        line_object: CustomerRequestLine.new(request_type: "research", requested_quantity: 1, status: "new"),
        line_partial: "customers/customer_requests/line_fields",
        store: customers_store,
        line_locals: { request_types: request_types },
        hint: customer_request.persisted? ?
          "Add provisional lines or update quantities and notes. Match variants from the request show page." :
          "Capture the first request line. Add more lines after the request is created." %>

  <footer class="ss-form-actions">
    <%= f.submit submit_label, class: "ss-btn" %>
    <%= link_to "Cancel",
          (customer_request.persisted? ? customers_customer_request_path(customer_request) : customers_customer_requests_path),
          class: "ss-btn ss-btn-secondary" %>
  </footer>
<% end %>
