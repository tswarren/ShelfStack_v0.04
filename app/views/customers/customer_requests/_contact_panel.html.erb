<%# locals: customer_request:, contact_events:, show_presenter:, open: false %>
<div class="ss-sidebar-card" id="contact-panel">
  <h2>Customer contact</h2>

  <% if show_presenter.contact_relevant_line_cards.any? %>
    <p class="ss-muted">
      <% show_presenter.contact_relevant_line_cards.each do |line_card| %>
        Line <%= line_card.line.line_number %>: <%= line_card.next_action.label %><br>
      <% end %>
    </p>
  <% end %>

  <% if customer_request.customer_phone_snapshot.present? || customer_request.customer_email_snapshot.present? %>
    <p class="ss-muted">
      <%= [ customer_request.customer_phone_snapshot, customer_request.customer_email_snapshot ].compact.join(" · ") %>
    </p>
  <% end %>

  <% if Authorization.allowed?(user: current_user, permission_key: "customer_requests.contact", store: current_store) %>
    <%= form_with url: record_contact_customers_customer_request_path(customer_request),
                  method: :post,
                  class: "ss-form ss-form--standard" do %>
      <div class="ss-form-grid ss-form-grid--2">
        <div class="ss-field">
          <%= label_tag :contact_method, "Contact method", class: "ss-label" %>
          <%= select_tag :contact_method,
                options_for_select(
                  CustomerContactEvent::CONTACT_METHODS.map { |method| [customers_preferred_contact_label(method), method] },
                  customer_request.preferred_contact_method
                ),
                class: "ss-input" %>
        </div>
        <div class="ss-field">
          <%= label_tag :status, "Outcome", class: "ss-label" %>
          <%= select_tag :status,
                options_for_select(CustomerContactEvent::STATUSES.map { |status| [status.titleize, status] }),
                class: "ss-input" %>
        </div>
      </div>
      <% if show_presenter.contact_line_options.many? %>
        <div class="ss-field">
          <%= label_tag :line_id, "Related line", class: "ss-label" %>
          <%= select_tag :line_id,
                options_for_select(show_presenter.contact_line_options),
                include_blank: "Whole request",
                class: "ss-input" %>
        </div>
      <% elsif show_presenter.contact_line_options.one? %>
        <%= hidden_field_tag :line_id, show_presenter.contact_line_options.first.last %>
      <% end %>
      <div class="ss-field">
        <%= label_tag :summary, "Summary", class: "ss-label" %>
        <%= text_area_tag :summary, nil, required: true, rows: 3, class: "ss-input", placeholder: "What was discussed or attempted?" %>
      </div>
      <%= submit_tag "Record contact", class: "ss-btn" %>
    <% end %>
  <% end %>

  <% if contact_events.any? %>
    <h3 class="ss-line-card__subtitle">Recent contact</h3>
    <ul class="ss-document-trail">
      <% contact_events.first(5).each do |event| %>
        <li>
          <strong><%= display_time(event.occurred_at) %></strong>
          · <%= customers_preferred_contact_label(event.contact_method) %>
          · <%= event.status.titleize %><br>
          <span class="ss-muted"><%= event.summary %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="ss-muted">No contact events yet.</p>
  <% end %>
</div>
