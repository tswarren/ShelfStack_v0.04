<%# locals: action:, line_card: %>
<div class="ss-next-action-strip">
  <div>
    <span class="ss-next-action-strip__label">Next action</span>
    <strong><%= action.label %></strong>
    <% if line_card.contact_relevant? %>
      <span class="ss-muted">· Customer contact may be needed</span>
    <% end %>
  </div>
  <%= link_to "Go to workflow", action.path, class: "ss-btn ss-btn-small" %>
</div>
