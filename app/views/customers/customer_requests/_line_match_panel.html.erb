<%# locals: customer_request:, line:, search_query: nil %>
<%= render "orders/shared/collapsible_panel", title: "Match variant", open: true do %>
  <%= form_with url: match_variant_customers_customer_request_path(customer_request),
                method: :post,
                class: "ss-form",
                data: {
                  controller: "inventory-variant-lookup",
                  inventory_variant_lookup_url_value: customers_variant_lookup_path,
                  inventory_variant_lookup_require_eligible_value: false
                } do %>
    <%= hidden_field_tag :line_id, line.id %>
    <div class="ss-field">
      <%= label_tag :product_variant_lookup, "SKU / barcode", class: "ss-label" %>
      <%= text_field_tag :product_variant_lookup, search_query,
            class: "ss-input",
            placeholder: "Scan or enter SKU, ISBN, UPC…",
            autocomplete: "off",
            data: {
              inventory_variant_lookup_target: "lookupInput",
              action: "keydown->inventory-variant-lookup#lookupExact input->inventory-variant-lookup#search"
            } %>
      <%= hidden_field_tag :product_variant_id, nil, data: { inventory_variant_lookup_target: "variantId" } %>
      <p class="ss-hint" data-inventory-variant-lookup-target="preview"></p>
      <p class="ss-hint" data-inventory-variant-lookup-target="message"></p>
      <div class="ss-pos-choices" data-inventory-variant-lookup-target="choices"></div>
    </div>
    <div class="ss-detail-actions">
      <%= submit_tag "Match to line", class: "ss-btn ss-btn-small" %>
      <%= link_to "Search items",
            items_root_path(customers_request_match_link_params(
              customer_request: customer_request,
              line: line,
              query: search_query || line.provisional_identifier.presence || line.provisional_title
            )),
            class: "ss-btn ss-btn-small ss-btn-secondary" %>
      <% if Authorization.allowed?(user: current_user, permission_key: "items.access", store: current_store) %>
        <%= link_to "Look up ISBN / Add Item",
              items_add_item_path(customers_request_match_link_params(customer_request: customer_request, line: line)),
              class: "ss-btn ss-btn-small ss-btn-secondary" %>
      <% end %>
    </div>
  <% end %>
<% end %>
