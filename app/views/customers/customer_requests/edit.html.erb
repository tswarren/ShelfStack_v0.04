<%= render "setup/shared/back_link", path: customers_customer_request_path(@customer_request), label: @customer_request.request_number %>

<%= render "shared/forms/page_header",
           eyebrow: "Customers",
           title: "Edit Customer Request",
           description: "Update customer details and request lines." %>

<%= render "form",
      customer_request: @customer_request,
      selected_customer: @selected_customer,
      request_types: @request_types,
      sources: @sources,
      submit_label: "Save Changes" %>
