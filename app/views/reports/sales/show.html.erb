<div class="ss-report report-print">
  <%= render "reports/shared/header",
             title: "Sales List",
             scope: "Recent completed transactions",
             actions: report_standard_actions(export_url: reports_sales_path(format: :csv)) %>

  <div class="ss-report-body">
    <% if @transactions.any? %>
      <table class="ss-table ss-table--report">
        <thead>
          <tr>
            <th>Transaction</th>
            <th>Completed</th>
            <th>Type</th>
            <th class="ss-num ss-money">Subtotal</th>
            <th class="ss-num ss-money">Tax</th>
            <th class="ss-num ss-money">Total</th>
            <th>Cashier</th>
          </tr>
        </thead>
        <tbody>
          <% @transactions.each do |transaction| %>
            <tr>
              <td><%= transaction.transaction_number %></td>
              <td><%= format_report_date(transaction.completed_at, basis: "completed_at") %></td>
              <td><%= transaction.transaction_type %></td>
              <td class="ss-num ss-money"><%= format_report_money(transaction.subtotal_cents) %></td>
              <td class="ss-num ss-money"><%= format_report_money(transaction.tax_cents) %></td>
              <td class="ss-num ss-money"><%= format_report_money(transaction.total_cents) %></td>
              <td><%= transaction.cashier_user.username %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <%= render "reports/shared/empty_state", title: "No sales found", message: "Completed sale transactions will appear here." %>
    <% end %>
  </div>
</div>
