<div class="ss-report report-print">
  <%= render "reports/shared/header",
             title: @presenter.title,
             scope: @presenter.scope_label,
             actions: report_print_button %>

  <%= render layout: "reports/shared/filter_bar", locals: { url: reports_shells_reconciliation_path } do %>
    <%= render "reports/shared/date_range",
               start_value: params[:start_date] || Date.current.beginning_of_month,
               end_value: params[:end_date] || Date.current %>
  <% end %>

  <%= render "reports/shared/section_notice",
             message: "Sample reconciliation shell with placeholder data for Phase 9a layout proof." %>

  <%= render "reports/shared/metric_strip",
             metrics: @presenter.metrics.map { |metric|
               if metric[:value_cents]
                 metric.merge(value: format_report_money(metric[:value_cents]))
               else
                 metric
               end
             } %>

  <div class="ss-report-body">
    <table class="ss-table ss-table--report ss-table--compact">
      <thead>
        <tr>
          <th>Tax category / rate</th>
          <th class="ss-num ss-money">Tax collected</th>
        </tr>
      </thead>
      <tbody>
        <% @presenter.rows.each do |row| %>
          <tr class="<%= { subtotal: 'ss-table-row--subtotal', total: 'ss-table-row--total' }[row.row_type] %>">
            <th scope="row"><%= row.label %></th>
            <td class="ss-num ss-money"><%= format_report_money(row.amount_cents) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
