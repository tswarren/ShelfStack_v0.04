<div class="ss-report report-print">
  <%= render "reports/shared/header",
             title: "Sales & Revenue Summary",
             scope: @report&.scope&.label,
             actions: report_standard_actions(export_url: (@report ? reports_sales_summary_path(request.query_parameters.merge(format: :csv)) : nil)) %>

  <%= render "reports/shared/pos_scope_filter", url: reports_sales_summary_path, sessions: @sessions %>

  <% if @scope.blank? && params.except(:controller, :action).present? %>
    <%= render "reports/shared/section_notice", message: "Choose a valid filter and run the report." %>
  <% elsif @report %>
    <div class="ss-report-body">
      <div class="ss-pos-report__grid">
        <%= render "pos/reports/revenue_summary", summary: @report.revenue_summary %>
        <%= render "pos/reports/clerk_breakdown", rows: @report.by_clerk, totals: @report.revenue_summary %>
      </div>

      <div class="ss-pos-report__grid">
        <%= render "pos/reports/payments_by_type", rows: @report.by_tender %>
        <%= render "pos/reports/hourly_breakdown", rows: @report.by_hour %>
      </div>

      <% if @report.drawer.available %>
        <%= render "pos/reports/drawer_reconciliation", drawer: @report.drawer %>
      <% elsif !@scope.register_session? %>
        <%= render "reports/shared/section_notice", message: "Drawer reconciliation is available when filtering by register session." %>
      <% end %>
    </div>
  <% end %>
</div>
