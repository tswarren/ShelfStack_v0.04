<div class="ss-report report-print">
  <%= render "reports/shared/header",
             title: "Stored Value Liability",
             scope: report_store.name,
             actions: report_standard_actions %>

  <%= render layout: "reports/shared/filter_bar", locals: { url: reports_stored_value_path } do %>
    <%= render "reports/shared/date_range", start_value: params[:start_date], end_value: params[:end_date] %>
  <% end %>

  <%= render "reports/shared/metric_strip", metrics: [
    { label: "Total liability", value: format_report_money(@report.total_liability_cents) }
  ] %>

  <div class="ss-report-body">
    <h2>Outstanding balances</h2>
    <% if @report.balance_rows.any? %>
      <table class="ss-table ss-table--report">
        <thead>
          <tr>
            <th>Account type</th>
            <th>Issuing store</th>
            <th class="ss-num">Accounts</th>
            <th class="ss-num ss-money">Balance</th>
          </tr>
        </thead>
        <tbody>
          <% @report.balance_rows.each do |row| %>
            <tr>
              <td><%= stored_value_account_type_label(row.account_type) %></td>
              <td><%= row.issuing_store_name %></td>
              <td class="ss-num"><%= format_report_quantity(row.account_count) %></td>
              <td class="ss-num ss-money"><%= format_report_money(row.total_balance_cents) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <%= render "reports/shared/empty_state", title: "No outstanding liability", message: "No active stored value balances with positive amounts." %>
    <% end %>

    <h2>Activity summary</h2>
    <% if @report.activity_rows.any? %>
      <table class="ss-table ss-table--report">
        <thead>
          <tr><th>Entry type</th><th class="ss-num">Count</th><th class="ss-num ss-money">Total delta</th></tr>
        </thead>
        <tbody>
          <% @report.activity_rows.each do |row| %>
            <tr>
              <td><%= row.entry_type.humanize %></td>
              <td class="ss-num"><%= format_report_quantity(row.entry_count) %></td>
              <td class="ss-num ss-money"><%= format_report_money(row.total_amount_cents, signed: true) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <%= render "reports/shared/empty_state", title: "No activity", message: "Widen the date range or clear filters to see ledger activity." %>
    <% end %>
  </div>
</div>
