<%# locals: title:, scope: nil, actions: nil %>
<header class="ss-page-header ss-report-header">
  <div>
    <h1><%= title %></h1>
    <% if local_assigns.fetch(:scope, nil).present? %>
      <p class="ss-page-description ss-report-scope"><%= scope %></p>
    <% end %>
  </div>
  <% if local_assigns.fetch(:actions, nil).present? %>
    <div class="ss-page-actions ss-report-actions"><%= actions %></div>
  <% end %>
</header>
