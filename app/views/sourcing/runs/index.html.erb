<h1>Sourcing</h1>

<%= form_with url: sourcing_root_path, method: :get, class: "ss-filter-bar ss-form" do %>
  <%= select_tag :status,
        options_for_select(
          [["All statuses", ""]] + SourcingRun::STATUSES.map { |s| [sourcing_run_status_label(s), s] },
          params[:status]
        ),
        class: "ss-input" %>
  <%= select_tag :capture_intent,
        options_for_select(
          [["All intents", ""]] + DemandLine::CAPTURE_INTENTS.map { |i| [demand_capture_intent_label(i), i] },
          params[:capture_intent]
        ),
        class: "ss-input" %>
  <%= select_tag :queue,
        options_for_select(
          [["All runs", ""], ["Needs review", "needs_review"]],
          params[:queue]
        ),
        class: "ss-input" %>
  <%= submit_tag "Filter", class: "ss-btn ss-btn-secondary" %>
<% end %>

<% if @sourcing_runs.any? %>
  <table class="ss-table">
    <thead>
      <tr>
        <th>Run</th>
        <th>Demand</th>
        <th>Intent</th>
        <th>Item</th>
        <th>Status</th>
        <th>Qty</th>
        <th>Started</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @sourcing_runs.each do |run| %>
        <tr>
          <td>#<%= run.id %></td>
          <td><%= link_to run.demand_line.demand_number, demand_demand_line_path(run.demand_line) %></td>
          <td><%= sourcing_demand_intent_label(run.demand_line) %></td>
          <td><%= demand_item_label(run.demand_line) %></td>
          <td><span class="<%= sourcing_run_status_class(run.status) %>"><%= sourcing_run_status_label(run.status) %></span></td>
          <td class="ss-num"><%= run.quantity_requested %></td>
          <td><%= display_time(run.started_at) %></td>
          <td><%= link_to "View", sourcing_run_path(run) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="ss-muted">No sourcing runs match the current filters.</p>
<% end %>
