<%= render "shared/ui/page_header",
           title: "Inventory Adjustments",
           actions: render("shared/ui/button", label: "New", variant: :primary, url: new_inventory_adjustment_path) %>

<table class="ss-table">
  <thead><tr><th>ID</th><th>Type</th><th>Status</th><th>Posted</th><th></th></tr></thead>
  <tbody>
    <% @adjustments.each do |adjustment| %>
      <tr>
        <td><%= adjustment.id %></td>
        <td><%= adjustment.adjustment_type %></td>
        <td><%= adjustment.status %></td>
        <td><%= adjustment.posted_at ? display_time(adjustment.posted_at) : "—" %></td>
        <td><%= link_to "View", inventory_adjustment_path(adjustment) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
