<% if @total_pages > 1 %>
  <nav class="ss-pagination" aria-label="Inventory pagination">
    <% if @page > 1 %>
      <%= render "shared/ui/button",
            label: "Previous",
            variant: :secondary,
            url: inventory_root_path(request.query_parameters.merge("page" => @page - 1)) %>
    <% end %>
    <span class="ss-pagination__summary">Page <%= @page %> of <%= @total_pages %> (<%= @total_count %> balances)</span>
    <% if @page < @total_pages %>
      <%= render "shared/ui/button",
            label: "Next",
            variant: :secondary,
            url: inventory_root_path(request.query_parameters.merge("page" => @page + 1)) %>
    <% end %>
  </nav>
<% elsif @total_count.positive? %>
  <p class="ss-pagination__summary"><%= @total_count %> <%= "balance".pluralize(@total_count) %></p>
<% end %>
