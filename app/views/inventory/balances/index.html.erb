<%
  header_actions = safe_join([
    render("shared/ui/button", label: "Adjustments", variant: :secondary, url: inventory_adjustments_path),
    render("shared/ui/button", label: "Negative On Hand", variant: :secondary, url: inventory_negative_path),
    (Authorization.allowed?(user: current_user, permission_key: "inventory.enterprise.view", store: current_store) ?
      render("shared/ui/button", label: "Enterprise Rollup", variant: :secondary, url: inventory_enterprise_path) : nil),
    (Authorization.allowed?(user: current_user, permission_key: "inventory.admin.rebuild_balances", store: current_store) ?
      render("shared/ui/button", label: "Admin Tools", variant: :secondary, url: inventory_admin_path) : nil),
    render("shared/ui/button", label: "New Opening Inventory", variant: :secondary, url: new_inventory_adjustment_path(adjustment_type: "opening_inventory")),
    render("shared/ui/button", label: "New Adjustment", variant: :primary, url: new_inventory_adjustment_path)
  ].compact)
%>

<%= render "shared/ui/page_header",
           title: "Store Inventory",
           description: "Store: #{inventory_store.name}",
           actions: header_actions %>

<%= form_with url: inventory_root_path, method: :get, class: "ss-form-inline" do %>
  <%= text_field_tag :q, params[:q], placeholder: "Search SKU or name" %>
  <%= hidden_field_tag :stock, params[:stock] if params[:stock].present? %>
  <%= render "shared/ui/button", label: "Search", type: :submit, variant: :secondary %>
<% end %>

<nav class="ss-filter-bar" aria-label="Stock filters">
  <%= link_to "All stock", inventory_root_path(q: params[:q]), class: @stock_filter.blank? ? "ss-filter-chip ss-filter-chip--active" : "ss-filter-chip" %>
  <%= link_to "Zero stock", inventory_root_path(q: params[:q], stock: "zero"), class: @stock_filter == "zero" ? "ss-filter-chip ss-filter-chip--active" : "ss-filter-chip" %>
  <%= link_to "Low stock", inventory_root_path(q: params[:q], stock: "low"), class: @stock_filter == "low" ? "ss-filter-chip ss-filter-chip--active" : "ss-filter-chip" %>
</nav>

<p class="ss-muted">
  On hand: <%= @totals[:quantity_on_hand] %> |
  Retail value: <%= format_cents(@totals[:inventory_retail_value_cents]) %> |
  Cost value: <%= format_cents(@totals[:inventory_cost_value_cents]) %>
</p>

<table class="ss-table">
  <thead>
    <tr>
      <th>SKU</th>
      <th>Variant</th>
      <th class="ss-num">On Hand</th>
      <th class="ss-num">Available</th>
      <th class="ss-num">On Order</th>
      <th class="ss-num">Pending</th>
      <th class="ss-num">Retail Value</th>
      <th class="ss-num">Cost Value</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @balances.each do |balance| %>
      <% order_qty = @order_quantities[balance.product_variant_id] %>
      <tr>
        <td><%= balance.product_variant.sku %></td>
        <td><%= balance.product_variant.name %></td>
        <td class="ss-num"><%= balance.quantity_on_hand %></td>
        <td class="ss-num"><%= balance.quantity_available %></td>
        <td class="ss-num"><%= order_qty&.on_order || 0 %></td>
        <td class="ss-num"><%= order_qty&.pending || 0 %></td>
        <td class="ss-num"><%= format_cents(balance.inventory_retail_value_cents) %></td>
        <td class="ss-num"><%= format_cents(balance.inventory_cost_value_cents) %></td>
        <td>
          <%= link_to "Ledger", inventory_variant_path(balance.product_variant) %>
          <% if Authorization.allowed?(user: current_user, permission_key: "inventory.adjustments.create", store: current_store) %>
            | <%= link_to "Adjust", new_inventory_adjustment_path(product_variant_id: balance.product_variant_id) %>
          <% end %>
          <% if Authorization.allowed?(user: current_user, permission_key: "demand.create", store: current_store) %>
            | <%= link_to "Manual TBO", new_demand_demand_line_path(product_variant_id: balance.product_variant_id, capture_intent: "manual_tbo") %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= render "pagination" %>
