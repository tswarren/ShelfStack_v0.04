<h1>Inventory Admin Tools</h1>
<p class="ss-muted">Store: <%= inventory_store.name %></p>

<div class="ss-actions">
  <%= link_to "New Balance Correction", new_inventory_adjustment_path(adjustment_type: "balance_correction"), class: "ss-btn" %>
  <%= button_to "Rebuild Balances", rebuild_balances_inventory_admin_path, method: :post, class: "ss-btn", data: { turbo_confirm: "Rebuild all inventory balances from the ledger?" } %>
  <%= button_to "Run Integrity Check", integrity_check_inventory_admin_path, method: :post, class: "ss-btn" %>
  <%= link_to "Back to Inventory", inventory_root_path, class: "ss-btn ss-btn-secondary" %>
</div>

<% if @integrity_result %>
  <section class="ss-summary-block">
    <h2>Integrity Check Result</h2>
    <% if @integrity_result["passed"] %>
      <p class="ss-success">Integrity check passed.</p>
    <% else %>
      <p class="ss-errors">Integrity check failed: <%= @integrity_result["mismatch_count"] %> mismatch(es).</p>
      <% if @integrity_result["mismatches"].any? %>
        <table class="ss-table">
          <thead>
            <tr>
              <th>Store</th>
              <th>Variant</th>
              <th class="ss-num">Cached</th>
              <th class="ss-num">Ledger</th>
            </tr>
          </thead>
          <tbody>
            <% @integrity_result["mismatches"].each do |row| %>
              <tr>
                <td><%= row["store_id"] %></td>
                <td><%= row["product_variant_id"] %></td>
                <td class="ss-num"><%= row["cached_on_hand"] %></td>
                <td class="ss-num"><%= row["ledger_on_hand"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </section>
<% end %>
