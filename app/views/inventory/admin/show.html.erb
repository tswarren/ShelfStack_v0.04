<%
  header_actions = safe_join([
    render("shared/ui/button", label: "New Balance Correction", variant: :secondary, url: new_inventory_adjustment_path(adjustment_type: "balance_correction")),
    render("shared/ui/button", label: "Rebuild Balances", variant: :secondary, url: rebuild_balances_inventory_admin_path, method: :post, data: { turbo_confirm: "Rebuild all inventory balances from the ledger?" }),
    render("shared/ui/button", label: "Run Integrity Check", variant: :secondary, url: integrity_check_inventory_admin_path, method: :post),
    render("shared/ui/button", label: "Back to Inventory", variant: :tertiary, url: inventory_root_path)
  ])
%>

<%= render "shared/ui/page_header",
           title: "Inventory Admin Tools",
           description: "Store: #{inventory_store.name}",
           actions: header_actions %>

<% if @integrity_result %>
  <section class="ss-summary-block">
    <h2>Integrity Check Result</h2>
    <% if @integrity_result["passed"] %>
      <p class="ss-success">Integrity check passed.</p>
    <% else %>
      <p class="ss-errors">Integrity check failed: <%= @integrity_result["mismatch_count"] %> mismatch(es).</p>
      <% if @integrity_result["mismatches"].any? %>
        <table class="ss-table">
          <thead>
            <tr>
              <th>Store</th>
              <th>Variant</th>
              <th class="ss-num">Cached</th>
              <th class="ss-num">Ledger</th>
            </tr>
          </thead>
          <tbody>
            <% @integrity_result["mismatches"].each do |row| %>
              <tr>
                <td><%= row["store_id"] %></td>
                <td><%= row["product_variant_id"] %></td>
                <td class="ss-num"><%= row["cached_on_hand"] %></td>
                <td class="ss-num"><%= row["ledger_on_hand"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </section>
<% end %>
