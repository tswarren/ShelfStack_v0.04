<% presenter = @show_presenter %>

<%= render "orders/shared/document_header",
      title: presenter.title,
      status: presenter.status,
      metadata_lines: presenter.metadata_lines do %>
  <% unless %w[cancelled closed].include?(@purchase_request.status) %>
    <%= link_to "Edit", edit_orders_purchase_request_path(@purchase_request), class: "ss-btn" %>
    <% if @buildable && Authorization.allowed?(user: current_user, permission_key: "orders.purchase_orders.create", store: current_store) %>
      <%= link_to "Build Purchase Order", build_purchase_order_orders_purchase_request_path(@purchase_request), class: "ss-btn" %>
    <% end %>
    <%= button_to "Cancel", cancel_orders_purchase_request_path(@purchase_request), method: :patch, class: "ss-btn" %>
  <% end %>
  <%= link_to "Back", orders_purchase_requests_path %>
<% end %>

<%= render "orders/shared/metric_strip", metrics: presenter.metrics %>
<%= render "orders/shared/attention_panel", items: presenter.attention_items %>

<%= render layout: "orders/shared/document_layout" do %>
  <h2>Lines</h2>
  <table class="ss-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Item</th>
        <th class="ss-num">Qty</th>
        <th>Reason</th>
        <th>Status</th>
        <th>PO</th>
      </tr>
    </thead>
    <tbody>
      <% @document_hub.lines.each do |row| %>
        <% line = row.purchase_request_line %>
        <tr>
          <td><%= line.line_number %></td>
          <td>
            <%= render "orders/shared/variant_identity", variant: line.product_variant %>
          </td>
          <td class="ss-num"><%= line.requested_quantity %></td>
          <td><%= line.request_reason || "—" %></td>
          <td><%= render "orders/shared/status_badge", status: line.status %></td>
          <td>
            <% if row.purchase_order.present? %>
              <%= link_to "PO ##{row.purchase_order.id} line #{row.purchase_order_line.line_number}",
                    orders_purchase_order_path(row.purchase_order) %>
            <% else %>
              —
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% content_for :document_sidebar do %>
    <%= render "orders/shared/document_trail", nodes: presenter.trail_nodes %>
    <%= render "orders/shared/sidebar_facts", facts: presenter.sidebar_facts %>
  <% end %>
<% end %>

<% if presenter.show_related_detail? %>
  <%= render "orders/shared/collapsible_panel", title: "Related documents (detail)" do %>
    <%= render "orders/shared/related_records_panel",
          title: "Related Purchase Orders",
          records: @document_hub.purchase_orders,
          headers: [
            { label: "PO" },
            { label: "Status" },
            { label: "Lines", class: "ss-num" },
            { label: "" }
          ] do %>
      <% @document_hub.purchase_orders.each do |entry| %>
        <tr>
          <td>Purchase Order #<%= entry.purchase_order.id %></td>
          <td><%= entry.purchase_order.status %></td>
          <td class="ss-num"><%= entry.line_count %></td>
          <td><%= link_to "View", orders_purchase_order_path(entry.purchase_order) %></td>
        </tr>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<%= render "orders/shared/collapsible_panel", title: "Audit timeline" do %>
  <%= render "shared/audit_timeline", audit_events: @audit_events %>
<% end %>
