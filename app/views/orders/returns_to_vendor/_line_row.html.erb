<% primary_columns = 6 %>
<tr data-purchasing-line-table-target="line"
    data-controller="purchasing-line-row"
    data-purchasing-line-row-url-value="<%= orders_line_lookup_path %>"
    data-purchasing-line-row-context-value="<%= lookup_context %>"
    data-purchasing-line-row-vendor-field-id-value="<%= vendor_field_id %>"
    data-purchasing-line-row-quantity-field-value="<%= quantity_field %>"
    data-purchasing-line-row-require-eligible-value="true"
    data-purchasing-line-row-refresh-on-vendor-change-value="true"
    data-blank-row="<%= blank_row ? "true" : "false" %>"
    <% if variant %>
    data-purchasing-line-row-initial-sku-value="<%= variant.sku %>"
    data-purchasing-line-row-initial-variant-id-value="<%= variant.id %>"
    data-purchasing-line-row-initial-on-hand-value="<%= balance&.quantity_on_hand || 0 %>"
    <% if local_assigns[:vendor].present? %>
    data-purchasing-line-row-initial-returnability-value="<%= Purchasing::ReturnabilityResolver.resolve(variant: variant, vendor: local_assigns[:vendor]) %>"
    <% end %>
    <% end %>>
  <%= line_form.hidden_field :id if line_form.object.persisted? %>
  <%= line_form.hidden_field :_destroy, value: false, data: { purchasing_line_table_target: "destroy" } %>

  <%= render "orders/shared/scan_lookup_cell", line_form: line_form, variant: variant %>
  <td>
    <% if variant %>
      <%= render "orders/shared/variant_identity", variant: variant %>
    <% else %>
      <span data-purchasing-line-row-target="title"></span>
    <% end %>
  </td>
  <td class="ss-num">
    <%= line_form.number_field :quantity, min: 1, step: 1, class: "ss-input ss-purchasing-table__qty",
          data: {
            purchasing_line_row_target: "quantityOrdered",
            action: "keydown->purchasing-line-row#quantityKeydown input->purchasing-line-row#quantityChanged"
          } %>
  </td>
  <td class="ss-num">
    <%= line_form.number_field :credit_amount_cents, min: 0, step: 1, class: "ss-input ss-purchasing-table__money",
          data: { purchasing_line_row_target: "creditAmount", action: "input->purchasing-line-row#creditAmountChanged" } %>
  </td>
  <td class="ss-purchasing-table__warnings" data-purchasing-line-row-target="warnings"></td>
  <%= render "orders/shared/line_remove_cell" %>
</tr>
<tr class="ss-purchasing-table__details" hidden data-purchasing-line-row-details>
  <td colspan="<%= primary_columns %>">
    <dl class="ss-purchasing-table__details-grid">
      <div>
        <dt>On hand</dt>
        <dd class="ss-num" data-purchasing-line-row-target="onHand"><%= balance&.quantity_on_hand || 0 %></dd>
      </div>
      <div>
        <dt>Returnability</dt>
        <dd data-purchasing-line-row-target="returnability">
          <% if variant && local_assigns[:vendor].present? %>
            <%= Purchasing::ReturnabilityResolver.resolve(variant: variant, vendor: local_assigns[:vendor]).humanize %>
          <% else %>
            —
          <% end %>
        </dd>
      </div>
      <div>
        <dt>Unit cost</dt>
        <dd class="ss-num">
          <%= line_form.number_field :unit_cost_cents, min: 0, step: 1, class: "ss-input ss-purchasing-table__money",
                data: { purchasing_line_row_target: "unitCost", action: "input->purchasing-line-row#creditDriverChanged" } %>
        </dd>
      </div>
    </dl>
  </td>
</tr>
