<h1>Return to Vendor #<%= @return_to_vendor.id %></h1>
<p>Vendor: <%= @return_to_vendor.vendor.name %> | Status: <%= @return_to_vendor.status %></p>
<% if @return_to_vendor.notes.present? %><p><%= @return_to_vendor.notes %></p><% end %>

<table class="ss-table">
  <thead>
    <tr>
      <th>#</th>
      <th>Item</th>
      <th class="ss-num">Qty</th>
      <th class="ss-num">Unit Cost</th>
      <th class="ss-num">Credit</th>
    </tr>
  </thead>
  <tbody>
    <% @return_to_vendor.return_to_vendor_lines.each do |line| %>
      <tr>
        <td><%= line.line_number %></td>
        <td><%= render "orders/shared/variant_identity", variant: line.product_variant %></td>
        <td class="ss-num"><%= line.quantity %></td>
        <td class="ss-num"><%= line.unit_cost_cents ? format_cents(line.unit_cost_cents) : "—" %></td>
        <td class="ss-num"><%= line.credit_amount_cents ? format_cents(line.credit_amount_cents) : "—" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="ss-actions">
  <% if @return_to_vendor.draft? %>
    <%= link_to "Edit", edit_orders_returns_to_vendor_path(@return_to_vendor), class: "ss-btn" %>
    <%= button_to "Post", post_orders_returns_to_vendor_path(@return_to_vendor), method: :patch, class: "ss-btn" %>
    <%= button_to "Cancel", cancel_orders_returns_to_vendor_path(@return_to_vendor), method: :patch, class: "ss-btn" %>
  <% end %>
  <%= link_to "Back", orders_returns_to_vendor_index_path %>
</div>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
