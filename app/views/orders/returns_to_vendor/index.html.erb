<% new_rtv_action = render("shared/ui/button", label: "New", variant: :primary, url: new_orders_returns_to_vendor_path) %>

<%= render "shared/ui/page_header", title: "Returns to Vendor", actions: new_rtv_action %>

<table class="ss-table">
  <thead><tr><th>ID</th><th>Vendor</th><th>Status</th><th>Posted</th><th></th></tr></thead>
  <tbody>
    <% @returns_to_vendor.each do |return_to_vendor| %>
      <tr>
        <td><%= return_to_vendor.id %></td>
        <td><%= return_to_vendor.vendor.name %></td>
        <td><%= return_to_vendor.status %></td>
        <td><%= return_to_vendor.posted_at ? display_time(return_to_vendor.posted_at) : "—" %></td>
        <td><%= link_to "View", orders_returns_to_vendor_path(return_to_vendor) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
