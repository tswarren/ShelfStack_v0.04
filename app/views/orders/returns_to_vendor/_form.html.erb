<h1><%= return_to_vendor.persisted? ? "Edit" : "New" %> Return to Vendor</h1>

<%= form_with model: return_to_vendor, url: (return_to_vendor.persisted? ? orders_return_to_vendor_path(return_to_vendor) : orders_returns_to_vendor_path) do |f| %>
  <% if return_to_vendor.errors.any? %>
    <div class="ss-errors"><%= return_to_vendor.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="ss-field">
    <%= f.label :vendor_id, "Vendor" %>
    <%= f.collection_select :vendor_id, @vendors, :id, :name, include_blank: true %>
  </div>

  <div class="ss-field">
    <%= f.label :notes %>
    <%= f.text_area :notes %>
  </div>

  <%= render "shared/forms/nested_lines",
        f: f,
        association: :return_to_vendor_lines,
        line_object: ReturnToVendorLine.new,
        line_partial: "orders/returns_to_vendor/line_fields",
        store: orders_store %>

  <%= f.submit class: "ss-btn" %>
<% end %>
