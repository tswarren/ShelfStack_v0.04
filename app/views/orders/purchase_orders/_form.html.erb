<h1><%= purchase_order.persisted? ? "Edit" : "New" %> Purchase Order</h1>

<%= form_with model: purchase_order, url: (purchase_order.persisted? ? orders_purchase_order_path(purchase_order) : orders_purchase_orders_path) do |f| %>
  <% if purchase_order.errors.any? %>
    <div class="ss-errors"><%= purchase_order.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="ss-field">
    <%= f.label :vendor_id, "Vendor" %>
    <%= f.collection_select :vendor_id, @vendors, :id, :name, include_blank: true %>
  </div>

  <div class="ss-field">
    <%= f.label :notes %>
    <%= f.text_area :notes %>
  </div>

  <%= render "shared/forms/nested_lines",
        f: f,
        association: :purchase_order_lines,
        line_object: PurchaseOrderLine.new,
        line_partial: "orders/purchase_orders/line_fields",
        store: orders_store %>

  <%= f.submit class: "ss-btn" %>
<% end %>
