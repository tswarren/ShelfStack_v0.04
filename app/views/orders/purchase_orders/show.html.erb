<h1>Purchase Order #<%= @purchase_order.id %></h1>
<p>Vendor: <%= @purchase_order.vendor.name %> | Status: <%= @purchase_order.status %></p>
<% if @purchase_order.notes.present? %><p><%= @purchase_order.notes %></p><% end %>

<div class="ss-detail-actions">
  <% if @purchase_order.draft? %>
    <%= link_to "Edit", edit_orders_purchase_order_path(@purchase_order), class: "ss-btn" %>
    <%= button_to "Submit", submit_orders_purchase_order_path(@purchase_order), method: :patch, class: "ss-btn" %>
    <%= button_to "Cancel", cancel_orders_purchase_order_path(@purchase_order), method: :patch, class: "ss-btn" %>
  <% elsif @purchase_order.status == "submitted" %>
    <%= button_to "Cancel", cancel_orders_purchase_order_path(@purchase_order), method: :patch, class: "ss-btn" %>
  <% end %>
  <% if @receivable && Authorization.allowed?(user: current_user, permission_key: "orders.receipts.create", store: current_store) %>
    <%= button_to "Receive", receive_orders_purchase_order_path(@purchase_order), method: :post, class: "ss-btn" %>
  <% end %>
  <% if @closable %>
    <%= button_to "Close", close_orders_purchase_order_path(@purchase_order), method: :patch, class: "ss-btn",
          data: { turbo_confirm: "Close this purchase order? Open lines will be marked closed or closed short." } %>
  <% end %>
  <%= link_to "Back", orders_purchase_orders_path %>
</div>

<%= render "sourcing_warnings", sourcing_warnings: @sourcing_warnings %>

<h2>Order Summary</h2>
<dl class="ss-summary">
  <dt>Total units</dt><dd class="ss-num"><%= @order_summary.total_units %></dd>
  <dt>Total cost</dt><dd class="ss-num"><%= format_cents(@order_summary.total_cost_cents) %></dd>
  <dt>Total retail</dt><dd class="ss-num"><%= format_cents(@order_summary.total_retail_cents) %></dd>
  <dt>Net discount</dt>
  <dd class="ss-num">
    <%= format_cents(@order_summary.net_discount_cents) %>
    <% if @order_summary.net_discount_bps %>
      (<%= format_basis_points(@order_summary.net_discount_bps) %>)
    <% end %>
  </dd>
</dl>

<%= render "orders/shared/receive_progress_panel", progress: @document_hub.receive_progress %>

<% if @document_hub.purchase_requests.any? %>
  <div class="ss-summary">
    <h2>Related Purchase Requests</h2>
    <table class="ss-table">
      <thead>
        <tr>
          <th>Request</th>
          <th>Status</th>
          <th class="ss-num">Lines</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @document_hub.purchase_requests.each do |entry| %>
          <tr>
            <td>Purchase Request #<%= entry.purchase_request.id %></td>
            <td><%= entry.purchase_request.status %></td>
            <td class="ss-num"><%= entry.line_count %></td>
            <td><%= link_to "View", orders_purchase_request_path(entry.purchase_request) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<% if @document_hub.receipts.any? %>
  <div class="ss-summary">
    <h2>Related Receipts</h2>
    <table class="ss-table">
      <thead>
        <tr>
          <th>Receipt</th>
          <th>Status</th>
          <th>Type</th>
          <th class="ss-num">Lines</th>
          <th class="ss-num">Accepted</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @document_hub.receipts.each do |entry| %>
          <tr>
            <td>Receipt #<%= entry.receipt.id %></td>
            <td><%= entry.receipt.status %></td>
            <td><%= entry.receipt.receipt_type %></td>
            <td class="ss-num"><%= entry.line_count %></td>
            <td class="ss-num"><%= entry.accepted_quantity %></td>
            <td><%= link_to "View", orders_receipt_path(entry.receipt) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%= render "orders/shared/discrepancies_panel", discrepancies: @document_hub.discrepancies %>
<%= render "orders/shared/line_activity_panel", line_activity: @document_hub.line_activity %>

<h2>Lines</h2>
<table class="ss-table">
  <thead>
    <tr>
      <th>#</th>
      <th>Item</th>
      <th>Vendor item #</th>
      <th class="ss-num">Ordered</th>
      <th class="ss-num">Received</th>
      <th class="ss-num">Open</th>
      <th class="ss-num">Unit Cost</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @purchase_order.purchase_order_lines.each do |line| %>
      <tr>
        <td><%= line.line_number %></td>
        <td>
          <%= render "orders/shared/variant_identity",
                variant: line.product_variant,
                sku_snapshot: line.variant_sku_snapshot,
                name_snapshot: line.variant_name_snapshot %>
        </td>
        <td><%= line.vendor_item_number_snapshot || "—" %></td>
        <td class="ss-num"><%= line.quantity_ordered %></td>
        <td class="ss-num"><%= line.quantity_received %></td>
        <td class="ss-num"><%= @purchase_order.open_quantity_for_line(line) %></td>
        <td class="ss-num"><%= line.unit_cost_cents ? format_cents(line.unit_cost_cents) : "—" %></td>
        <td><%= line.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Audit Timeline</h2>
<%= render "shared/audit_timeline", audit_events: @audit_events %>
