<%
  header_actions = safe_join([
    render("shared/ui/button", label: "Manual TBO", variant: :secondary, url: orders_orders_purchase_requests_path),
    render("shared/ui/button", label: "New", variant: :primary, url: new_orders_purchase_order_path)
  ])
%>

<%= render "shared/ui/page_header", title: "Purchase Orders", actions: header_actions %>

<table class="ss-table">
  <thead><tr><th>ID</th><th>Vendor</th><th>Status</th><th>Submitted</th><th></th></tr></thead>
  <tbody>
    <% @purchase_orders.each do |purchase_order| %>
      <tr>
        <td><%= purchase_order.id %></td>
        <td><%= purchase_order.vendor.name %></td>
        <td><%= purchase_order.status %></td>
        <td><%= purchase_order.submitted_at ? display_time(purchase_order.submitted_at) : "—" %></td>
        <td><%= link_to "View", orders_purchase_order_path(purchase_order) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
