<ul class="ss-detail-list">
  <% breakdown.allocation_rows.each do |row| %>
    <li>
      <%= row.quantity_open %> open / <%= row.quantity_allocated %> allocated for
      <%= row.customer_name %>
      <% if row.demand_number.present? && row.demand_line_id.present? %>
        · <%= link_to "Demand #{row.demand_number}", demand_demand_line_path(row.demand_line_id) %>
      <% end %>
      · <%= demand_allocation_kind_label(row.allocation_kind) %>
      · <%= row.status.humanize %>
    </li>
  <% end %>
  <% if breakdown.internal_tbo_quantity.positive? %>
    <li><%= breakdown.internal_tbo_quantity %> for store replenishment</li>
  <% end %>
</ul>
