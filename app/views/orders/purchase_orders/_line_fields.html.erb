<fieldset
  class="ss-adjustment-line"
  data-nested-form-lines-target="line"
  data-controller="inventory-variant-lookup"
  data-inventory-variant-lookup-url-value="<%= orders_variant_lookup_path(eligible_only: false) %>"
  data-inventory-variant-lookup-require-eligible-value="false"
  data-inventory-variant-lookup-form-vendor-select-id-value="<%= vendor_field_id %>"
  <% if variant %>
    data-inventory-variant-lookup-initial-sku-value="<%= variant.sku %>"
    data-inventory-variant-lookup-initial-variant-id-value="<%= variant.id %>"
    data-inventory-variant-lookup-initial-label-value="<%= variant.name %>"
    data-inventory-variant-lookup-initial-on-hand-value="<%= balance&.quantity_on_hand || 0 %>"
  <% end %>
>
  <%= line_form.hidden_field :id if line_form.object.persisted? %>
  <%= line_form.hidden_field :_destroy, value: false, data: { nested_form_lines_target: "destroy" } %>

  <%= render "shared/forms/variant_lookup_field", line_form: line_form, variant: variant %>

  <div class="ss-field">
    <%= line_form.label :quantity_ordered %>
    <%= line_form.number_field :quantity_ordered, min: 1, step: 1 %>
  </div>
  <div class="ss-field">
    <%= line_form.label :unit_list_price_cents, "List price (cents)" %>
    <%= line_form.number_field :unit_list_price_cents, min: 0, step: 1,
          data: { inventory_variant_lookup_target: "listPrice" } %>
    <p class="ss-hint">Defaults from product list price when blank.</p>
  </div>
  <div class="ss-field">
    <%= line_form.label :supplier_discount_bps, "Discount (bps)" %>
    <%= line_form.number_field :supplier_discount_bps, min: 0, max: 10_000, step: 1,
          data: { inventory_variant_lookup_target: "discountBps" } %>
  </div>
  <div class="ss-field">
    <%= line_form.label :unit_cost_cents, "Unit cost (cents)" %>
    <%= line_form.number_field :unit_cost_cents, min: 0, step: 1,
          data: { inventory_variant_lookup_target: "unitCost" } %>
  </div>
  <button type="button" class="ss-btn ss-btn-secondary" data-action="nested-form-lines#removeLine">Remove line</button>
</fieldset>
