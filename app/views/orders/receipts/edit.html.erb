<%= render "form", receipt: @receipt, allocation_preview: @allocation_preview %>

<% if @receipt.draft? && !(@receipt.po_backed? && @receipt.purchase_order_id.present?) %>
  <%= render "orders/receipts/line_match_workpad",
        receipt: @receipt,
        receipt_line_matches: @receipt_line_matches,
        match_candidates_by_line: @match_candidates_by_line %>
<% end %>
