<fieldset
  class="ss-adjustment-line"
  data-nested-form-lines-target="line"
  data-controller="inventory-variant-lookup"
  data-inventory-variant-lookup-url-value="<%= orders_variant_lookup_path %>"
  data-inventory-variant-lookup-require-eligible-value="true"
  <% if variant %>
    data-inventory-variant-lookup-initial-sku-value="<%= variant.sku %>"
    data-inventory-variant-lookup-initial-variant-id-value="<%= variant.id %>"
    data-inventory-variant-lookup-initial-label-value="<%= variant.name %>"
    data-inventory-variant-lookup-initial-on-hand-value="<%= balance&.quantity_on_hand || 0 %>"
  <% end %>
>
  <%= line_form.hidden_field :id if line_form.object.persisted? %>
  <%= line_form.hidden_field :_destroy, value: false, data: { nested_form_lines_target: "destroy" } %>

  <%= render "shared/forms/variant_lookup_field", line_form: line_form, variant: variant %>

  <div class="ss-field">
    <%= line_form.label :quantity_expected %>
    <%= line_form.number_field :quantity_expected, min: 0, step: 1 %>
  </div>
  <div class="ss-field">
    <%= line_form.label :quantity_received %>
    <%= line_form.number_field :quantity_received, min: 0, step: 1 %>
  </div>
  <div class="ss-field">
    <%= line_form.label :quantity_accepted %>
    <%= line_form.number_field :quantity_accepted, min: 0, step: 1 %>
    <p class="ss-hint">Accepted quantity posts to inventory. Defaults to received when rejected is zero.</p>
  </div>
  <div class="ss-field">
    <%= line_form.label :quantity_rejected %>
    <%= line_form.number_field :quantity_rejected, min: 0, step: 1 %>
  </div>
  <div class="ss-field">
    <%= line_form.label :unit_cost_cents, "Unit cost (cents)" %>
    <%= line_form.number_field :unit_cost_cents, min: 0, step: 1 %>
  </div>
  <button type="button" class="ss-btn ss-btn-secondary" data-action="nested-form-lines#removeLine">Remove line</button>
</fieldset>
