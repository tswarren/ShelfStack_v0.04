<%
  header_actions = safe_join([
    render("shared/ui/button", label: "Vendor shipment", variant: :secondary, url: new_orders_receipt_path(receiving_mode: "vendor_shipment")),
    render("shared/ui/button", label: "New", variant: :primary, url: new_orders_receipt_path)
  ])
%>

<%= render "shared/ui/page_header", title: "Receipts", actions: header_actions %>

<table class="ss-table">
  <thead><tr><th>ID</th><th>Vendor</th><th>Type</th><th>Status</th><th>Posted</th><th></th></tr></thead>
  <tbody>
    <% @receipts.each do |receipt| %>
      <tr>
        <td><%= receipt.id %></td>
        <td><%= receipt.vendor.name %></td>
        <td><%= receipt.receipt_type %></td>
        <td><%= receipt.status %></td>
        <td><%= receipt.posted_at ? display_time(receipt.posted_at) : "—" %></td>
        <td><%= link_to "View", orders_receipt_path(receipt) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
