<% primary_columns = 8 %>
<tr data-purchasing-line-table-target="line"
    data-controller="purchasing-line-row"
    data-purchasing-line-row-url-value="<%= orders_line_lookup_path %>"
    data-purchasing-line-row-context-value="<%= lookup_context %>"
    data-purchasing-line-row-vendor-field-id-value="<%= vendor_field_id %>"
    data-purchasing-line-row-purchase-order-field-id-value="<%= purchase_order_field_id %>"
    data-purchasing-line-row-quantity-field-value="<%= quantity_field %>"
    data-purchasing-line-row-require-eligible-value="true"
    data-blank-row="<%= blank_row ? "true" : "false" %>"
    <% if line_form.object.purchase_order_line_id.present? %>data-merge-allowed="false"<% end %>
    <% if variant %>
    data-purchasing-line-row-initial-sku-value="<%= variant.sku %>"
    data-purchasing-line-row-initial-variant-id-value="<%= variant.id %>"
    <% end %>
    <% customer_reserved = Purchasing::ReceiptLineDemand.customer_reserved_open(line_form.object.purchase_order_line) %>
    <% if customer_reserved.positive? %>
    data-purchasing-line-row-initial-customer-reserved-value="<%= customer_reserved %>"
    <% end %>>
  <%= line_form.hidden_field :id if line_form.object.persisted? %>
  <%= line_form.hidden_field :_destroy, value: false, data: { purchasing_line_table_target: "destroy" } %>
  <%= line_form.hidden_field :purchase_order_line_id, data: { purchasing_line_row_target: "purchaseOrderLineId" } %>
  <%= line_form.hidden_field :quantity_accepted, data: { purchasing_line_row_target: "quantityAccepted" } %>

  <%= render "orders/shared/scan_lookup_cell", line_form: line_form, variant: variant %>
  <td data-purchasing-line-row-target="title"><%= variant&.name %></td>
  <td class="ss-num">
    <%= line_form.number_field :quantity_received, min: 0, step: 1, class: "ss-input ss-purchasing-table__qty",
          data: {
            purchasing_line_row_target: "quantityReceived",
            action: "keydown->purchasing-line-row#quantityKeydown input->purchasing-line-row#quantityChanged"
          } %>
  </td>
  <td class="ss-num" data-purchasing-line-row-target="acceptingDisplay"><%= line_form.object.quantity_accepted %></td>
  <td class="ss-purchasing-table__exception">
    <% has_exception = line_form.object.quantity_rejected.to_i.positive? %>
    <%= render "shared/ui/button",
          label: (has_exception ? "Edit exception" : "Add exception"),
          type: :button,
          variant: :link,
          data: { purchasing_line_row_target: "exceptionToggle", action: "purchasing-line-row#toggleException" } %>
    <div data-purchasing-line-row-target="exceptionPanel"
         class="ss-purchasing-table__exception-panel"
         <%= "hidden" unless has_exception %>>
      <%= line_form.number_field :quantity_rejected, min: 0, step: 1, class: "ss-input ss-purchasing-table__qty",
            data: {
              purchasing_line_row_target: "quantityRejected",
              action: "input->purchasing-line-row#exceptionChanged"
            } %>
      <%= line_form.select :exception_reason,
            options_for_select(
              ReceiptLine::EXCEPTION_REASONS.map { |reason| [ reason.humanize, reason ] },
              line_form.object.exception_reason
            ),
            { include_blank: "Reason…" },
            class: "ss-input",
            data: { purchasing_line_row_target: "exceptionReason", action: "change->purchasing-line-row#exceptionChanged" } %>
      <%= render "shared/ui/button",
            label: "Remove",
            type: :button,
            variant: :link,
            data: { action: "purchasing-line-row#clearException" } %>
    </div>
  </td>
  <td class="ss-num">
    <%= line_form.number_field :unit_cost_cents, min: 0, step: 1, class: "ss-input ss-purchasing-table__money",
          data: { purchasing_line_row_target: "unitCost", action: "input->purchasing-line-row#quantityChanged" } %>
  </td>
  <td class="ss-purchasing-table__warnings" data-purchasing-line-row-target="warnings"></td>
  <%= render "orders/shared/line_remove_cell" %>
</tr>
<tr class="ss-purchasing-table__details" hidden data-purchasing-line-row-details>
  <td colspan="<%= primary_columns %>">
    <dl class="ss-purchasing-table__details-grid">
      <div>
        <dt>Expected</dt>
        <dd class="ss-num">
          <% if local_assigns.fetch(:po_locked, false) %>
            <%= line_form.object.quantity_expected %>
            <%= line_form.hidden_field :quantity_expected, data: { purchasing_line_row_target: "quantityExpected" } %>
          <% else %>
            <%= line_form.number_field :quantity_expected, min: 0, step: 1, class: "ss-input ss-purchasing-table__qty",
                  data: { purchasing_line_row_target: "quantityExpected", action: "input->purchasing-line-row#quantityChanged" } %>
          <% end %>
        </dd>
      </div>
      <% if customer_reserved.to_i.positive? %>
        <div class="ss-notice ss-notice--info">
          <%= customer_reserved %> <%= "copy".pluralize(customer_reserved) %> reserved for customers on this PO line.
        </div>
      <% end %>
    </dl>
  </td>
</tr>
