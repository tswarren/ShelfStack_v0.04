<%# locals: metrics %>
<% if metrics.present? %>
  <div class="ss-metric-strip">
    <% metrics.each do |metric| %>
      <div class="ss-metric-card">
        <span class="ss-metric-card__label"><%= metric[:label] %></span>
        <span class="ss-metric-card__value ss-num<%= " #{metric[:class]}" if metric[:class].present? %>"><%= metric[:value] %></span>
      </div>
    <% end %>
  </div>
<% end %>
