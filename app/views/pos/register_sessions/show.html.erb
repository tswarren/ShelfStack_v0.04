<h1>Register Session</h1>

<dl class="ss-pos-stats">
  <div><dt>Business date</dt><dd><%= @register_session.business_date %></dd></div>
  <div><dt>Status</dt><dd><%= @register_session.status %></dd></div>
  <div><dt>Completed transactions</dt><dd><%= @summary.completed_transaction_count %></dd></div>
  <div><dt>Suspended on workstation</dt><dd><%= @summary.suspended_transaction_count %></dd></div>
</dl>

<section class="ss-pos-panel">
  <h2>Session activity</h2>
  <h3>Cash movements</h3>
  <table class="ss-table ss-pos-table">
    <thead>
      <tr><th>Type</th><th>Amount</th><th>Reason</th><th>Recorded</th></tr>
    </thead>
    <tbody>
      <% @cash_movements.each do |movement| %>
        <tr>
          <td><%= movement.movement_type.humanize %></td>
          <td><%= pos_money(movement.amount_cents) %></td>
          <td><%= movement.reason_code %></td>
          <td><%= movement.recorded_at %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h3>Completed transactions</h3>
  <table class="ss-table ss-pos-table">
    <thead>
      <tr><th>Number</th><th>Type</th><th>Total</th><th>Completed</th></tr>
    </thead>
    <tbody>
      <% @completed_transactions.each do |transaction| %>
        <tr>
          <td><%= link_to transaction.transaction_number, pos_transaction_path(transaction) %></td>
          <td><%= transaction.transaction_type %></td>
          <td><%= pos_money(transaction.total_cents) %></td>
          <td><%= transaction.completed_at %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<section class="ss-pos-panel" id="cash-movement">
  <h2>Cash movement</h2>
  <%= form_with url: pos_register_session_cash_movements_path(@register_session), class: "ss-form" do %>
    <%= select_tag :movement_type, options_for_select([["Paid in", "paid_in"], ["Paid out", "paid_out"]]) %>
    <%= pos_money_field :amount_dollars, nil, min: 0.01, placeholder: "Amount" %>
    <%= text_field_tag :reason_code, nil, placeholder: "Reason" %>
    <%= submit_tag "Record", class: "ss-btn" %>
  <% end %>
</section>

<% if @register_session.open? %>
  <section class="ss-pos-panel ss-pos-close-panel" id="close-register"
           data-controller="pos-register-close pos-transaction-edit"
           data-pos-register-close-expected-cents-value="<%= @summary.expected_closing_cash_cents %>"
           data-action="pos:authorization-granted@document->pos-transaction-edit#setAuthorizationId">
    <h2>Close register</h2>

    <table class="ss-table ss-pos-reconciliation-table">
      <tbody>
        <tr><th scope="row">Opening cash</th><td class="ss-pos-money-col"><%= pos_money(@summary.opening_cash_cents) %></td></tr>
        <tr><th scope="row">Cash sales</th><td class="ss-pos-money-col"><%= pos_money(@summary.cash_sales_cents) %></td></tr>
        <tr><th scope="row">Cash refunds</th><td class="ss-pos-money-col"><%= pos_money(@summary.cash_refunds_cents) %></td></tr>
        <tr><th scope="row">Paid in</th><td class="ss-pos-money-col"><%= pos_money(@summary.paid_in_cents) %></td></tr>
        <tr><th scope="row">Paid out</th><td class="ss-pos-money-col">−<%= pos_money(@summary.paid_out_cents) %></td></tr>
        <tr class="ss-pos-reconciliation-table__total"><th scope="row">Expected drawer</th><td class="ss-pos-money-col"><strong><%= pos_money(@summary.expected_closing_cash_cents) %></strong></td></tr>
      </tbody>
    </table>

    <%= form_with url: close_pos_register_session_path(@register_session), method: :patch, class: "ss-form ss-pos-close-form" do %>
      <%= hidden_field_tag :expected_closing_cash_dollars, format("%.2f", @summary.expected_closing_cash_cents / 100.0) %>
      <div class="ss-field">
        <%= label_tag :counted_closing_cash_dollars, "Counted cash" %>
        <%= pos_money_field :counted_closing_cash_dollars, nil, required: true, data: { pos_register_close_target: "countedField", action: "input->pos-register-close#updateVariance change->pos-register-close#updateVariance" } %>
      </div>
      <p class="ss-pos-variance">Variance: <span data-pos-register-close-target="varianceDisplay"><%= pos_money(0) %></span></p>
      <%= submit_tag "Close register", class: "ss-btn" %>
    <% end %>

    <details class="ss-pos-advanced-actions">
      <summary>Advanced / Manager actions</summary>
      <div class="ss-pos-advanced-actions__panel">
        <p class="ss-hint">Force close requires manager approval and should only be used when normal close is blocked.</p>
        <%= form_with url: force_close_pos_register_session_path(@register_session), method: :patch, class: "ss-form" do %>
          <%= hidden_field_tag :pos_authorization_id, nil, data: { pos_transaction_edit_target: "authorizationId" } %>
          <%= hidden_field_tag :expected_closing_cash_dollars, format("%.2f", @summary.expected_closing_cash_cents / 100.0) %>
          <%= pos_money_field :counted_closing_cash_dollars, nil %>
          <button type="button" class="ss-btn ss-btn-secondary" data-action="pos-transaction-edit#requestAuth" data-authorization-type="force_close_register" data-register-session-id="<%= @register_session.id %>" data-authorization-message="Force close requires manager approval.">
            Authorize force close
          </button>
          <%= submit_tag "Force close register", class: "ss-btn ss-btn--danger", data: { turbo_confirm: "Force close this register session?" } %>
        <% end %>
      </div>
    </details>
  </section>
<% else %>
  <% if @register_session.expected_closing_cash_cents && @register_session.counted_closing_cash_cents %>
    <p>Variance: <%= pos_money(@register_session.counted_closing_cash_cents - @register_session.expected_closing_cash_cents) %></p>
  <% end %>
<% end %>
