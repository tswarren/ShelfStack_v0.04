<% register_session = local_assigns[:register_session] || @register_session || @transaction&.pos_register_session %>
<% summary = register_session && Pos::RegisterSessionSummary.for(register_session) %>
<% suspended_transactions = local_assigns.fetch(:suspended_transactions, @suspended_transactions || []) %>

<%= render "shared/interaction/drawer",
      id: "pos-session-drawer",
      title: "Register session",
      close_on_escape: true,
      close_on_backdrop: true,
      dirty_guard: false do %>
  <section id="pos-session-drawer-summary" class="ss-drawer-section">
    <h3 class="ss-drawer-section-title">Session summary</h3>
    <% if register_session.blank? %>
      <p class="ss-hint">No register session is open.</p>
    <% else %>
      <dl class="ss-pos-stats">
        <div><dt>Business date</dt><dd><%= register_session.business_date %></dd></div>
        <div><dt>Status</dt><dd><%= register_session.status %></dd></div>
        <div><dt>Session opened</dt><dd><%= pos_store_local_time(register_session.opened_at) %></dd></div>
        <div><dt>Opened by</dt><dd><%= register_session.opened_by_user.username %></dd></div>
        <% if summary %>
          <div><dt>Completed transactions</dt><dd><%= summary.completed_transaction_count %></dd></div>
          <div><dt>Held on workstation</dt><dd><%= summary.suspended_transaction_count %></dd></div>
          <div><dt>Expected drawer</dt><dd><%= pos_money(summary.expected_closing_cash_cents) %></dd></div>
        <% end %>
      </dl>
      <div class="ss-pos-session-summary__links">
        <%= link_to "Full session details", pos_register_session_path(register_session), class: "ss-link" %>
        <%= link_to "Register summary report", register_summary_pos_reports_path(register_session_id: register_session.id), class: "ss-link" %>
        <%= link_to "Session history", drawer_pos_reports_path, class: "ss-link" %>
      </div>
    <% end %>
  </section>

  <section id="pos-session-drawer-held" class="ss-drawer-section">
    <h3 class="ss-drawer-section-title">Held sales</h3>
    <p class="ss-hint">Suspended transactions stay on this workstation until resumed explicitly.</p>
    <%= render "pos/shared/held_transactions_table", suspended_transactions: suspended_transactions %>
  </section>
<% end %>
