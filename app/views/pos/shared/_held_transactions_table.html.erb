<% suspended_transactions = local_assigns.fetch(:suspended_transactions) %>

<table class="ss-table ss-pos-table ss-pos-table--compact">
  <thead>
    <tr>
      <th>Trans. #</th>
      <th>Cashier</th>
      <th>Items</th>
      <th>Amount</th>
      <th>Held</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% if suspended_transactions.any? %>
      <% suspended_transactions.each do |transaction| %>
        <tr>
          <td>#<%= transaction.id %></td>
          <td><%= transaction.cashier_user.username %></td>
          <td><%= transaction.pos_transaction_lines.size %></td>
          <td><%= pos_money(transaction.total_cents) %></td>
          <td><%= transaction.suspended_at ? pos_store_local_time(transaction.suspended_at) : "—" %></td>
          <td>
            <% if pos_can_resume_transaction?(transaction) %>
              <%= render "shared/ui/button",
                         label: "Resume",
                         variant: :secondary,
                         size: :small,
                         url: resume_pos_transaction_path(transaction),
                         method: :patch %>
            <% else %>
              <span class="ss-hint">No access</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td colspan="6" class="ss-pos-home__empty">No held transactions on this workstation.</td>
      </tr>
    <% end %>
  </tbody>
</table>
