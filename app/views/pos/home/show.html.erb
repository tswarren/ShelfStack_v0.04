<% content_for :main_class, "ss-main--wide ss-pos-main" %>

<div class="ss-pos-home">
  <% if @register_session %>
    <%= render "open_dashboard" %>
  <% else %>
    <div class="ss-pos-home__closed-shell"
         data-controller="pos-command-bar"
         data-pos-command-bar-route-url-value="<%= pos_route_command_path %>">
      <%= render "pos/shared/workspace_header", register_session: nil, context: :root %>
      <div id="pos_flash">
        <%= render "pos/transactions/flash" %>
      </div>
      <%= render "pos/shared/workspace_modals", register_session: nil, suspended_transactions: @suspended_transactions || [] %>
      <%= render "closed_dashboard" %>
    </div>
  <% end %>
</div>
