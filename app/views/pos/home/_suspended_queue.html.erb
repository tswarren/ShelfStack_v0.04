<section class="ss-pos-panel ss-pos-home__queue-panel">
  <h2 class="ss-pos-panel__title">Suspended Transactions</h2>
  <table class="ss-table ss-pos-table ss-pos-table--compact">
    <thead>
      <tr>
        <th>Trans. #</th>
        <th>Cashier</th>
        <th>Items</th>
        <th>Amount</th>
        <th>Time</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if @suspended_transactions.any? %>
        <% @suspended_transactions.each do |transaction| %>
          <tr>
            <td>#<%= transaction.id %></td>
            <td><%= transaction.cashier_user.username %></td>
            <td><%= transaction.pos_transaction_lines.size %></td>
            <td><%= pos_money(transaction.total_cents) %></td>
            <td><%= transaction.suspended_at ? pos_store_local_time(transaction.suspended_at) : "—" %></td>
            <td><%= link_to "Resume", resume_pos_transaction_path(transaction), data: { turbo_method: :patch }, class: "ss-btn ss-btn-secondary ss-btn--small" %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="6" class="ss-pos-home__empty">None</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
