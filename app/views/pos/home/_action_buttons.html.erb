<div class="ss-pos-action-grid">
  <% if variant == :open %>
    <% if @draft_transactions.any? %>
      <%= link_to "Continue", edit_pos_transaction_path(@draft_transactions.first), class: "ss-pos-action-grid__btn ss-btn" %>
    <% else %>
      <%= button_to "New Transaction", pos_transactions_path, method: :post, params: { mode: "sale" }, class: "ss-pos-action-grid__btn ss-btn" %>
    <% end %>
    <%= link_to "Manage Session", pos_register_session_path(@register_session), class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
    <%= button_to "Customer Pickup", pos_transactions_path, method: :post, params: { mode: "pickup" }, class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
    <%= link_to "Cash In/Out", pos_register_session_path(@register_session, anchor: "cash-movement"), class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
    <%= link_to "Reports", pos_reports_path, class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
  <% else %>
    <%= link_to "Open Register", new_pos_register_session_path, class: "ss-pos-action-grid__btn ss-btn" %>
    <%= link_to "Sessions (History)", drawer_pos_reports_path, class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
    <%= link_to "Reports", pos_reports_path, class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
  <% end %>
</div>
