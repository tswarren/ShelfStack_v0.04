<div class="ss-pos-action-grid">
  <% if variant == :open %>
    <% if @draft_transactions.any? %>
      <%= render "shared/ui/button",
                 label: "Continue",
                 variant: :primary,
                 class: "ss-pos-action-grid__btn",
                 url: edit_pos_transaction_path(@draft_transactions.first) %>
    <% else %>
      <%= render "shared/ui/button",
                 label: "New Transaction",
                 variant: :primary,
                 class: "ss-pos-action-grid__btn",
                 url: pos_transactions_path,
                 method: :post,
                 params: { mode: "sale" } %>
    <% end %>
    <%= render "shared/ui/button", label: "Manage Session", variant: :secondary, class: "ss-pos-action-grid__btn", url: pos_register_session_path(@register_session) %>
    <%= render "shared/ui/button", label: "Cash In/Out", variant: :secondary, class: "ss-pos-action-grid__btn", url: pos_register_session_path(@register_session, anchor: "cash-movement") %>
    <%= render "shared/ui/button", label: "Reports", variant: :secondary, class: "ss-pos-action-grid__btn", url: pos_reports_path %>
    <%= render "shared/ui/button", label: "Check Balance", variant: :secondary, class: "ss-pos-action-grid__btn", url: pos_stored_value_balance_path %>
  <% else %>
    <%= render "shared/ui/button", label: "Open Register", variant: :primary, class: "ss-pos-action-grid__btn", url: new_pos_register_session_path %>
    <%= render "shared/ui/button", label: "Sessions (History)", variant: :secondary, class: "ss-pos-action-grid__btn", url: drawer_pos_reports_path %>
    <%= render "shared/ui/button", label: "Reports", variant: :secondary, class: "ss-pos-action-grid__btn", url: pos_reports_path %>
  <% end %>
</div>
