<section class="report-section ss-pos-register-summary__box">
  <h2 class="ss-pos-register-summary__box-title">Taxes Collected</h2>
  <table class="ss-pos-register-summary__kv">
    <tbody>
      <% rows.each do |row| %>
        <tr class="<%= "is-total" if row.label == "Total tax" %>">
          <th scope="row"><%= row.label %></th>
          <td><%= pos_report_signed_money(row.tax_cents) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
