<nav class="ss-pos-mode-switch" aria-label="Register mode">
  <% PosHelper::POS_WORKSPACE_MODES.each do |mode| %>
    <% active = pos_mode_switch_active?(mode) %>
    <% path = if mode == "sale"
          edit_pos_transaction_path(transaction, mode: "sale")
        else
          edit_pos_transaction_path(transaction, mode: "sale", carry_forward: mode)
        end %>
    <%= link_to pos_mode_label(mode),
          path,
          class: "ss-pos-mode-switch__btn #{'ss-pos-mode-switch__btn--active' if active}",
          aria: { current: active ? "page" : nil } %>
  <% end %>
</nav>
