<%# locals: (transaction:, readiness:, inactive_warnings:) %>
<% confirm_inactive = params[:confirm_inactive].present? %>
<% complete_label = pos_complete_button_label(transaction, confirm_inactive: confirm_inactive && inactive_warnings.any?) %>
<% settlement_rows = transaction.pos_tenders.settlement_rows.order(:line_number) %>
<% sync_url = sync_tenders_pos_transaction_path(transaction) %>

<div class="ss-pos-modal__backdrop" data-action="click->pos-settlement-panel#close"></div>
<div class="ss-pos-modal__panel ss-pos-modal__panel--settlement ss-pos-tender-workspace"
     role="dialog"
     aria-labelledby="pos-settlement-title"
     aria-modal="true"
     data-pos-settlement-panel-sync-url-value="<%= sync_url %>">
  <% complete_params = {} %>
  <% complete_params[:confirm_inactive] = 1 if confirm_inactive %>
  <%= form_with url: complete_pos_transaction_path(transaction, complete_params),
        method: :patch,
        class: "ss-form ss-pos-settlement-form ss-pos-tender-workspace__form",
        data: {
          action: "input->pos-settlement-panel#update change->pos-settlement-panel#update input->pos-transaction-edit#updateChange change->pos-transaction-edit#updateChange"
        } do %>
    <%= hidden_field_tag :pos_authorization_id, params[:pos_authorization_id], data: { pos_transaction_edit_target: "authorizationId" } %>
    <%= hidden_field_tag :confirm_inactive, 1, data: { pos_transaction_edit_target: "confirmInactiveField" }, disabled: !confirm_inactive, id: nil %>

    <h2 id="pos-settlement-title" class="ss-pos-modal__title">Tender transaction</h2>

    <div id="pos_settlement_readiness" class="js-pos-readiness-host"<%= " hidden" if readiness.alert_blockers.empty? %>>
      <%= render "pos/transactions/readiness_alerts", transaction: transaction, readiness: readiness %>
    </div>

    <dl class="ss-pos-tender-workspace__summary">
      <div class="ss-pos-tender-workspace__summary-row">
        <dt>Amount due</dt>
        <dd data-pos-settlement-panel-target="amountDue"><%= pos_money(transaction.total_cents) %></dd>
      </div>
      <div class="ss-pos-tender-workspace__summary-row">
        <dt>Tendered</dt>
        <dd data-pos-settlement-panel-target="tenderedTotal">$0.00</dd>
      </div>
      <div class="ss-pos-tender-workspace__summary-row">
        <dt>Remaining</dt>
        <dd data-pos-settlement-panel-target="remainingBalance">—</dd>
      </div>
      <div class="ss-pos-tender-workspace__summary-row">
        <dt>Change due</dt>
        <dd data-pos-settlement-panel-target="changeDue">—</dd>
      </div>
    </dl>

    <div class="ss-pos-tender-workspace__types"
         role="group"
         aria-label="Tender type"
         data-pos-settlement-panel-target="typeSelector">
      <% if pos_can_use_tender_type?(transaction, "cash") %>
        <%= button_tag "1 Cash", type: "button", class: "ss-btn ss-btn-secondary ss-pos-tender-workspace__type-btn",
              data: { action: "pos-settlement-panel#selectTenderType", tender_type: "cash", hotkey: "1" } %>
      <% end %>
      <% if pos_can_use_tender_type?(transaction, "card") %>
        <%= button_tag "2 Card", type: "button", class: "ss-btn ss-btn-secondary ss-pos-tender-workspace__type-btn",
              data: { action: "pos-settlement-panel#selectTenderType", tender_type: "card", hotkey: "2" } %>
      <% end %>
      <% if pos_can_use_tender_type?(transaction, "check") %>
        <%= button_tag "3 Check", type: "button", class: "ss-btn ss-btn-secondary ss-pos-tender-workspace__type-btn",
              data: { action: "pos-settlement-panel#selectTenderType", tender_type: "check", hotkey: "3" } %>
      <% end %>
      <% if pos_stored_value_tender_available?(transaction) %>
        <%= button_tag "4 Stored value", type: "button", class: "ss-btn ss-btn-secondary ss-pos-tender-workspace__type-btn",
              data: { action: "pos-settlement-panel#selectTenderType", tender_type: "stored_value", hotkey: "4" } %>
      <% end %>
    </div>

    <section class="ss-pos-tender-workspace__active-detail"
             aria-label="Active tender details"
             data-pos-settlement-panel-target="activeDetail"
             hidden>
      <h3 class="ss-pos-tender-workspace__active-title">Active tender</h3>
      <table class="ss-pos-settlement-table ss-pos-settlement-table--draft">
        <tbody data-pos-settlement-panel-target="draftRows"></tbody>
      </table>
      <footer class="ss-pos-tender-workspace__active-footer">
        <%= button_tag "Save tender", type: "button", class: "ss-btn ss-pos-tender-workspace__save-btn",
              data: { action: "pos-settlement-panel#saveActiveDetail" } %>
        <%= button_tag "Cancel", type: "button", class: "ss-btn ss-btn-secondary",
              data: { action: "pos-settlement-panel#cancelActiveDetail" } %>
      </footer>
    </section>

    <section class="ss-pos-tender-workspace__saved" aria-label="Saved tenders">
      <h3 class="ss-pos-tender-workspace__saved-title">Saved tenders</h3>
      <table class="ss-pos-settlement-table ss-pos-settlement-table--modal">
        <tbody data-pos-settlement-panel-target="rows" data-action="focusout->pos-settlement-panel#rowFocusOut">
          <% if settlement_rows.any? %>
            <% settlement_rows.each_with_index do |row, index| %>
              <%= render "pos/transactions/settlement_row", row: row, transaction: transaction, row_index: index, modal: true %>
            <% end %>
          <% else %>
            <tr class="ss-pos-settlement-empty" data-pos-settlement-panel-target="emptyRow">
              <td colspan="3">No tenders saved yet.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>

    <template data-pos-settlement-panel-target="cardTemplate">
      <%= render "pos/transactions/settlement_row",
            row: PosTender.new(tender_type: "card", card_brand: "other", line_number: 0),
            transaction: transaction,
            row_index: "TEMPLATE",
            modal: true %>
    </template>

    <template data-pos-settlement-panel-target="checkTemplate">
      <%= render "pos/transactions/settlement_row",
            row: PosTender.new(tender_type: "check", line_number: 0),
            transaction: transaction,
            row_index: "TEMPLATE",
            modal: true %>
    </template>

    <template data-pos-settlement-panel-target="cashTemplate">
      <%= render "pos/transactions/settlement_row",
            row: PosTender.new(tender_type: "cash", line_number: 0),
            transaction: transaction,
            row_index: "TEMPLATE",
            modal: true %>
    </template>

    <template data-pos-settlement-panel-target="storedValueTemplate">
      <%= render "pos/transactions/settlement_row",
            row: PosTender.new(tender_type: "stored_value", line_number: 0),
            transaction: transaction,
            row_index: "TEMPLATE",
            modal: true %>
    </template>

    <template data-pos-settlement-panel-target="storeCreditTemplate">
      <%= render "pos/transactions/settlement_row",
            row: PosTender.new(tender_type: "store_credit", line_number: 0),
            transaction: transaction,
            row_index: "TEMPLATE",
            modal: true %>
    </template>

    <template data-pos-settlement-panel-target="giftCardTemplate">
      <%= render "pos/transactions/settlement_row",
            row: PosTender.new(tender_type: "gift_card", line_number: 0),
            transaction: transaction,
            row_index: "TEMPLATE",
            modal: true %>
    </template>

    <div class="ss-pos-tender-workspace__ready"
         data-pos-settlement-panel-target="readyComplete"
         hidden>
      <p class="ss-pos-tender-workspace__ready-label">Ready to complete</p>
      <p class="ss-hint">Press Enter to complete the sale, or Esc to return to the transaction.</p>
    </div>

    <div class="ss-pos-settlement-modal-footer">
      <div class="ss-pos-settlement-modal-footer__toolbar">
        <div class="ss-pos-settlement-modal-footer__right">
          <%= button_tag "Back", type: "button", class: "ss-btn ss-btn-secondary ss-btn--small", data: { action: "pos-settlement-panel#close" } %>
        </div>
      </div>
      <div class="ss-pos-settlement-modal-footer__complete">
        <%= submit_tag complete_label,
              class: "ss-btn ss-pos-complete-btn ss-pos-settlement-complete-btn",
              disabled: !readiness.complete_ready?,
              data: { pos_transaction_edit_target: "completeButton" } %>
      </div>
    </div>
  <% end %>
</div>
