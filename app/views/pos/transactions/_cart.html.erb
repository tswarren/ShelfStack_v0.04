<section class="ss-pos-panel ss-pos-cart">
  <h2 class="ss-pos-panel__title">Cart</h2>
  <%= render "pos/transactions/pickup_context_banner", transaction: transaction %>
  <% if transaction.pos_transaction_lines.empty? %>
    <p class="ss-hint">Scan an item to begin.</p>
  <% else %>
    <table class="ss-table ss-pos-table ss-pos-cart-table">
      <thead>
        <tr>
          <th>Qty</th>
          <th>Item</th>
          <th class="ss-pos-money-col">Discount</th>
          <th class="ss-pos-money-col">Total</th>
          <th>Tax</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% transaction.pos_transaction_lines.order(:line_number).each do |line| %>
          <%= render "pos/transactions/cart_line", transaction: transaction, line: line %>
          <% if line.gift_card_sale_line? %>
            <%= render "pos/transactions/gift_card_sale_activation", transaction: transaction, line: line %>
          <% end %>
          <%= render "pos/transactions/cart_line_edit", transaction: transaction, line: line %>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
