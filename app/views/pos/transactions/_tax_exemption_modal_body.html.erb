<%# locals: (transaction:, exemption_error: nil) %>
<% exemption_error ||= @tax_exemption_error if defined?(@tax_exemption_error) && @tax_exemption_error.present? %>
<% submitted = exemption_error&.dig(:submitted) || {} %>
<% invalid_fields = exemption_error&.dig(:invalid_fields) || [] %>
<% exemption = transaction.active_tax_exemption %>

<% if exemption.present? %>
  <% summary = pos_transaction_tax_exemption_summary(transaction) %>
  <div class="ss-pos-tax-exemption-summary">
    <p><strong>Active exemption:</strong> <%= exemption.tax_exception_reason.name %></p>
    <% if exemption.certificate_number.present? %>
      <p><strong>Certificate:</strong> <%= exemption.certificate_number %></p>
    <% end %>
    <% if summary[:expected_tax_cents].positive? %>
      <p><strong>Expected tax:</strong> <%= pos_money(summary[:expected_tax_cents]) %></p>
      <p><strong>Tax removed:</strong> −<%= pos_money(summary[:tax_removed_cents]) %></p>
    <% end %>
    <% if Authorization.allowed?(user: current_user, permission_key: "pos.tax_exemptions.void", store: current_store) %>
      <%= button_to "Remove exemption",
            void_tax_exemption_pos_transaction_path(transaction, exemption_id: exemption.id),
            method: :delete,
            class: "ss-btn ss-btn-secondary",
            form: { data: { turbo_stream: true, action: "turbo:submit-end->pos-command-bar#taxExemptionSubmitted" } } %>
    <% end %>
  </div>
<% else %>
  <% if exemption_error&.dig(:message).present? %>
    <p class="ss-hint ss-hint--warning ss-pos-tax-exemption-form__error"><%= exemption_error[:message] %></p>
  <% end %>

  <%= form_with url: apply_tax_exemption_pos_transaction_path(transaction),
        method: :post,
        class: "ss-form ss-pos-tax-exemption-form",
        html: { novalidate: true },
        data: {
          turbo_stream: true,
          action: "submit->pos-tax-exemption-input#validateSubmit turbo:submit-end->pos-command-bar#taxExemptionSubmitted"
        } do %>
    <%= render "pos/transactions/tax_exemption_fields",
          id_prefix: "tax_exemption_modal",
          submitted: submitted,
          invalid_fields: invalid_fields %>

    <footer class="ss-modal-form-footer ss-pos-tax-exemption-form__footer">
      <%= submit_tag "Apply tax exemption", class: "ss-btn ss-pos-tax-exemption-form__action" %>
      <button type="button"
              class="ss-btn ss-btn-secondary ss-pos-tax-exemption-form__action"
              data-action="pos-command-bar#closeTaxExemptionModal">Cancel</button>
    </footer>
  <% end %>
<% end %>
