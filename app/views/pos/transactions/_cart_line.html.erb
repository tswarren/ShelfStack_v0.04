<tr class="ss-pos-cart-line <%= 'ss-pos-cart-line--return' if line.return_line? %>"
    id="<%= dom_id(line) %>"
    data-pos-cart-line-target="displayRow"
    data-line-id="<%= line.id %>">
  <td class="ss-pos-cart-line__qty">
    <div class="ss-pos-qty-controls">
      <%= button_to "−",
            update_line_pos_transaction_path(transaction, line_id: line.id, quantity_delta: -1),
            method: :patch,
            class: "ss-btn ss-btn-secondary ss-btn--small",
            form: { data: { turbo_stream: true } } %>
      <span><%= line.quantity.abs %></span>
      <%= button_to "+",
            update_line_pos_transaction_path(transaction, line_id: line.id, quantity_delta: 1),
            method: :patch,
            class: "ss-btn ss-btn-secondary ss-btn--small",
            form: { data: { turbo_stream: true } } %>
    </div>
  </td>
  <td class="ss-pos-cart-line__item">
    <div class="ss-pos-cart-line__header">
      <% if line.return_line? %><span class="ss-pos-cart-line__badge">RETURN</span><% end %>
      <% if line.inventory_reservation_id.present? %><span class="ss-pos-cart-line__badge">PICKUP</span><% end %>
      <span class="ss-pos-cart-line__meta"><%= pos_line_display_sku(line) %></span>
      <span class="ss-pos-cart-line__tax-letter"><%= render "pos/transactions/line_tax_indicator", line: line %></span>
    </div>
    <strong class="ss-pos-cart-line__title"><%= pos_line_display_title(line) %></strong>
    <div class="ss-pos-cart-line__details">
      <% if line.return_line? %>
        <span class="ss-status-badge status-warning"><%= line.return_disposition&.humanize || "Return" %></span>
      <% end %>
      <% if (source_label = pos_line_return_source_label(line)).present? %>
        <span class="ss-hint"><%= source_label %></span>
      <% end %>
      <% if (pickup_label = pos_line_pickup_label(line)).present? %>
        <span class="ss-hint"><%= pickup_label %></span>
      <% end %>
    </div>
  </td>
  <td class="ss-pos-money-col"><%= pos_money(line.unit_price_cents) %></td>
  <td class="ss-pos-money-col">
    <% if pos_line_total_discount_cents(line).positive? %>
      <span class="ss-pos-discount-amount">−<%= pos_money(pos_line_total_discount_cents(line)) %></span>
    <% else %>
      —
    <% end %>
  </td>
  <td class="ss-pos-money-col ss-pos-cart-line__total"><%= pos_money(pos_line_total_cents(line)) %></td>
  <td class="ss-pos-cart-line__actions">
    <button type="button" class="ss-btn ss-btn-secondary ss-btn--small" data-action="pos-cart-line#edit" data-line-id="<%= line.id %>">More</button>
    <%= button_to "Remove",
          remove_line_pos_transaction_path(transaction, line_id: line.id),
          method: :delete,
          class: "ss-btn ss-btn-secondary ss-btn--small",
          form: { data: { turbo_stream: true, turbo_confirm: "Remove this line?" } } %>
  </td>
</tr>
