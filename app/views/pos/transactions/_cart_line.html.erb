<% panel_error = @line_panel_error if defined?(@line_panel_error) && @line_panel_error.present? %>
<% line_editing = pos_cart_line_panel_open?(line, panel_error) %>
<% can_edit = pos_cart_line_edit_panel_available?(line) %>
<% can_discount = pos_cart_line_discount_panel_available?(line) &&
     Authorization.allowed?(user: current_user, permission_key: "pos.discounts.line.apply", store: current_store) %>
<% can_tax = pos_cart_line_tax_panel_available?(line) &&
     Authorization.allowed?(user: current_user, permission_key: "pos.tax_overrides.line.apply", store: current_store) %>
<% line_discount_total = pos_line_total_discount_cents(line) %>
<% line_discount_share = line.line_discount_cents.to_i %>
<% transaction_discount_share = pos_line_transaction_discount_cents(line) %>
<tr class="ss-pos-cart-line <%= 'ss-pos-cart-line--return' if line.return_line? %><%= ' ss-pos-cart-line--editing' if line_editing %>"
    id="<%= dom_id(line) %>"
    data-pos-cart-line-target="displayRow"
    data-line-id="<%= line.id %>">
  <td class="ss-pos-cart-line__qty">
    <% if line.gift_card_sale_line? %>
      <span class="ss-pos-cart-line__qty-readonly"><%= line.quantity %></span>
    <% elsif line.inventory_reservation_id.present? %>
      <span class="ss-pos-cart-line__qty-readonly"><%= line.quantity.abs %></span>
    <% else %>
      <div class="ss-pos-qty-controls">
        <%= button_to "−",
              update_line_pos_transaction_path(transaction, line_id: line.id, quantity_delta: -1),
              method: :patch,
              class: "ss-btn ss-btn-secondary ss-btn--small",
              form: { data: { turbo_stream: true } } %>
        <span><%= line.quantity.abs %></span>
        <%= button_to "+",
              update_line_pos_transaction_path(transaction, line_id: line.id, quantity_delta: 1),
              method: :patch,
              class: "ss-btn ss-btn-secondary ss-btn--small",
              form: { data: { turbo_stream: true } } %>
      </div>
    <% end %>
  </td>
  <td class="ss-pos-cart-line__item">
    <div class="ss-pos-cart-line__header">
      <% if line.return_line? %><span class="ss-pos-cart-line__badge">RETURN</span><% end %>
      <% if line.gift_card_sale_line? %><span class="ss-pos-cart-line__badge">GIFT CARD</span><% end %>
      <% if line.inventory_reservation_id.present? %><span class="ss-pos-cart-line__badge">PICKUP</span><% end %>
      <span class="ss-pos-cart-line__meta"><%= pos_line_display_sku(line) %></span>
    </div>
    <strong class="ss-pos-cart-line__title"><%= pos_line_display_title(line) %></strong>
    <div class="ss-pos-cart-line__details">
      <% if line.return_line? %>
        <span class="ss-status-badge status-warning"><%= line.return_disposition&.humanize || "Return" %></span>
      <% end %>
      <% if (source_label = pos_line_return_source_label(line)).present? %>
        <span class="ss-hint"><%= source_label %></span>
      <% end %>
      <% if (pickup_context = pos_line_pickup_context(line)).present? %>
        <div class="ss-pos-pickup-context">
          <strong>Pickup for <%= pickup_context.customer_name || "customer" %></strong>
          <% if pickup_context.request_number.present? %>
            <span>Request <%= pickup_context.request_number %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </td>
  <td class="ss-pos-money-col ss-pos-cart-line__discount">
    <% if line_discount_total.positive? %>
      <span class="ss-pos-discount-amount">−<%= pos_money(line_discount_total) %></span>
      <% if line_discount_share.positive? || transaction_discount_share.positive? %>
        <div class="ss-pos-cart-line__discount-breakdown">
          <% if line_discount_share.positive? %>
            <span>Line: <%= pos_money(line_discount_share) %></span>
          <% end %>
          <% if transaction_discount_share.positive? %>
            <span>Trans: <%= pos_money(transaction_discount_share) %></span>
          <% end %>
        </div>
      <% end %>
    <% else %>
      —
    <% end %>
  </td>
  <td class="ss-pos-money-col ss-pos-cart-line__total">
    <%= pos_money(pos_line_total_cents(line)) %>
    <% if line.quantity.to_i.abs > 1 && !line.gift_card_sale_line? %>
      <div class="ss-pos-cart-line__unit-hint"><%= line.quantity.abs %> @ <%= pos_money(line.unit_price_cents) %></div>
    <% end %>
  </td>
  <td class="ss-pos-cart-line__tax">
    <%= render "pos/transactions/line_tax_cell", line: line %>
  </td>
  <td class="ss-pos-cart-line__actions">
    <div class="ss-pos-line-actions">
      <button type="button"
              class="ss-btn ss-btn-secondary ss-btn--small"
              data-action="pos-cart-line#toggleMenu"
              data-line-id="<%= line.id %>"
              aria-haspopup="menu"
              aria-expanded="false"
              aria-controls="pos_line_menu_<%= line.id %>">More ▾</button>
      <div class="ss-pos-line-menu"
           id="pos_line_menu_<%= line.id %>"
           role="menu"
           data-pos-cart-line-target="menu"
           data-line-id="<%= line.id %>"
           hidden>
        <% if can_edit %>
          <button type="button"
                  class="ss-pos-line-menu__item"
                  role="menuitem"
                  data-action="pos-cart-line#selectPanel"
                  data-panel="edit"
                  data-line-id="<%= line.id %>">Change quantity/price</button>
        <% end %>
        <% if can_discount %>
          <button type="button"
                  class="ss-pos-line-menu__item"
                  role="menuitem"
                  data-action="pos-cart-line#selectPanel"
                  data-panel="discount"
                  data-line-id="<%= line.id %>">Discount line</button>
        <% end %>
        <% if can_tax %>
          <button type="button"
                  class="ss-pos-line-menu__item"
                  role="menuitem"
                  data-action="pos-cart-line#selectPanel"
                  data-panel="tax"
                  data-line-id="<%= line.id %>">Change tax</button>
        <% end %>
        <%= button_to "Remove line",
              remove_line_pos_transaction_path(transaction, line_id: line.id),
              method: :delete,
              class: "ss-pos-line-menu__item ss-pos-line-menu__item--danger",
              form: { data: { turbo_stream: true, turbo_confirm: "Remove this line?" }, class: "ss-pos-line-menu__form" } %>
      </div>
    </div>
  </td>
</tr>
