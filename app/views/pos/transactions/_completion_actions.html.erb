<div class="ss-pos-transaction-show__actions">
  <%= render "shared/ui/button",
             label: "POS Menu",
             variant: :primary,
             class: "ss-pos-transaction-show__primary-action",
             url: pos_root_path %>

  <% if transaction.pos_receipt %>
    <%= render "shared/ui/button",
               label: "Receipt",
               variant: :secondary,
               class: "ss-pos-transaction-show__secondary-action",
               url: pos_receipt_path(transaction.pos_receipt) %>
  <% else %>
    <%= render "shared/ui/button",
               label: "Receipt",
               variant: :secondary,
               disabled: true,
               class: "ss-pos-transaction-show__secondary-action" %>
  <% end %>
</div>
<%= render "pos/transactions/issuance_slip_links", transaction: transaction %>
