<div class="ss-pos-action-grid ss-pos-action-grid--three">
  <%= link_to "POS Menu", pos_root_path, class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
  <% if transaction.pos_receipt %>
    <%= link_to "Receipt", pos_receipt_path(transaction.pos_receipt), class: "ss-pos-action-grid__btn ss-btn ss-btn-secondary" %>
  <% else %>
    <span class="ss-pos-action-grid__btn ss-btn ss-btn-secondary" aria-disabled="true">Receipt</span>
  <% end %>
  <%= button_to "New Transaction", pos_transactions_path, method: :post, params: { mode: "sale" }, class: "ss-pos-action-grid__btn ss-btn" %>
</div>
