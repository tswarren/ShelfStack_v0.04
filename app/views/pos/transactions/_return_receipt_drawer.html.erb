<section class="ss-pos-panel ss-pos-drawer <%= 'ss-pos-drawer--inline' if local_assigns[:inline] %>"
         data-controller="pos-return-lookup"
         data-pos-return-lookup-url-value="<%= pos_return_lookup_path %>"
         data-pos-return-lookup-add-url-value="<%= add_return_line_pos_transaction_path(transaction) %>">
  <div class="ss-pos-drawer__header">
    <h2 class="ss-pos-panel__title">Return from receipt</h2>
    <% if local_assigns[:inline] %>
      <button type="button" class="ss-btn ss-btn-secondary ss-btn--small" data-action="pos-command-bar#closeReceiptPanel">Cancel</button>
    <% end %>
  </div>
  <div class="ss-pos-scan-row">
    <%= text_field_tag :receipt_number, nil, placeholder: "Receipt / transaction number", class: "ss-pos-scan-input", data: { pos_return_lookup_target: "input", action: "keydown->pos-return-lookup#lookup" } %>
    <%= button_tag "Find receipt", type: "button", class: "ss-btn ss-btn-secondary", data: { action: "pos-return-lookup#lookup" } %>
  </div>
  <p class="ss-hint ss-hint--warning" data-pos-return-lookup-target="message" hidden></p>
  <div data-pos-return-lookup-target="results"></div>
</section>
