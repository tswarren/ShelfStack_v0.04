<%# locals: (transaction:, label: nil, id_prefix: nil, type_name: :discount_type, value_name: :discount_value, show_reason: true) %>
<% field_id = local_assigns[:id_prefix].presence || "discount" %>
<% type_name = local_assigns.fetch(:type_name, "discount_type") %>
<% value_name = local_assigns.fetch(:value_name, "discount_value") %>
<% show_reason = local_assigns.fetch(:show_reason, true) %>
<% authorization_id = params[:pos_authorization_id] %>
<% selected_reason_requires_auth = pos_discount_reason_requires_authorization?(params[:discount_reason_id]) %>

<div class="ss-field ss-pos-discount-field"
     data-controller="pos-discount-input"
     data-pos-discount-input-amount-label-value="$ Amount"
     data-pos-discount-input-percent-label-value="% Percent"
     data-pos-discount-input-transaction-id-value="<%= transaction.id %>"
     data-pos-discount-input-authorization-type-value="discount_reason_approval"
     data-action="pos:authorization-granted@document->pos-discount-input#authorizationGranted">
  <%= label_tag "#{field_id}_discount_value", local_assigns.fetch(:label, "Discount") %>
  <div class="ss-pos-discount-field__row">
    <%= select_tag type_name,
          options_for_select(pos_discount_type_options, "amount"),
          id: "#{field_id}_discount_type",
          data: { pos_discount_input_target: "type", action: "change->pos-discount-input#updateMode" } %>
    <%= number_field_tag value_name,
          nil,
          id: "#{field_id}_discount_value",
          min: 0,
          step: 0.01,
          class: "ss-pos-discount-input",
          data: { pos_discount_input_target: "value" } %>
  </div>
  <% if show_reason %>
    <div class="ss-field">
      <%= label_tag "#{field_id}_discount_reason_id", "Reason" %>
      <%= select_tag :discount_reason_id,
            options_for_select(pos_discount_reason_options, params[:discount_reason_id]),
            id: "#{field_id}_discount_reason_id",
            include_blank: "Select a reason",
            required: true,
            data: {
              pos_discount_input_target: "reason",
              action: "change->pos-discount-input#reasonChanged"
            } %>
    </div>
    <div class="ss-field">
      <%= label_tag "#{field_id}_discount_note", "Note" %>
      <%= text_area_tag :discount_note, nil, id: "#{field_id}_discount_note", rows: 2 %>
    </div>
  <%= hidden_field_tag :pos_authorization_id, authorization_id, data: { pos_discount_input_target: "authorizationId", pos_transaction_edit_target: "authorizationId" } %>
    <div class="ss-pos-discount-auth"
         data-pos-discount-input-target="authorizePanel"
         <%= "hidden" unless selected_reason_requires_auth && authorization_id.blank? %>>
      <p class="ss-hint ss-hint--warning">This reason requires manager approval before applying the discount.</p>
      <button type="button"
              class="ss-btn ss-btn-secondary ss-btn--small"
              data-action="pos-discount-input#requestAuthorization">
        Authorize discount
      </button>
    </div>
    <p class="ss-hint ss-pos-discount-auth-status"
       data-pos-discount-input-target="authorizedStatus"
       <%= "hidden" unless authorization_id.present? %>>
      Manager authorization recorded. You can apply the discount.
    </p>
  <% end %>
</div>
