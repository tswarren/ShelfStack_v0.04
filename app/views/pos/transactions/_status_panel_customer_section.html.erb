<%# locals: (transaction:) %>
<div class="ss-pos-status-panel__header">
  <h2 class="ss-pos-status-panel__title">Customer</h2>
  <% if transaction.customer.blank? &&
        transaction.editable? &&
        Authorization.allowed?(user: current_user, permission_key: "pos.access", store: current_store) %>
    <button type="button"
            class="ss-btn ss-btn-secondary ss-btn--small ss-pos-status-panel__header-action"
            data-action="pos-command-bar#showCustomerLookupModal">
      Link customer
    </button>
  <% end %>
</div>

<table class="ss-pos-status-panel__table">
  <tbody>
    <% if transaction.customer.present? %>
      <tr>
        <td class="ss-pos-status-panel__cell ss-pos-status-panel__cell--label"><%= transaction.customer.display_name %></td>
        <td class="ss-pos-status-panel__cell ss-pos-status-panel__cell--amount" aria-hidden="true"></td>
        <td class="ss-pos-status-panel__cell ss-pos-status-panel__cell--action">
          <% if transaction.editable? %>
            <%= button_to "Remove",
                  detach_customer_pos_transaction_path(transaction),
                  method: :patch,
                  class: "ss-btn-link",
                  form: { data: { turbo_stream: true }, class: "ss-pos-status-panel__action-form" } %>
          <% end %>
        </td>
      </tr>
    <% else %>
      <tr>
        <td class="ss-pos-status-panel__cell ss-pos-status-panel__cell--label ss-pos-status-panel__empty" colspan="3">None attached</td>
      </tr>
    <% end %>
  </tbody>
</table>
