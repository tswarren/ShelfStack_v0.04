<% return_mode = false %>

<section class="ss-pos-panel ss-pos-command-bar"
         data-controller="pos-command-bar pos-line-entry"
         data-pos-command-bar-route-url-value="<%= route_command_pos_transaction_path(transaction) %>"
         data-pos-command-bar-add-gift-card-url-value="<%= add_gift_card_sale_line_pos_transaction_path(transaction) %>"
         data-pos-command-bar-return-mode-value="<%= return_mode %>"
         data-pos-line-entry-url-value="<%= pos_line_lookup_path %>"
         data-pos-line-entry-add-url-value="<%= add_line_pos_transaction_path(transaction) %>"
         data-pos-line-entry-add-reservation-url-value="<%= add_reservation_line_pos_transaction_path(transaction) %>"
         data-pos-line-entry-return-mode-value="<%= return_mode %>"
         data-pos-line-entry-mode-value="<%= pos_workspace_mode %>">
  <div class="ss-pos-command-bar__entry-row">
    <div class="ss-pos-command-bar__scan-column">
      <%= label_tag :pos_command_input, "Scan or enter item", class: "ss-pos-command-bar__scan-label" %>
      <%= text_field_tag :pos_command_input, nil,
            autocomplete: "off",
            placeholder: "Scan SKU/ISBN or enter a command, such as /op, /giftcard, /balance, or /help",
            class: "ss-pos-scan-input ss-pos-scan-input--primary",
            data: {
              pos_command_bar_target: "input",
              pos_line_entry_target: "query",
              action: "keydown.enter->pos-command-bar#submit input->pos-line-entry#search"
            } %>
    </div>
    <div class="ss-pos-command-bar__mode-column">
      <%= render "pos/transactions/mode_switcher", transaction: transaction %>
    </div>
  </div>

  <p class="ss-hint" data-pos-line-entry-target="message"></p>
  <div class="ss-pos-choices" data-pos-line-entry-target="choices"></div>

  <div class="ss-pos-inline-panel" data-pos-command-bar-target="receiptPanel" hidden>
    <%= render "pos/transactions/return_receipt_drawer", transaction: transaction, inline: true %>
  </div>

  <div class="ss-pos-inline-panel" data-pos-command-bar-target="openRingPanel" hidden>
    <%= render "pos/transactions/open_ring_drawer", transaction: transaction, sub_departments: sub_departments, inline: true %>
  </div>

  <div class="ss-pos-inline-panel" data-pos-command-bar-target="giftCardPanel" hidden>
    <%= render "pos/transactions/gift_card_sale_drawer", transaction: transaction, inline: true %>
  </div>

  <div class="ss-pos-inline-panel" data-pos-command-bar-target="balancePanel" hidden>
    <%= render "pos/shared/stored_value_balance_inquiry", show_close: true %>
  </div>

  <div class="ss-pos-inline-panel" data-pos-command-bar-target="pickupPanel" hidden>
    <%= render "pos/transactions/pickup_panel", transaction: transaction, inline: true %>
  </div>
</section>
