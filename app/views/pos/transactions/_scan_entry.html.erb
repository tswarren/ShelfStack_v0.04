<section class="ss-pos-panel ss-pos-scan-panel" data-pos-register-workspace-target="salePanel">
  <div data-controller="pos-line-entry"
       data-pos-line-entry-url-value="<%= pos_line_lookup_path %>"
       data-pos-line-entry-auto-add-value="true">
    <%= form_with url: add_line_pos_transaction_path(transaction), method: :post, class: "ss-pos-scan-form", data: { pos_line_entry_target: "form" } do %>
      <%= hidden_field_tag :product_variant_id, nil, data: { pos_line_entry_target: "variantId" } %>
      <%= hidden_field_tag :entry_action, entry_action, data: { pos_line_entry_target: "entryActionField", pos_register_workspace_target: "entryActionField" } %>
      <%= hidden_field_tag :pos_authorization_id, params[:pos_authorization_id], data: { pos_transaction_edit_target: "authorizationId" } %>
      <div class="ss-pos-scan-row ss-pos-scan-row--primary">
        <%= text_field_tag :sku_lookup, nil,
              placeholder: "Scan ISBN / UPC / SKU",
              autocomplete: "off",
              class: "ss-pos-scan-input ss-pos-scan-input--primary",
              data: { pos_line_entry_target: "lookupInput", action: "keydown->pos-line-entry#lookupExact input->pos-line-entry#search" } %>
        <%= number_field_tag :quantity, 1, step: 1, class: "ss-pos-qty-input ss-pos-no-print", data: { pos_line_entry_target: "quantity", pos_register_workspace_target: "scanQuantity" } %>
        <%= pos_money_field :unit_price, nil, placeholder: "Price override", class: "ss-pos-money-input ss-pos-no-print", data: { pos_line_entry_target: "unitPrice" } %>
        <%= button_tag "Add", type: "button", class: "ss-btn ss-pos-no-print", data: { action: "pos-line-entry#submitLine" } %>
      </div>
      <p class="ss-pos-preview" data-pos-line-entry-target="preview"></p>
      <p class="ss-hint ss-hint--warning" data-pos-line-entry-target="message" hidden></p>
      <div data-pos-line-entry-target="choices" class="ss-pos-choices"></div>
    <% end %>
  </div>
</section>
