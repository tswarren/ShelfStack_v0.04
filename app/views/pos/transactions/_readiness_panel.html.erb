<section class="ss-pos-panel ss-pos-readiness <%= pos_readiness_panel_class(readiness) %>">
  <h2 class="ss-pos-panel__title"><%= pos_readiness_panel_title(readiness) %></h2>
  <ul class="ss-pos-readiness-list">
    <% readiness.checks.each do |check| %>
      <li class="ss-pos-readiness-list__item ss-pos-readiness-list__item--<%= check.status %>">
        <div class="ss-pos-readiness-list__content">
          <% if check.status == :ok %>
            <span aria-hidden="true">✓</span>
          <% else %>
            <span aria-hidden="true">•</span>
          <% end %>
          <%= check.message %>
        </div>
        <% if check.status.in?(%i[block warn]) && check.action_key.present? %>
          <div class="ss-pos-readiness-list__action">
            <% case check.action_key %>
            <% when :open_register %>
              <%= link_to check.action_label, new_pos_register_session_path, class: "ss-btn ss-btn-secondary ss-btn--small" %>
            <% when :focus_scan %>
              <button type="button" class="ss-btn ss-btn-secondary ss-btn--small" data-action="pos-transaction-edit#focusScan"><%= check.action_label %></button>
            <% when :fill_cash %>
              <button type="button"
                      class="ss-btn ss-btn-secondary ss-btn--small"
                      data-action="pos-transaction-edit#fillTender"
                      data-tender-type="cash"><%= check.action_label %></button>
            <% when :confirm_inactive %>
              <label class="ss-pos-confirm-inactive">
                <%= check_box_tag :confirm_inactive_checkbox, 1, params[:confirm_inactive].present?, data: { action: "change->pos-transaction-edit#confirmInactive", pos_transaction_edit_target: "confirmInactive" } %>
                <%= check.action_label %>
              </label>
            <% when :supervisor_auth %>
              <button type="button"
                      class="ss-btn ss-btn-secondary ss-btn--small"
                      data-action="pos-transaction-edit#requestAuth"
                      data-authorization-type="<%= { discount_auth: 'discount_over_limit', no_receipt_return: 'no_receipt_return', cash_refund_auth: 'cash_refund_over_threshold' }[check.key] %>"
                      data-transaction-id="<%= transaction.id %>"
                      data-authorization-message="<%= pos_supervisor_auth_message(check) %>">
                <%= check.action_label %>
              </button>
            <% end %>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
</section>
