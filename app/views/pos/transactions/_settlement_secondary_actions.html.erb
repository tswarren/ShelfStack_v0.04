<%# locals: (transaction:, compact: false) %>
<div class="ss-pos-secondary-actions ss-pos-secondary-actions--inline<%= " ss-pos-secondary-actions--compact" if compact %>">
  <div class="ss-inline-actions">
    <%= render "shared/ui/button",
               label: "Suspend",
               variant: :secondary,
               size: (compact ? :small : nil),
               url: suspend_pos_transaction_path(transaction),
               method: :patch %>
    <%= render "shared/ui/button",
               label: "Cancel transaction",
               variant: :danger,
               size: (compact ? :small : nil),
               url: cancel_pos_transaction_path(transaction),
               method: :patch,
               data: { turbo_confirm: "Cancel this draft?" } %>
  </div>
</div>
