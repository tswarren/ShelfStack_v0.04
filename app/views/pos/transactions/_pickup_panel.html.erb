<% promoted = local_assigns.fetch(:promoted, false) %>
<% inline = local_assigns.fetch(:inline, false) %>
<% panel_open = local_assigns.fetch(:open, params[:pickup].present? || pos_pickup_mode?) %>

<% add_pickup_url = local_assigns.fetch(:add_pickup_url) {
  if transaction.present?
    add_demand_allocation_line_pos_transaction_path(transaction)
  else
    pos_workspace_add_demand_allocation_line_path
  end
} %>
<% redirect_on_success = local_assigns.fetch(:redirect_on_success, false) %>

<% pickup_content = capture do %>
  <div data-controller="pos-pickup-panel"
       data-pos-pickup-panel-url-value="<%= pos_pickup_lookup_path %>"
       data-pos-pickup-panel-add-pickup-url-value="<%= add_pickup_url %>"
       data-pos-pickup-panel-redirect-on-success-value="<%= redirect_on_success %>">
    <div class="ss-field">
      <%= label_tag :pos_pickup_customer_query, "Find customer" %>
      <%= text_field_tag :pos_pickup_customer_query, nil,
            class: "ss-input",
            data: { pos_pickup_panel_target: "query", action: "keydown.enter->pos-pickup-panel#search" } %>
    </div>
    <div class="ss-field">
      <%= label_tag :pos_pickup_demand_number, "Demand number" %>
      <%= text_field_tag :pos_pickup_demand_number, params[:pickup],
            class: "ss-input",
            data: { pos_pickup_panel_target: "demandNumber", action: "keydown.enter->pos-pickup-panel#search" } %>
    </div>
    <%= render "shared/ui/button", label: "Search ready items", variant: :secondary, data: { action: "pos-pickup-panel#search" } %>
    <p class="ss-hint" data-pos-pickup-panel-target="message"></p>
    <div class="ss-pos-choices" data-pos-pickup-panel-target="results"></div>
  </div>
<% end %>

<% if inline %>
  <section class="ss-pos-panel ss-pos-drawer ss-pos-drawer--inline">
    <div class="ss-pos-drawer__header">
      <h2 class="ss-pos-panel__title">Customer pickup</h2>
      <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, size: :small, data: { action: "pos-command-bar#closePickupPanel" } %>
    </div>
    <%= pickup_content %>
  </section>
<% elsif promoted %>
  <section class="ss-pos-panel ss-pos-pickup-panel ss-pos-pickup-panel--promoted">
    <h2 class="ss-pos-panel__title">Find pickup</h2>
    <%= pickup_content %>
  </section>
<% else %>
  <details class="ss-pos-panel" <%= "open" if panel_open %>>
    <summary>Customer pickup</summary>
    <%= pickup_content %>
  </details>
<% end %>
