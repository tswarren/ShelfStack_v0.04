<div data-controller="pos-void">
  <h1>Transaction <%= @transaction.completed? ? @transaction.transaction_number : "##{@transaction.id}" %></h1>

  <p>Status: <%= @transaction.status %></p>
  <% if @transaction.transaction_type.present? %>
    <p>Type: <%= @transaction.transaction_type %></p>
  <% end %>

  <dl class="ss-pos-totals-list">
    <div><dt>Subtotal</dt><dd><%= pos_money(@transaction.subtotal_cents) %></dd></div>
    <% if @transaction.discount_cents.to_i.positive? %>
      <div><dt>Order discount</dt><dd>−<%= pos_money(@transaction.discount_cents) %></dd></div>
    <% end %>
    <%= render "pos/transactions/tax_totals", transaction: @transaction %>
    <div class="ss-pos-totals-list__total"><dt>Total</dt><dd><%= pos_money(@transaction.total_cents) %></dd></div>
  </dl>

  <table class="ss-table ss-pos-table">
    <thead>
      <tr>
        <th>Line</th>
        <th>SKU</th>
        <th>Description</th>
        <th>Qty</th>
        <th>Unit</th>
        <th>Discount</th>
        <th>Tax</th>
        <th>Extended</th>
      </tr>
    </thead>
    <tbody>
      <% @transaction.pos_transaction_lines.each do |line| %>
        <tr>
          <td><%= line.line_number %></td>
          <td><%= line.variant_sku_snapshot || line.product_variant&.sku %></td>
          <td><%= line.variant_name_snapshot || line.open_ring_description || line.product_variant&.name %></td>
          <td><%= line.quantity %></td>
          <td><%= pos_money(line.unit_price_cents) %></td>
          <%= render "pos/transactions/line_discount", line: line %>
          <%= render "pos/transactions/line_tax", line: line %>
          <td><%= pos_money(line.extended_price_cents) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @transaction.completed? && @transaction.pos_receipt %>
    <%= link_to "View receipt", pos_receipt_path(@transaction.pos_receipt), class: "ss-btn" %>
  <% end %>

  <% if @transaction.completed? && !@transaction.voided? %>
    <button type="button" class="ss-btn ss-btn--danger" data-action="pos-void#open">Void transaction</button>

    <div class="ss-pos-modal" data-pos-void-target="modal" hidden>
      <div class="ss-pos-modal__backdrop" data-action="click->pos-void#close"></div>
      <div class="ss-pos-modal__panel">
        <h2>Void transaction <%= @transaction.transaction_number %></h2>
        <%= form_with url: void_pos_transaction_path(@transaction), method: :patch, data: { pos_void_target: "form", action: "submit->pos-void#submit" } do %>
          <div class="ss-field">
            <%= label_tag :reason_code, "Reason" %>
            <%= select_tag :reason_code, options_for_select(pos_void_reason_options), include_blank: "Select a reason", required: true, data: { pos_void_target: "reasonField" } %>
          </div>
          <div class="ss-field">
            <%= label_tag :notes, "Notes" %>
            <%= text_area_tag :notes, nil, rows: 3, placeholder: "Optional notes", data: { pos_void_target: "notesField" } %>
          </div>
          <p class="ss-hint">This will reverse inventory and tenders. Original receipt remains in history.</p>
          <div class="ss-pos-modal__actions">
            <%= submit_tag "Void transaction", class: "ss-btn ss-btn--danger" %>
            <button type="button" class="ss-btn ss-btn-secondary" data-action="pos-void#close">Cancel</button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= link_to "Back to POS", pos_root_path, class: "ss-btn ss-btn-secondary" %>
</div>
