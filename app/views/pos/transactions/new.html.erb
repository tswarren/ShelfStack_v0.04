<%= render "shared/forms/page_header",
           eyebrow: "POS",
           title: "New Transaction",
           description: "Start a draft sale, return, or exchange on this workstation." %>

<section class="ss-panel">
  <% unless current_register_session %>
    <%= render "shared/ui/alert",
               variant: :warning,
               message: "No register session is open. You can build a draft now, but you must open the register before completing." %>
    <p>
      <%= render "shared/ui/button", label: "Open register", variant: :secondary, url: new_pos_register_session_path %>
    </p>
  <% end %>

  <footer class="ss-form-actions">
    <%= render "shared/ui/button", label: "Start transaction", variant: :primary, url: pos_transactions_path, method: :post %>
    <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, url: pos_root_path %>
  </footer>
</section>
