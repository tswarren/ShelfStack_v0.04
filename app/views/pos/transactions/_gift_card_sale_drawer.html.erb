<% if pos_can_issue_gift_card_sale?(transaction) %>
  <section class="ss-pos-panel ss-pos-drawer <%= 'ss-pos-drawer--inline' if local_assigns[:inline] %>">
    <div class="ss-pos-drawer__header">
      <h2 class="ss-pos-panel__title">Sell gift card</h2>
      <% if local_assigns[:inline] %>
        <%= render "shared/ui/button", label: "Cancel", variant: :tertiary, size: :small, data: { action: "pos-command-bar#closeGiftCardPanel" } %>
      <% end %>
    </div>
    <%= form_with url: add_gift_card_sale_line_pos_transaction_path(transaction),
                  method: :post,
                  class: "ss-form ss-pos-gift-card-sale-form",
                  data: {
                    turbo_stream: true,
                    action: "turbo:submit-end->pos-command-bar#giftCardSubmitted"
                  } do %>
      <%= pos_money_field :unit_price, nil, placeholder: "Gift card amount", required: true, min: 0.01 %>
      <footer class="ss-form-actions">
        <%= render "shared/ui/button", label: "Add gift card", type: :submit, variant: :primary %>
      </footer>
    <% end %>
  </section>
<% end %>
