<%# locals: (row:, transaction:, row_index:) %>
<% refund = transaction.total_cents.to_i.negative? %>
<% display_amount = refund && row.amount_cents.to_i.negative? ? row.amount_cents.abs : row.amount_cents.to_i %>
<% row_amount_cents = row.tender_type == "cash" ? (refund ? display_amount : pos_tendered_display_cents(row).to_i) : display_amount.to_i %>
<% collapsed = row_amount_cents.positive? %>
<tr class="ss-pos-settlement-row"
    data-settlement-row
    data-settlement-type="<%= row.tender_type %>"
    data-row-id="<%= row.id %>"
    data-collapsed="<%= collapsed %>"
    data-pos-settlement-panel-target="row">
  <td class="ss-pos-settlement-row__type">
    <%= pos_settlement_row_type_label(row.tender_type, transaction) %>
    <%= hidden_field_tag "settlements[][id]", row.id %>
    <%= hidden_field_tag "settlements[][tender_type]", row.tender_type %>
    <%= hidden_field_tag "settlements[][line_number]", row.line_number %>
    <%= hidden_field_tag "settlements[][_destroy]", 0, data: { pos_settlement_panel_target: "destroyField" } %>
  </td>
  <td class="ss-pos-settlement-row__body" colspan="2">
    <button type="button"
            class="ss-pos-settlement-row__summary"
            data-pos-settlement-panel-target="rowSummary"
            data-action="pos-settlement-panel#expandRow">
      <span data-pos-settlement-panel-target="rowSummaryLabel"><%= pos_settlement_row_summary(row, transaction) %></span>
      <span class="ss-pos-settlement-row__summary-edit">Edit</span>
    </button>

    <div class="ss-pos-settlement-row__details" data-pos-settlement-panel-target="rowDetails">
      <% if row.tender_type == "cash" %>
        <div class="ss-pos-settlement-row__field-group">
          <%= label_tag nil, refund ? "Refund amount" : "Tendered", class: "ss-pos-settlement-row__field-label" %>
          <% cash_display = refund ? display_amount : pos_tendered_display_cents(row) %>
          <%= pos_money_field "settlements[][#{refund ? 'amount_dollars' : 'tendered_dollars'}]",
                cash_display,
                min: 0,
                data: {
                  pos_settlement_panel_target: "amountField",
                  pos_transaction_edit_target: "amountField",
                  settlement_amount: true,
                  action: "input->pos-settlement-panel#update change->pos-settlement-panel#update"
                } %>
        </div>
      <% elsif row.tender_type == "card" %>
        <div class="ss-pos-settlement-row__field-group">
          <%= label_tag nil, "Brand", class: "ss-pos-settlement-row__field-label" %>
          <%= select_tag "settlements[][card_brand]",
                options_for_select(pos_card_brand_options, row.card_brand || "other"),
                data: { action: "change->pos-settlement-panel#update" } %>
        </div>
        <div class="ss-pos-settlement-row__field-group">
          <%= label_tag nil, "Last four", class: "ss-pos-settlement-row__field-label" %>
          <%= text_field_tag "settlements[][card_last_four]", row.card_last_four,
                maxlength: 4,
                inputmode: "numeric",
                placeholder: "1234",
                data: { action: "input->pos-settlement-panel#update change->pos-settlement-panel#update" } %>
        </div>
        <div class="ss-pos-settlement-row__field-group">
          <%= label_tag nil, "Auth code", class: "ss-pos-settlement-row__field-label" %>
          <%= text_field_tag "settlements[][card_authorization_code]", row.card_authorization_code,
                data: { action: "input->pos-settlement-panel#update change->pos-settlement-panel#update" } %>
        </div>
        <div class="ss-pos-settlement-row__field-group">
          <%= label_tag nil, refund ? "Refund amount" : "Amount", class: "ss-pos-settlement-row__field-label" %>
          <%= pos_money_field "settlements[][amount_dollars]", display_amount, min: 0,
                data: {
                  pos_settlement_panel_target: "amountField",
                  pos_transaction_edit_target: "amountField",
                  settlement_amount: true,
                  action: "input->pos-settlement-panel#update change->pos-settlement-panel#update"
                } %>
        </div>
      <% elsif row.tender_type == "check" %>
        <div class="ss-pos-settlement-row__field-group">
          <%= label_tag nil, "Check number", class: "ss-pos-settlement-row__field-label" %>
          <%= text_field_tag "settlements[][check_number]", row.check_number,
                data: { action: "input->pos-settlement-panel#update change->pos-settlement-panel#update" } %>
        </div>
        <div class="ss-pos-settlement-row__field-group">
          <%= label_tag nil, refund ? "Refund amount" : "Amount", class: "ss-pos-settlement-row__field-label" %>
          <%= pos_money_field "settlements[][amount_dollars]", display_amount, min: 0,
                data: {
                  pos_settlement_panel_target: "amountField",
                  pos_transaction_edit_target: "amountField",
                  settlement_amount: true,
                  action: "input->pos-settlement-panel#update change->pos-settlement-panel#update"
                } %>
        </div>
      <% end %>
    </div>
  </td>
  <td class="ss-pos-settlement-row__actions">
    <div class="ss-pos-settlement-row__actions-expanded">
      <% unless row.tender_type == "cash" %>
        <%= button_tag "Fill",
              type: "button",
              class: "ss-btn ss-btn-secondary ss-btn--small",
              data: { action: "pos-settlement-panel#fillRemaining", tender_type: row.tender_type } %>
        <%= button_tag "Remove",
              type: "button",
              class: "ss-btn ss-btn--danger ss-btn--small",
              data: { action: "pos-settlement-panel#removeRow" } %>
      <% else %>
        <%= button_tag "Fill",
              type: "button",
              class: "ss-btn ss-btn-secondary ss-btn--small",
              data: { action: "pos-settlement-panel#fillRemaining", tender_type: "cash" } %>
      <% end %>
    </div>
    <div class="ss-pos-settlement-row__actions-collapsed">
      <% unless row.tender_type == "cash" %>
        <%= button_tag "Remove",
              type: "button",
              class: "ss-btn ss-btn--danger ss-btn--small",
              data: { action: "pos-settlement-panel#removeRow" } %>
      <% end %>
    </div>
  </td>
</tr>
