<%= render "shared/ui/page_header", title: "Recent Transactions" %>

<table class="ss-table">
  <thead>
    <tr>
      <th>ID / Number</th>
      <th>Status</th>
      <th>Type</th>
      <th>Total</th>
      <th>Updated</th>
    </tr>
  </thead>
  <tbody>
    <% @transactions.each do |transaction| %>
      <tr>
        <td>
          <%= link_to(
                transaction.transaction_number.presence || "##{transaction.id}",
                pos_transaction_path(transaction)
              ) %>
        </td>
        <td><%= transaction.status %></td>
        <td><%= transaction.transaction_type || "—" %></td>
        <td><%= number_to_currency(transaction.total_cents / 100.0) %></td>
        <td><%= transaction.updated_at %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<footer class="ss-form-actions">
  <%= render "shared/ui/button", label: "New transaction", variant: :primary, url: new_pos_transaction_path %>
  <%= render "shared/ui/button", label: "Back to POS", variant: :tertiary, url: pos_root_path %>
</footer>
