<div class="ss-pos-no-print ss-receipt-actions" data-controller="pos-receipt-print" data-pos-receipt-print-print-url-value="<%= print_pos_stored_value_issuance_slip_path(ledger_entry) %>">
  <%= render "shared/ui/button",
             label: "Print",
             variant: :primary,
             class: "ss-receipt-actions__print",
             data: { action: "pos-receipt-print#print" } %>

  <div class="ss-receipt-actions__secondary">
    <% if transaction.pos_receipt %>
      <%= render "shared/ui/button", label: "Receipt", variant: :secondary, url: pos_receipt_path(transaction.pos_receipt) %>
    <% end %>
    <%= render "shared/ui/button", label: "Summary", variant: :secondary, url: pos_transaction_path(transaction) %>
    <%= render "shared/ui/button", label: "Menu", variant: :secondary, url: pos_root_path %>
  </div>
</div>
