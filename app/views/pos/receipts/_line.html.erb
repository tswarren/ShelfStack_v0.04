<% line_class = line.return_line? ? "ss-receipt-line is-return" : "ss-receipt-line" %>
<article class="<%= line_class %>">
  <% if line.return_line? %>
    <p class="ss-receipt-line__return-label">Return</p>
  <% end %>

  <div class="ss-receipt-line__body">
    <span class="ss-receipt-line__sku"><%= pos_receipt_line_sku(line) %></span>
    <strong class="ss-receipt-line__amount">
      <%= pos_receipt_money(pos_receipt_line_header_amount_cents(line)) %>
      <% indicator = pos_line_tax_indicator(line) %>
      <% if indicator.present? && indicator != "—" %>
        <span class="ss-receipt-line__tax-code"><%= indicator %></span>
      <% end %>
    </strong>

    <div class="ss-receipt-line__name">
      <%= pos_line_display_title(line) %>
    </div>

    <div class="ss-receipt-line__details">
      <% if line.return_line? %>
        <% if line.return_disposition.present? %>
          <p class="ss-receipt-line__detail"><%= line.return_disposition.humanize %></p>
        <% end %>
        <% if (source_label = pos_line_return_source_label(line)).present? %>
          <p class="ss-receipt-line__detail"><%= source_label %></p>
        <% end %>
        <% if pos_receipt_line_show_quantity_detail?(line) %>
          <p class="ss-receipt-line__detail"><%= line.quantity.abs %> @ <%= pos_receipt_money(pos_receipt_line_unit_paid_amount_cents(line)) %></p>
        <% end %>
      <% else %>
        <% if pos_receipt_line_show_quantity_detail?(line) %>
          <p class="ss-receipt-line__detail"><%= line.quantity.abs %> @ <%= pos_receipt_money(pos_receipt_line_unit_paid_amount_cents(line)) %></p>
        <% end %>
        <% if pos_receipt_line_show_list_detail?(line) %>
          <p class="ss-receipt-line__detail">List price <%= pos_money(pos_receipt_line_unit_list_amount_cents(line)) %></p>
        <% end %>
        <% pos_receipt_line_discount_details(line).each do |detail| %>
          <p class="ss-receipt-line__detail"><%= detail.label %> −<%= pos_money(detail.amount_cents) %></p>
        <% end %>
        <% if line.gift_card_sale_line? %>
          <% if (card_number = pos_gift_card_sale_receipt_identifier_value(line)).present? %>
            <p class="ss-receipt-line__detail">Card number <%= card_number %></p>
          <% end %>
          <% value_label = pos_gift_card_sale_receipt_reload?(line) ? "Reload amount" : "Value" %>
          <p class="ss-receipt-line__detail"><%= value_label %> <%= pos_money(line.extended_price_cents) %></p>
          <% if (balance_cents = pos_gift_card_sale_receipt_balance_cents(line)).present? %>
            <p class="ss-receipt-line__detail ss-receipt-line__detail--emphasis">New balance <%= pos_money(balance_cents) %></p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</article>
