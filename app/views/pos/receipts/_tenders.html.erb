<section class="ss-receipt-tenders">
  <% transaction.pos_tenders.settlement_rows.order(:line_number).each do |tender| %>
    <div class="ss-receipt-row">
      <span><%= pos_tender_receipt_label(tender) %></span>
      <strong><%= pos_receipt_money(pos_tender_receipt_amount_cents(tender)) %></strong>
    </div>
    <% if tender.tender_type == "cash" && tender.amount_cents != pos_tender_receipt_amount_cents(tender) %>
      <div class="ss-receipt-row">
        <span>Cash applied</span>
        <strong><%= pos_receipt_money(tender.amount_cents) %></strong>
      </div>
    <% end %>
  <% end %>

  <% change_cents = pos_receipt_change_cents(transaction) %>
  <% if change_cents.positive? %>
    <div class="ss-receipt-row ss-receipt-row--total">
      <span>Change</span>
      <strong><%= pos_receipt_money(change_cents) %></strong>
    </div>
  <% end %>
</section>
