<% return_path = local_assigns.fetch(:return_path, nil) %>
<% back_path = return_path.presence || pos_transaction_path(transaction) %>
<% back_label = return_path.present? ? "Back to completed sale" : "Back to summary" %>

<div class="ss-pos-no-print ss-receipt-actions" data-controller="pos-receipt-print" data-pos-receipt-print-print-url-value="<%= print_pos_receipt_path(receipt) %>">
  <%= render "shared/ui/button",
             label: "Print",
             variant: :primary,
             class: "ss-receipt-actions__print",
             data: { action: "pos-receipt-print#print" } %>

  <%= render "shared/ui/button",
             label: back_label,
             variant: :secondary,
             class: "ss-receipt-actions__back",
             url: back_path %>

  <%= render "pos/transactions/issuance_slip_links", transaction: transaction %>
</div>
