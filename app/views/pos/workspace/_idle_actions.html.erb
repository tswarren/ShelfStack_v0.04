<div class="ss-pos-workspace__actions">
  <%= button_to "New sale", pos_transactions_path, method: :post, params: { mode: "sale" }, class: "ss-btn ss-btn-secondary" %>
  <% held_count = @suspended_transactions&.size.to_i %>
  <% if held_count.positive? %>
    <button type="button"
            class="ss-btn ss-btn-secondary"
            data-action="pos-command-bar#openHeldDrawer">
      Held sales (<%= held_count %>)
    </button>
  <% end %>
  <button type="button"
          class="ss-btn ss-btn-secondary"
          data-action="pos-command-bar#openSessionDrawer">
    Session
  </button>
  <%= link_to "Reports", pos_reports_path, class: "ss-btn ss-btn-secondary" %>
  <%= link_to "Check Balance", pos_stored_value_balance_path, class: "ss-btn ss-btn-secondary" %>
</div>
